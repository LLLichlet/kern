// source: callback coercions must not synthesize a thunk that downcasts the parameter side through a trait-object upcast
// stderr: expected `*Fn(*Derived[4]) i32`

type Base[N: usize] = trait {
    tag: fn() i32,
};

type Derived[N: usize]: Base[N] = trait {};

type X = struct {};

impl *X: Derived[4] {}

impl *X: Base[4] {
    fn tag() i32 {
        return 7;
    }
}

fn use_base(value: *Base[4]) i32 {
    return value.tag();
}

fn take(cb: *Fn(*Derived[4]) i32) i32 {
    let x = X.{};
    let derived = *Derived[4].{ x.& };
    return cb(derived);
}

fn main() i32 {
    return take(use_base) - 7;
}
