trait Left {};
trait Right {};

impl i32 : Left {}
impl i32 : Right {}

trait Pick {
    type Out;
};

struct Box[T] {
    value: T,
};

impl[T] Box[T]: Pick where T: Left {
    type Out = i32;
}

impl[T] Box[T]: Pick where T: Right {
    type Out = bool;
}

fn take(value: Box[i32].Pick.Out) i32 {
    return 0;
}

fn main() i32 {
    return take(1);
}
