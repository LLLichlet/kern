// class: projection-cycle
// stderr: recursive associated type projection cycle detected
// stderr: projection repeatedly re-enters the same impl-associated type

trait Loop[N: usize] {
    type Out;
};

struct X {};

impl[N: usize] X: Loop[N] {
    type Out = X.Loop[N + 1].Out;
}

fn project(value: X) X.Loop[0].Out {
    _ = value;
    return X.{};
}

fn main() i32 {
    _ = project(X.{});
    return 0;
}
