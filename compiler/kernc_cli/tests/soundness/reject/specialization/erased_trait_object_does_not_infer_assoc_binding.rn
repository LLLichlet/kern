// stderr: cannot infer generic argument(s) `T` for function `take`

type Base[N: usize] = trait {
    type Out;
    make: fn() Out,
};

type X = struct {};

impl *X: Base[4] {
    type Out = i64;

    fn make() Out {
        return 7;
    }
}

fn erase(value: *Base[4]) *Base[4] {
    return value;
}

fn take[T](value: *Base[4, Out = T]) T {
    return value.make();
}

fn main() i32 {
    let x = X.{};
    return (take(erase(*Base[4].{ x.& })) as i32) - 7;
}
