// source: a bare supertrait bound on a generic type does not pin inherited associated types via downstream impl selection
// stderr: required bound: `T: Base[4, Out = i64]`

trait Base[N: usize] {
    type Out;
    fn value() i32;
};

trait Derived[N: usize]: Base[N] {};

struct X {};

impl[N: usize] &X: Derived[N] {}

impl[N: usize] &X: Base[N] {
    type Out = i32;

    fn value() i32 {
        return 1;
    }
}

impl &X: Base[4] {
    type Out = i64;

    fn value() i32 {
        return 9;
    }
}

fn need_base[T](value: T) i32
    where T: Base[4, Out = i64],
{
    return value.value();
}

fn need_derived[T](value: T) i32
    where T: Derived[4],
{
    return need_base(value);
}

fn main() i32 {
    let x = X.{};
    return need_derived(x.&) - 9;
}
