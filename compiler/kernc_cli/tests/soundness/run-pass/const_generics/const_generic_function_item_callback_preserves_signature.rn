fn takes(cb: *Fn([4]i32) i32) i32 {
    return cb([4]i32.{ 1, 2, 3, 4 });
}

fn last[N: usize](arr: [N]i32) i32 {
    return arr.[N - 1];
}

fn main() i32 {
    return takes(last[4]) - 4;
}
