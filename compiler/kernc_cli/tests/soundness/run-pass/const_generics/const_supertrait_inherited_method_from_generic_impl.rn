// class: const-generic-supertrait-dispatch
// source: inherited trait-object methods should keep const generic arguments when the impl is generic only in the trait head
// exit: 0

trait Base[N: usize] {
    fn value() i32;
};

trait Derived[N: usize]: Base[N] {};

struct X {};

impl[N: usize] &X: Derived[N] {}

impl[N: usize] &X: Base[N] {
    fn value() i32 {
        return N as i32;
    }
}

fn main() i32 {
    let x = X.{};
    let derived = &Derived[4].{ x.& };
    return derived.value() - 4;
}
