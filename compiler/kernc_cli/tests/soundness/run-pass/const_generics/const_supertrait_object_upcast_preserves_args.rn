// class: const-generic-supertrait-upcast
// source: trait-object upcasts through supertraits must substitute const generic arguments when matching the target trait
// exit: 0

trait Base[N: usize] {
    fn value() i32;
};

trait Derived[N: usize]: Base[N] {};

struct X {};

impl &X: Derived[4] {}

impl &X: Base[4] {
    fn value() i32 {
        return 7;
    }
}

fn main() i32 {
    let x = X.{};
    let derived = (x.& as &Derived[4]);
    let base = (derived as &Base[4]);
    return base.value() - 7;
}
