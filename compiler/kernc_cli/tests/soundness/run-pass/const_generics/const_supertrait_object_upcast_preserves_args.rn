// class: const-generic-supertrait-upcast
// source: trait-object upcasts through supertraits must substitute const generic arguments when matching the target trait
// exit: 0

type Base[N: usize] = trait {
    value: fn() i32,
};

type Derived[N: usize]: Base[N] = trait {};

type X = struct {};

impl *X: Derived[4] {}

impl *X: Base[4] {
    fn value() i32 {
        return 7;
    }
}

fn main() i32 {
    let x = X.{};
    let derived = *Derived[4].{ x.& };
    let base = *Base[4].{ derived };
    return base.value() - 7;
}
