trait Base[N: usize] {
    fn value() i32;
};

trait Derived[N: usize]: Base[N] {};

struct X {};

impl &X: Derived[4] {}

impl &X: Base[4] {
    fn value() i32 {
        return 7;
    }
}

fn main() i32 {
    let x = X.{};
    let derived = &Derived[4].{ x.& };
    let base = &Base[4].{ derived };
    return base.value() - 7;
}
