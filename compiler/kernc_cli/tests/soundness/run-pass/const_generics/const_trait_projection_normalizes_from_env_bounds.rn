// class: const-generic-projection
// source: projection normalization through active trait bounds must preserve const trait arguments
// exit: 0

type HasOut[N: usize] = trait {
    type Out;
};

type X = struct {};

impl X: HasOut[1] {
    type Out = i32;
}

fn lift[T](value: T.HasOut[1].Out) T.HasOut[1].Out
    where T: HasOut[1, Out = i32],
{
    return value;
}

fn main() i32 {
    return lift[X](7) - 7;
}
