// class: const-generic-coherence
// source: impls that differ only in target const arguments are disjoint, not overlapping
// exit: 0

type Flag = trait {
    value: fn() i32,
};

type Box[N: usize] = struct {};

impl Box[1]: Flag {
    fn value() i32 {
        return 1;
    }
}

impl Box[2]: Flag {
    fn value() i32 {
        return 2;
    }
}

fn main() i32 {
    return Box[2].{}.value() - 2;
}
