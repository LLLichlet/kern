// source: loops, mutation, and enum pattern matching compose without special-case lowering interactions
enum Step {
    Add: i32,
    Stop,
}

fn apply(step: Step, current: i32) i32 {
    return match step {
        .{ Add: amount } => current + amount,
        .Stop => current,
    };
}

fn main() i32 {
    let mut total = 0i32;
    let mut index = 0i32;
    while index < 4i32 {
        total = apply(Step.{ Add: index }, total);
        index += 1i32;
    }
    return total - 6i32;
}
