// exit: 0

type Base[N: usize] = trait {
    type Out;
};

type Derived[N: usize]: Base[N] = trait {
    more: fn() i32,
};

type X = struct {};

impl[N: usize] *X: Derived[N] {
    fn more() i32 {
        return 2;
    }
}

impl[N: usize] *X: Base[N] {
    type Out = i32;
}

impl *X: Base[4] {
    type Out = i64;
}

fn take(value: *Derived[4]) i32 {
    return value.more() - 2;
}

fn main() i32 {
    let x = X.{};
    let derived = *Derived[4].{ x.& };
    return take(derived);
}
