// class: modules-inline-const-static
// source: inline modules must have independent item scopes for same-named consts and statics
// exit: 0

mod left {
    const SHARED = 11i32;
    static VALUE = 31i32;

    pub fn read() i32 {
        return SHARED + VALUE;
    }
}

mod right {
    const SHARED = 7i32;
    static VALUE = 13i32;

    pub fn read() i32 {
        return SHARED + VALUE;
    }
}

fn main() i32 {
    return left.read() + right.read() - 62;
}
