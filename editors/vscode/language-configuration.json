{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\s`~!@#%^&*()=+\\[{\\]}\\\\|;:'\\\",.<>/?]+)",
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["/*", "*/"]
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*(?:\\{|\\(|\\[)\\s*$",
    "decreaseIndentPattern": "^\\s*(?:\\}|\\)|\\])"
  }
}
