{
  "name": "kern-language",
  "displayName": "Kern",
  "description": "VS Code support for the Kern programming language.",
  "version": "0.8.2",
  "publisher": "kern-project",
  "icon": "icons/kern.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kern-project/kern.git"
  },
  "homepage": "https://github.com/kern-project/kern",
  "bugs": {
    "url": "https://github.com/kern-project/kern/issues"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "kern",
    "systems",
    "compiler",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:kern",
    "onCommand:kern.restartLanguageServer",
    "onCommand:kern.showLanguageServerOutput",
    "onCommand:kern.craft.buildPackage",
    "onCommand:kern.craft.runTarget",
    "onCommand:kern.craft.testTarget",
    "workspaceContains:**/*.kn"
  ],
  "main": "./extension.js",
  "contributes": {
    "configurationDefaults": {
      "[kern]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        },
        "editor.wordBasedSuggestions": "off"
      }
    },
    "languages": [
      {
        "id": "kern",
        "aliases": [
          "Kern",
          "kern"
        ],
        "extensions": [
          ".kn"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kern-light.svg",
          "dark": "./icons/kern-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kern",
        "scopeName": "source.kern",
        "path": "./syntaxes/kern.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "kern",
        "scopes": {
          "namespace": [
            "entity.name.namespace.kern",
            "variable.other.namespace.kern"
          ],
          "type": [
            "entity.name.type.kern"
          ],
          "struct": [
            "entity.name.type.kern",
            "entity.name.type.constructor.kern"
          ],
          "enum": [
            "entity.name.type.kern"
          ],
          "interface": [
            "entity.name.type.kern",
            "support.type.trait.kern"
          ],
          "typeParameter": [
            "entity.name.type.parameter.kern"
          ],
          "parameter": [
            "variable.parameter.kern"
          ],
          "variable": [
            "variable.other.kern"
          ],
          "property": [
            "variable.other.member.kern",
            "variable.other.property.kern"
          ],
          "function": [
            "entity.name.function.kern",
            "entity.name.function.call.kern"
          ],
          "method": [
            "entity.name.function.member.kern",
            "entity.name.function.method.kern"
          ],
          "enumMember": [
            "constant.other.enum-variant.kern",
            "entity.name.type.enum-variant.kern"
          ]
        }
      }
    ],
    "snippets": [
      {
        "language": "kern",
        "path": "./snippets/kern.json"
      }
    ],
    "commands": [
      {
        "command": "kern.restartLanguageServer",
        "title": "Kern: Restart Language Server"
      },
      {
        "command": "kern.showLanguageServerOutput",
        "title": "Kern: Show Language Server Output"
      },
      {
        "command": "kern.refreshCraftAnalysisContext",
        "title": "Kern: Refresh Craft Analysis Context"
      },
      {
        "command": "kern.craft.buildPackage",
        "title": "Kern: Build Package"
      },
      {
        "command": "kern.craft.runTarget",
        "title": "Kern: Run Target"
      },
      {
        "command": "kern.craft.testTarget",
        "title": "Kern: Run Test Target"
      }
    ],
    "configuration": {
      "title": "Kern",
      "properties": {
        "kern.craft.path": {
          "type": "string",
          "default": "",
          "description": "Path to the craft executable used by the refresh-analysis command. Leave empty to use craft on PATH."
        },
        "kern.toolchain.path": {
          "type": "string",
          "default": "",
          "description": "Path to a Kern toolchain root that contains bin/kern-lsp and lib/kern. Leave empty to use PATH, KERN_HOME, or the default ~/.kern install."
        },
        "kern.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the kern-lsp executable. Leave empty to use the configured toolchain root, PATH, KERN_HOME, a default install, or a workspace build."
        },
        "kern.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional command-line arguments passed to kern-lsp."
        },
        "kern.server.env": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string"
          },
          "description": "Extra environment variables to inject into the kern-lsp process."
        },
        "kern.project.features": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Explicit craft features enabled for workspace analysis."
        },
        "kern.project.noDefaultFeatures": {
          "type": "boolean",
          "default": false,
          "description": "Disable default craft features for workspace analysis."
        },
        "kern.editor.autoSuggest": {
          "type": "string",
          "default": "keywords",
          "enum": [
            "off",
            "keywords",
            "aggressive"
          ],
          "enumDescriptions": [
            "Never force-open the suggestion widget from the extension.",
            "Only auto-trigger suggestions for likely keyword prefixes in code positions.",
            "Auto-trigger suggestions for most identifier typing in code positions."
          ],
          "description": "Controls how aggressively the Kern extension asks VS Code to open completions while typing. This does not affect explicit completion requests."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run sync:icons && npm run compile",
    "compile": "tsc -p ./ && node ./scripts/build-extension.mjs",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "test": "npm run compile && node ./scripts/run-tests.mjs",
    "sync:icons": "node ./scripts/sync-icons.mjs",
    "package:vsix": "npm run sync:icons && node ./scripts/package-vsix.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.86.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "vscode-languageclient": "^9.0.1",
    "typescript": "^5.5.4",
    "yazl": "^2.5.1"
  }
}
