{
  "name": "kern-vscode",
  "displayName": "Kern",
  "description": "VS Code support for the Kern programming language.",
  "version": "0.6.5",
  "publisher": "softfault",
  "icon": "icons/kern.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/softfault/kern.git"
  },
  "homepage": "https://github.com/softfault/kern",
  "bugs": {
    "url": "https://github.com/softfault/kern/issues"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "kern",
    "systems",
    "compiler",
    "language-server"
  ],
  "activationEvents": [
    "onLanguage:kern",
    "onCommand:kern.restartLanguageServer",
    "onCommand:kern.showLanguageServerOutput",
    "workspaceContains:**/*.rn"
  ],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kern",
        "aliases": [
          "Kern",
          "kern"
        ],
        "extensions": [
          ".rn"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kern.svg",
          "dark": "./icons/kern.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kern",
        "scopeName": "source.kern",
        "path": "./syntaxes/kern.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kern",
        "path": "./snippets/kern.json"
      }
    ],
    "commands": [
      {
        "command": "kern.restartLanguageServer",
        "title": "Kern: Restart Language Server"
      },
      {
        "command": "kern.showLanguageServerOutput",
        "title": "Kern: Show Language Server Output"
      }
    ],
    "configuration": {
      "title": "Kern",
      "properties": {
        "kern.server.path": {
          "type": "string",
          "default": "",
          "description": "Path to the kern-lsp executable. Leave empty to use the bundled server, a workspace build, or PATH."
        },
        "kern.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional command-line arguments passed to kern-lsp."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run stage:server",
    "compile": "tsc -p ./ && node ./scripts/build-extension.mjs",
    "watch": "tsc -watch -p ./",
    "check": "tsc -p ./ --noEmit",
    "test": "npm run compile && node --test out/test/serverResolution.test.js",
    "stage:server": "node ./scripts/stage-server.mjs",
    "package:vsix": "node ./scripts/package-vsix.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.86.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "vscode-languageclient": "^9.0.1",
    "typescript": "^5.5.4"
  }
}
