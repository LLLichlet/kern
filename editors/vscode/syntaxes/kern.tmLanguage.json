{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kern",
  "scopeName": "source.kern",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#types"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kern",
          "match": "//.*$"
        },
        {
          "name": "comment.block.kern",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.kern",
          "begin": "#\\[",
          "end": "\\]",
          "patterns": [
            {
              "name": "entity.other.attribute-name.kern",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kern",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kern",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.kern",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.kern",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.kern",
          "match": "\\b(?:0x[0-9A-Fa-f_]+|0b[01_]+|0o[0-7_]+|\\d+(?:_\\d+)*(?:\\.\\d+(?:_\\d+)*)?)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kern",
          "match": "\\b(?:if|else|for|match|break|continue|return|defer|where|use|mod|impl|extern|pub|as)\\b"
        },
        {
          "name": "storage.modifier.kern",
          "match": "\\b(?:let|mut|const|static)\\b"
        },
        {
          "name": "storage.type.kern",
          "match": "\\b(?:fn|type|struct|union|enum|trait|void)\\b"
        },
        {
          "name": "constant.language.kern",
          "match": "\\b(?:true|false|undef|Self|self)\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "entity.name.function.kern",
          "match": "(?<=\\bfn\\s)([A-Za-z_][A-Za-z0-9_]*)"
        },
        {
          "name": "entity.name.type.kern",
          "match": "(?<=\\btype\\s)([A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.kern",
          "match": "\\b(?:i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|str)\\b"
        },
        {
          "name": "support.class.kern",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.kern",
          "match": "\\.\\.=|\\.\\.|\\.\\*|\\.\\{|\\.\\[|\\.\\&|\\.\\.\\&|\\.\\.\\[|==|!=|<=|>=|<<=|>>=|<<|>>|->|=>|[+\\-*/%&|^~!=<>]"
        }
      ]
    }
  }
}
