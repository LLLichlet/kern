{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kern",
  "scopeName": "source.kern",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#attributes"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#intrinsics"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#genericArguments"
    },
    {
      "include": "#impls"
    },
    {
      "include": "#closures"
    },
    {
      "include": "#constructors"
    },
    {
      "include": "#variants"
    },
    {
      "include": "#traitMembers"
    },
    {
      "include": "#fields"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.kern",
          "match": "//.*$"
        },
        {
          "name": "comment.block.kern",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [
            {
              "include": "#comments"
            }
          ]
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.kern",
          "begin": "#\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.attribute.begin.kern"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.attribute.end.kern"
            }
          },
          "patterns": [
            {
              "name": "entity.other.attribute-name.kern",
              "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#numbers"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kern",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.kern"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.kern"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.kern",
              "match": "\\\\(?:x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\}|.)"
            }
          ]
        },
        {
          "name": "string.quoted.single.kern",
          "begin": "(?:b)?'",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.kern"
            }
          },
          "end": "'",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.kern"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.kern",
              "match": "\\\\(?:x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f_]+\\}|.)"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.kern",
          "match": "\\b(?:0x[0-9A-Fa-f_]+|0b[01_]+|0o[0-7_]+|\\d+(?:_\\d+)*(?:\\.\\d+(?:_\\d+)*)?(?:[eE][+-]?\\d+(?:_\\d+)*)?)\\b"
        }
      ]
    },
    "intrinsics": {
      "patterns": [
        {
          "name": "support.function.intrinsic.kern",
          "match": "@[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.kern",
          "begin": "\\b(?:pub\\s+use|use)\\b",
          "beginCaptures": {
            "0": {
              "name": "keyword.control.import.kern"
            }
          },
          "end": ";",
          "endCaptures": {
            "0": {
              "name": "punctuation.terminator.statement.kern"
            }
          },
          "patterns": [
            {
              "name": "entity.name.namespace.kern",
              "match": "\\b[a-z][A-Za-z0-9_]*\\b(?=\\s*(?:\\.\\{|\\.))"
            },
            {
              "name": "support.type.imported.kern",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "name": "punctuation.separator.path.kern",
              "match": "\\.(?=\\{|[A-Za-z_])"
            },
            {
              "name": "punctuation.section.group.begin.kern",
              "match": "\\{"
            },
            {
              "name": "punctuation.section.group.end.kern",
              "match": "\\}"
            },
            {
              "name": "punctuation.separator.comma.kern",
              "match": ","
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.function.definition.kern",
          "match": "\\b(?:(?:pub|extern|const)\\s+)*(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.kern"
            },
            "2": {
              "name": "entity.name.function.kern"
            }
          }
        },
        {
          "name": "meta.type.definition.kern",
          "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:(\\s*:)\\s*([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": {
              "name": "keyword.control.kern"
            },
            "2": {
              "name": "entity.name.type.kern"
            },
            "3": {
              "name": "punctuation.separator.type-constraint.kern"
            },
            "4": {
              "name": "support.type.primitive.kern"
            }
          }
        },
        {
          "name": "meta.module.definition.kern",
          "match": "\\b(mod)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.module.kern"
            },
            "2": {
              "name": "entity.name.namespace.kern"
            }
          }
        }
      ]
    },
    "genericArguments": {
      "patterns": [
        {
          "name": "meta.generic.arguments.kern",
          "begin": "\\b([A-Za-z_][A-Za-z0-9_]*|@(?:typeOf|sizeOf|alignOf))\\s*(\\[)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.parameter.kern"
            },
            "2": {
              "name": "punctuation.definition.generic.begin.kern"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.generic.end.kern"
            }
          },
          "patterns": [
            {
              "name": "entity.name.type.parameter.kern",
              "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
            },
            {
              "include": "#types"
            },
            {
              "include": "#numbers"
            },
            {
              "name": "punctuation.separator.comma.kern",
              "match": ","
            }
          ]
        }
      ]
    },
    "impls": {
      "patterns": [
        {
          "name": "meta.impl.kern",
          "match": "\\b(impl)(\\s*\\[[^\\]]+\\])?(?:\\s+([^:{=\\n]+?))?(?:\\s*(:)\\s*([^\\{\\n]+))?",
          "captures": {
            "1": {
              "name": "keyword.control.implementation.kern"
            },
            "2": {
              "name": "meta.generic.parameters.kern"
            },
            "3": {
              "name": "entity.name.type.impl-target.kern"
            },
            "4": {
              "name": "punctuation.separator.trait-impl.kern"
            },
            "5": {
              "name": "support.type.trait.kern"
            }
          }
        }
      ]
    },
    "closures": {
      "patterns": [
        {
          "name": "meta.closure.kern",
          "begin": "\\.\\[",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.closure.begin.kern"
            }
          },
          "end": "\\]",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.closure.end.kern"
            }
          },
          "patterns": [
            {
              "name": "variable.parameter.capture.kern",
              "match": "\\b[a-zA-Z_][A-Za-z0-9_]*\\b(?=\\s*=)"
            },
            {
              "name": "variable.other.capture.kern",
              "match": "\\b[a-zA-Z_][A-Za-z0-9_]*\\b"
            },
            {
              "name": "keyword.operator.assignment.kern",
              "match": "="
            },
            {
              "name": "punctuation.separator.comma.kern",
              "match": ","
            },
            {
              "include": "#intrinsics"
            },
            {
              "include": "#numbers"
            },
            {
              "include": "#strings"
            },
            {
              "include": "#operators"
            }
          ]
        }
      ]
    },
    "constructors": {
      "patterns": [
        {
          "name": "entity.name.type.constructor.kern",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s*\\.\\{)"
        },
        {
          "name": "entity.name.type.constructor.kern",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s*\\[[^\\]]*\\]\\s*\\.\\{)"
        },
        {
          "name": "keyword.control.kern",
          "match": "\\b(?:extern\\s+)?(?:struct|union|enum|trait)\\b(?=\\s*(?::\\s*[A-Za-z_][A-Za-z0-9_]*\\s*)?\\{)"
        },
        {
          "name": "support.type.primitive.constructor.kern",
          "match": "\\b(?:i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|str)\\b(?=\\s*\\.\\{)"
        },
        {
          "name": "punctuation.definition.constructor.kern",
          "match": "\\.\\{"
        }
      ]
    },
    "variants": {
      "patterns": [
        {
          "name": "constant.other.enum-variant.kern",
          "match": "\\.[A-Z][A-Za-z0-9_]*\\b"
        },
        {
          "name": "entity.name.enum-variant.kern",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s*(?:=|,|\\}))"
        }
      ]
    },
    "traitMembers": {
      "patterns": [
        {
          "name": "entity.name.function.member.kern",
          "match": "\\b[a-zA-Z_][A-Za-z0-9_]*\\b(?=\\s*:\\s*fn\\b)"
        }
      ]
    },
    "fields": {
      "patterns": [
        {
          "name": "variable.other.member.kern",
          "match": "\\b[a-zA-Z_][A-Za-z0-9_]*\\b(?=\\s*:)"
        },
        {
          "name": "variable.other.property.kern",
          "match": "(?<=\\.)[a-zA-Z_][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.kern",
          "match": "\\b(?:i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|str)\\b"
        },
        {
          "name": "keyword.operator.pointer.kern",
          "match": "\\*mut\\b|\\^mut\\b|\\*\\b|\\^\\b"
        },
        {
          "name": "support.type.slice.kern",
          "match": "\\[\\](?:mut\\b)?"
        },
        {
          "name": "support.type.array.kern",
          "match": "\\[(?:_|\\d+(?:_\\d+)*)\\]"
        },
        {
          "name": "keyword.control.kern",
          "match": "\\bFn\\b"
        },
        {
          "name": "support.type.trait.kern",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s*\\{)"
        },
        {
          "name": "keyword.control.kern",
          "match": "\\bSelf\\b"
        },
        {
          "name": "entity.name.type.parameter.kern",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.call.kern",
          "match": "\\b(?!if\\b|else\\b|for\\b|match\\b|return\\b|defer\\b|while\\b|switch\\b)[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        },
        {
          "name": "entity.name.function.method.kern",
          "match": "(?<=\\.)[A-Za-z_][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kern",
          "match": "\\b(?:if|else|for|match|break|continue|return|defer|where|impl|as)\\b"
        },
        {
          "name": "keyword.control.import-export.kern",
          "match": "\\b(?:use|pub|mod|extern)\\b"
        },
        {
          "name": "keyword.control.kern",
          "match": "\\b(?:let|mut|const|static)\\b"
        },
        {
          "name": "keyword.control.kern",
          "match": "\\b(?:fn|type|struct|union|enum|trait|void)\\b"
        },
        {
          "name": "keyword.control.kern",
          "match": "\\b(?:and|or)\\b"
        },
        {
          "name": "keyword.control.kern",
          "match": "\\b(?:true|false|undef|self)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pointer.kern",
          "match": "\\.\\*|\\.\\&|\\.\\.\\&|\\.\\[|\\.\\.\\["
        },
        {
          "name": "keyword.operator.range.kern",
          "match": "\\.\\.=|\\.\\."
        },
        {
          "name": "keyword.operator.assignment.kern",
          "match": "<<=|>>=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|="
        },
        {
          "name": "keyword.operator.comparison.kern",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arrow.kern",
          "match": "->|=>"
        },
        {
          "name": "keyword.operator.arithmetic.kern",
          "match": "<<|>>|[+\\-*/%&|^~!]"
        }
      ]
    }
  }
}
