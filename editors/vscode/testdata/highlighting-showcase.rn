use base.sync.{MemOrder, ACQUIRE, RELEASE};

#[export_name("_start")]
extern fn start() ! {
    let mut counter = i32.{0};
    let device = SerialPort.{ port: 0x3F8 };
    let state = Option[i32].{ Some: 7 };
    let anon = struct { left: i32, right: i32 }.{ left: 1, right: 2 };
    let flag = enum: u8 { Off = 0, On = 1 }.On;
    let callback = [ptr = counter..&](value: i32) i32 {
        ptr.* += value;
        return ptr.*;
    };

    @asm(.{
        asm: .{ "out dx, al", },
        inputs: .{ dx: device.port, al: 0xFF },
        volatile: true
    });

    _ = match (state) {
        .{ Some: value } => callback(value),
        .None => @trap(),
    };

    let byte = device.buffer.[0];
    let view = device.buffer..&[0 .. 4];
    let io = &mut Writer.{ device..& };
    let heap_cb = &mut Fn(i32) i32.{ callback };
    _ = io.write(view as &[u8]);
    _ = heap_cb(anon.left + (flag as i32));
    @unreachable();
}

trait Writer {
    fn write(bytes: &[u8]) i32;
};

pub enum Option[T] {
    Some: T,
    None,
};

struct SerialPort {
    port: u16 = 0x3F8,
    buffer: [16]u8 = [16]u8.{ undef },
};

trait Printable {
    fn render() void;
};

impl[T] &Option[T] : Printable {
    pub fn render() void {
        _ = match (self.*) {
            .{ Some: value } => value,
            .None => 0,
        };
    }
}
