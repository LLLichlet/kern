use base.coll.{List, list};
use base.mem.alloc.gpa;
use std.io;
use base.test.report;
use std.mem.page;

fn main() i32 {
    let t = report(io.stderr())..&;

    let page = page()..&;
    let gpa = gpa().on(page)..&;

    let list = list[i32]()..&;
    defer list.deinit(gpa);

    list
        .try_push(gpa, 3)
        .should_ok()
        .sum(@loc(), t);
    list
        .try_push(gpa, 1)
        .should_ok()
        .sum(@loc(), t);
    list
        .try_push(gpa, 2)
        .should_ok()
        .sum(@loc(), t);

    list.as_mut_slice().sort();
    (list.view().as_slice() == [3]i32.{ 1, 2, 3 }).should().sum(@loc(), t);

    let found = list.view().position([](value: i32) bool {
        return value == 2;
    }).should_some().sum(@loc(), t);
    (found == 1usize).should().sum(@loc(), t);

    "collections: len={}, middle index={}".fmt(.{list.view().len(), found}).println();
    return 0;
}
