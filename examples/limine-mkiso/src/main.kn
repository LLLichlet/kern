use base.coll.String;
use base.mem.alloc.gpa;
use std.fs;
use std.proc;
use std.mem.Page;

fn write_stderr(text: &[u8]) void {
    let mut stderr = fs.stderr();
    _ = stderr..&.write_all(text);
}

fn write_stderr_line(text: &[u8]) void {
    write_stderr(text);
    write_stderr("\n");
}

fn fail(text: &[u8]) i32 {
    write_stderr_line(text);
    return 1;
}

fn push_shell_arg(
    out: &mut String,
    alloc: &mut base.mem.alloc.Allocator,
    arg: &[u8],
) bool {
    if out.is_empty().not() and out.try_push_char(alloc, b' ').is_ok().not() {
        return false;
    }
    if out.try_push_char(alloc, b'\'').is_ok().not() {
        return false;
    }
    let mut i = 0usize;
    while i < arg.@len() {
        if arg.[i] == b'\'' {
            if out.try_push_str(alloc, "'\"'\"'").is_ok().not() {
                return false;
            }
            i += 1;
            continue;
        }
        if out.try_push_char(alloc, arg.[i]).is_ok().not() {
            return false;
        }
        i += 1;
    }
    return out.try_push_char(alloc, b'\'').is_ok();
}

fn run_shell(
    alloc: &mut base.mem.alloc.Allocator,
    label: &[u8],
    command: &String,
) bool {
    let .{ Ok: capture } = command.as_str().shell_capture(alloc) else {
        .{ Err: _ } => {
            write_stderr("limine-mkiso: failed to spawn command for ");
            write_stderr_line(label);
            return false;
        },
    };
    let mut capture = capture;
    defer capture.output..&.deinit(alloc);

    if capture.status == 0 {
        return true;
    }

    write_stderr("limine-mkiso: command failed for ");
    write_stderr_line(label);
    write_stderr(command.as_str());
    write_stderr("\n");
    if capture.output.&.is_empty().not() {
        let output = capture.output.&.as_str();
        write_stderr(output);
        if output.ends_with("\n").not() {
            write_stderr("\n");
        }
    }
    return false;
}

fn main(argc: i32, argv: &&u8) i32 {
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let args = proc.args(argc, argv);

    if args.len() != 4 {
        return fail("usage: limine-mkiso <kernel-path> <build-root> <limine-root>");
    }

    let .{ Some: kernel_path } = args.get(1) else return fail(
        "usage: limine-mkiso <kernel-path> <build-root> <limine-root>",
    );
    let .{ Some: build_root } = args.get(2) else return fail(
        "usage: limine-mkiso <kernel-path> <build-root> <limine-root>",
    );
    let .{ Some: limine_root } = args.get(3) else return fail(
        "usage: limine-mkiso <kernel-path> <build-root> <limine-root>",
    );
    let .{ Some: iso_root } = fs.parent(kernel_path) else {
        return fail("limine-mkiso: kernel path did not include an iso-root parent");
    };

    let .{ Ok: tmp_iso } = fs.join(gpa, build_root, "limine-image.tmp.iso") else {
        return fail("limine-mkiso: failed to allocate temporary ISO path");
    };
    let mut tmp_iso = tmp_iso;
    let tmp_iso = tmp_iso..&;
    defer tmp_iso.deinit(gpa);

    let .{ Ok: limine_tool } = fs.join(gpa, limine_root, "limine") else {
        return fail("limine-mkiso: failed to allocate limine tool path");
    };
    let mut limine_tool = limine_tool;
    let limine_tool = limine_tool..&;
    defer limine_tool.deinit(gpa);

    _ = tmp_iso
        .as_str()
        .path()
        .remove_file_if_exists(gpa);

    let make_cmd = String.{}..&;
    defer make_cmd.deinit(gpa);
    if make_cmd.try_push_str(gpa, "make -C").is_ok().not()
        or push_shell_arg(make_cmd, gpa, limine_root).not()
        or make_cmd.try_push_str(gpa, " limine").is_ok().not()
    {
        return fail("limine-mkiso: failed to build limine make command");
    }
    if run_shell(gpa, "make limine", make_cmd).not() {
        return 1;
    }

    let xorriso_cmd = String.{}..&;
    defer xorriso_cmd.deinit(gpa);
    if xorriso_cmd.try_push_str(gpa, "xorriso -as mkisofs").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " -b boot/limine-bios-cd.bin").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " -no-emul-boot").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " -boot-load-size 4").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " -boot-info-table").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " --efi-boot boot/limine-uefi-cd.bin").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " -efi-boot-part").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " --efi-boot-image").is_ok().not()
        or xorriso_cmd.try_push_str(gpa, " --protective-msdos-label").is_ok().not()
        or push_shell_arg(xorriso_cmd, gpa, iso_root).not()
        or xorriso_cmd.try_push_str(gpa, " -o").is_ok().not()
        or push_shell_arg(xorriso_cmd, gpa, tmp_iso.as_str()).not()
    {
        return fail("limine-mkiso: failed to build xorriso command");
    }
    if run_shell(gpa, "xorriso", xorriso_cmd).not() {
        return 1;
    }

    let bios_install_cmd = String.{}..&;
    defer bios_install_cmd.deinit(gpa);
    if push_shell_arg(bios_install_cmd, gpa, limine_tool.as_str()).not()
        or bios_install_cmd.try_push_str(gpa, " bios-install").is_ok().not()
        or push_shell_arg(bios_install_cmd, gpa, tmp_iso.as_str()).not()
    {
        return fail("limine-mkiso: failed to build bios-install command");
    }
    if run_shell(gpa, "limine bios-install", bios_install_cmd).not() {
        return 1;
    }

    let .{ Ok: image } = tmp_iso.as_str().path().open_read(gpa) else {
        return fail("limine-mkiso: failed to open generated ISO");
    };
    let mut image = image;
    let image = image..&;
    defer image.deinit();

    let mut stdout = fs.stdout();
    let .{ Ok: _ } = image.copy_to(stdout..&) else {
        return fail("limine-mkiso: failed to stream ISO to stdout");
    };

    _ = tmp_iso
        .as_str()
        .path()
        .remove_file_if_exists(gpa);
    return 0;
}
