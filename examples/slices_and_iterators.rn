use base.coll.{iter_fold, iter_nth, range, range_down};
use std.io;
use base.io.Writer;
use base.test;

fn main() i32 {
    let mut err = io.stderr();
    let mut ctx = test.context(*mut Writer.{ err..& });

    let mut values = [5]i32.{ 1, 2, 3, 4, 5 };

    let middle = values.[1 .. 4];
    let mut sum = i32.{0};
    for (item: middle.iter()) {
        sum += item;
    }
    ctx..&.eq(sum, 9);

    let mut head = values..[0 .. 3];
    head.reverse();
    ctx..&.eq(values, [5]i32.{ 3, 2, 1, 4, 5 });

    let mut squares = i32.{0};
    for (i: range(1, 4)) {
        squares += i * i;
    }
    ctx..&.eq(squares, 14);

    let mut descending = range_down(5, 2);
    let descending_sum = iter_fold[i32, i32](descending..&, 0, .[](accum: i32, value: i32) i32 {
        return accum + value;
    });
    ctx..&.eq(descending_sum, 12);

    let mut nth = range(10, 20);
    ctx..&.eq(ctx..&.expect_some(iter_nth[i32](nth..&, usize.{4})), 14);

    io.println("slices: sum={}, squares={}, descending={}", .{sum, squares, descending_sum});
    return 0;
}
