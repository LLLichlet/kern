use std.io;
use base.test.report;

fn apply_operation(
    op: &fn(i32, i32) i32,
    a: i32,
    b: i32,
) i32 {
    return op(a, b);
}

fn process_with_context(cb: &Fn(i32) i32, val: i32) i32 {
    return cb(val);
}

fn repeat_twice(cb: &mut Fn() void) void {
    cb();
    cb();
}

fn main() i32 {
    let t = report(io.stderr())..&;

    let sum = apply_operation([](a: i32, b: i32) i32 {
        return a + b;
    }, 10, 20);
    (sum == 30).should().sum(@loc(), t);

    let base = 100i32;
    let result = process_with_context([base](x: i32) i32 {
        return base + x;
    }, 50);
    (result == 150).should().sum(@loc(), t);

    let mut counter = 0i32;
    repeat_twice([ptr = counter..&]() void {
        ptr.* += 1;
    });
    (counter == 2).should().sum(@loc(), t);

    let left = 10i32;
    let right = 20i32;
    let my_closure = [left, right](x: i32) i32 {
        return (left + right) * x;
    };
    (process_with_context((my_closure.& as &Fn(i32) i32), 2) == 60).should().sum(@loc(), t);

    "closures: sum={}, captured={}, counter={}".fmt(.{sum, result, counter}).println();
    return 0;
}
