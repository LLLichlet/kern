use std.io.println;

fn apply_operation(op: fn(i32, i32) i32, a: i32, b: i32) i32 {
    return op(a, b);
}
fn process_with_context(cb: *Fn(i32) i32, val: i32) i32 {
    return cb(val);
}
fn repeat_twice(cb: *mut Fn() void) void {
    cb();
    cb();
}
fn main(args: [][]u8) i32 {
    let sum = apply_operation(.[](a: i32, b: i32) i32 {
        return a + b;
    }, 10, 20);
    println("Decay sum: {}", .{sum.&,}); // 30
    let base = i32.{100};
    let result = process_with_context(.[base](x: i32) i32 {
        return base + x;
    }, 50);
    println("BNC capture by value: {}", .{result.&,}); // 150
    let mut counter = i32.{0};
    repeat_twice(.[ptr = counter..&]() void {
        ptr.* += 1;
    });
    println("Mutated counter: {}", .{counter.&,}); // 2
    let val1 = i32.{10};
    let val2 = i32.{20};
    let my_closure = .[val1, val2](x: i32) i32 { 
        return (val1 + val2) * x; 
    };
    let state_size = @sizeOf[@typeOf(my_closure)]();
    println("Closure state size: {} bytes", .{state_size.&,}); // 8 bytes

    return 0;
}