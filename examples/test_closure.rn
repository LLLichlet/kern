use std.io;
use base.io.Writer;
use base.test;

fn apply_operation(op: fn(i32, i32) i32, a: i32, b: i32) i32 {
    return op(a, b);
}

fn process_with_context(cb: *Fn(i32) i32, val: i32) i32 {
    return cb(val);
}

fn repeat_twice(cb: *mut Fn() void) void {
    cb();
    cb();
}

fn main() i32 {
    let mut err = io.stderr();
    let mut ctx = test.context(*mut Writer.{ err..& });

    let sum = apply_operation(.[](a: i32, b: i32) i32 {
        return a + b;
    }, 10, 20);
    ctx..&.eq(sum, 30);

    let base = i32.{100};
    let result = process_with_context(.[base](x: i32) i32 {
        return base + x;
    }, 50);
    ctx..&.eq(result, 150);

    let mut counter = i32.{0};
    repeat_twice(.[ptr = counter..&]() void {
        ptr.* += 1;
    });
    ctx..&.eq(counter, 2);

    let left = i32.{10};
    let right = i32.{20};
    let my_closure = .[left, right](x: i32) i32 {
        return (left + right) * x;
    };
    ctx..&.eq(process_with_context(*Fn(i32) i32.{ my_closure.& }, 2), 60);

    io.println("closures: sum={}, captured={}, counter={}", .{sum, result, counter});
    return 0;
}
