use base.coll.String;
use base.mem.alloc.{GPA, gpa};
use std.fs;
use base.test;
use std.io;
use sys.mem.Page;
use bed.{buffer, command, editor, input};

fn contains(text: &[u8], needle: &[u8]) bool {
    if (#needle == 0) {
        return true;
    }
    if (#needle > #text) {
        return false;
    }
    let mut i = usize.{0};
    while (i + #needle <= #text) {
        let mut matched = true;
        let mut j = usize.{0};
        while (j < #needle) {
            if (text.[i + j] != needle.[j]) {
                matched = false;
                break;
            }
            j += 1;
        }
        if (matched) {
            return true;
        }
        i += 1;
    }
    return false;
}

fn find_index(text: &[u8], needle: &[u8]) usize {
    if (#needle == 0 or #needle > #text) {
        return #text;
    }
    let mut i = usize.{0};
    while (i + #needle <= #text) {
        let mut matched = true;
        let mut j = usize.{0};
        while (j < #needle) {
            if (text.[i + j] != needle.[j]) {
                matched = false;
                break;
            }
            j += 1;
        }
        if (matched) {
            return i;
        }
        i += 1;
    }
    return #text;
}

fn find_byte(text: &[u8], needle: u8) usize {
    let mut i = usize.{0};
    while (i < #text) {
        if (text.[i] == needle) {
            return i;
        }
        i += 1;
    }
    return #text;
}

fn line_slice(text: &[u8], line_index: usize) &[u8] {
    let mut start = usize.{0};
    let mut current = usize.{0};
    let mut i = usize.{0};
    while (i < #text) {
        if (current == line_index and text.[i] == b'\n') {
            return text.&[start .. i];
        }
        if (text.[i] == b'\n') {
            current += 1;
            start = i + 1;
        }
        i += 1;
    }
    if (current == line_index and start <= #text) {
        return text.&[start .. #text];
    }
    return text.&[0 .. 0];
}

fn find_line_with(text: &[u8], needle: &[u8], max_lines: usize) usize {
    let mut line = usize.{0};
    while (line < max_lines) {
        if (contains(line_slice(text, line), needle)) {
            return line;
        }
        line += 1;
    }
    return max_lines;
}

fn type_text(state: &mut editor.Editor, gpa: &mut GPA, text: &[u8]) void {
    let mut i = usize.{0};
    while (i < #text) {
        state.handle_key(gpa, input.Key.{ Byte: text.[i] });
        i += 1;
    }
}

fn ctrl_w(state: &mut editor.Editor, gpa: &mut GPA, key: u8) void {
    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: key });
}

fn expect_cursor(state: &mut editor.Editor, row: usize, col: usize, label: &[u8]) void {
    let t = test.report(io.stderr())..&;
    _ = label;
    state.cursor_row().should().eq(row).sum(@loc(), t);
    state.cursor_col().should().eq(col).sum(@loc(), t);
}

fn run_ex_command(state: &mut editor.Editor, gpa: &mut GPA, text: &[u8]) void {
    state.handle_key(gpa, .{ Byte: b':' });
    type_text(state, gpa, text);
    state.handle_key(gpa, .Enter);
}

fn smoke_temp_root(gpa: &mut GPA) String {
    let t = test.report(io.stderr())..&;
    let root = String.{}..&;
    root.push_str(gpa, "t").should().sum(@loc(), t);
    _ = root.as_str().path().create_dir_all(gpa).should_ok().sum(@loc(), t);
    return root.*;
}

fn smoke_temp_path(gpa: &mut GPA, name: &[u8]) String {
    let t = test.report(io.stderr())..&;
    let root = smoke_temp_root(gpa)..&;
    defer root.deinit(gpa);
    let path = fs.join(gpa, root.as_str(), name).should_ok().sum(@loc(), t)..&;
    return path.*;
}

fn run_edit_command(state: &mut editor.Editor, gpa: &mut GPA, path: &[u8]) void {
    let t = test.report(io.stderr())..&;
    let command = String.{}..&;
    defer command.deinit(gpa);
    command.push_str(gpa, "e ").should().sum(@loc(), t);
    command.push_str(gpa, path).should().sum(@loc(), t);
    run_ex_command(state, gpa, command.as_str());
}

fn check_command_parse() void {
    let t = test.report(io.stderr())..&;
    match (command.parse("q")) {
        .Quit => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("q!")) {
        .ForceQuit => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("w tmp.txt")) {
        .{ WriteAs: path } => path.should().eq("tmp.txt").sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("w")) {
        .Write => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("wq")) {
        .WriteQuit => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("wq!")) {
        .WriteQuit => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("split")) {
        .Split => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("vsplit")) {
        .VSplit => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("close")) {
        .CloseWindow => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("only")) {
        .OnlyWindow => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("set number")) {
        .{ SetNumber: enabled } => enabled.should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (command.parse("set relativenumber")) {
        .{ SetRelativeNumber: enabled } => enabled.should().sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_buffer_editing() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let text = buffer.empty(gpa, "").should_ok().sum(@loc(), t)..&;
    defer text.deinit(gpa);

    text.insert_byte(gpa, 0, 0, b'a').should().sum(@loc(), t);
    text.insert_byte(gpa, 0, 1, b'b').should().sum(@loc(), t);
    text.split_line(gpa, 0, 1).should().sum(@loc(), t);
    text.line_count().should().eq(2).sum(@loc(), t);
    text.line(0).should().eq("a").sum(@loc(), t);
    text.line(1).should().eq("b").sum(@loc(), t);

    let cursor = text.delete_backward(gpa, 1, 0);
    cursor.row.should().eq(0).sum(@loc(), t);
    cursor.col.should().eq(1).sum(@loc(), t);
    text.line_count().should().eq(1).sum(@loc(), t);
    text.line(0).should().eq("ab").sum(@loc(), t);

    text.delete_at(gpa, 0, 1).should().sum(@loc(), t);
    text.line(0).should().eq("a").sum(@loc(), t);
}

fn check_escape_decode() void {
    let t = test.report(io.stderr())..&;
    match (input.map_csi_tilde(3)) {
        .Delete => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (input.map_csi_tilde(5)) {
        .PageUp => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (input.map_csi_final(b'H')) {
        .Home => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (input.map_csi_final(b'F')) {
        .End => {}
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_editor_resize_and_command_cursor() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(40, 120).should().sum(@loc(), t);
    state.resize(40, 120).not().should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b':' });
    state.handle_key(gpa, .{ Byte: b'w' });
    state.handle_key(gpa, .{ Byte: b'q' });
    state.handle_key(gpa, .ArrowLeft);
    state.handle_key(gpa, .{ Byte: b'!' });
    state.handle_key(gpa, .End);
    state.handle_key(gpa, .Backspace);
    state.handle_key(gpa, .Escape);
    state.should_quit().not().should().sum(@loc(), t);
}

fn check_editor_normal_mode_subset() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.handle_key(gpa, .{ Byte: b'i' });
    type_text(state, gpa, "one two");
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b'w' });
    state.cursor_row().should().eq(0).sum(@loc(), t);
    state.cursor_col().should().eq(4).sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'e' });
    state.cursor_col().should().eq(6).sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'b' });
    state.cursor_col().should().eq(4).sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'A' });
    state.handle_key(gpa, .{ Byte: b'!' });
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .{ Byte: b'O' });
    state.handle_key(gpa, .{ Byte: b'X' });
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .{ Byte: b'G' });
    state.cursor_row().should().eq(1).sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'0' });
    state.cursor_row().should().eq(0).sum(@loc(), t);
    state.line(0).should().eq("X").sum(@loc(), t);
    state.line(1).should().eq("one two!").sum(@loc(), t);
}

fn check_editor_extended_normal_motions() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.handle_key(gpa, .{ Byte: b'i' });
    type_text(state, gpa, "foo, bar");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "abcdef");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "ab");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "abcdef");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "row4");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "row5");
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b'w' });
    expect_cursor(state, 0, 3, "expected w to stop on punctuation word");
    state.handle_key(gpa, .{ Byte: b'w' });
    expect_cursor(state, 0, 5, "expected second w to reach next word");
    state.handle_key(gpa, .{ Byte: b'b' });
    expect_cursor(state, 0, 3, "expected b to return to punctuation word");
    state.handle_key(gpa, .{ Byte: b'W' });
    expect_cursor(state, 0, 5, "expected W to skip punctuation inside WORD");
    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'e' });
    expect_cursor(state, 0, 3, "expected ge to move to previous word end");

    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b'f' });
    state.handle_key(gpa, .{ Byte: b'o' });
    expect_cursor(state, 0, 1, "expected fo to find first o");
    state.handle_key(gpa, .{ Byte: b';' });
    expect_cursor(state, 0, 2, "expected ; to repeat forward find");
    state.handle_key(gpa, .{ Byte: b',' });
    expect_cursor(state, 0, 1, "expected , to repeat find in reverse");
    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b't' });
    state.handle_key(gpa, .{ Byte: b'b' });
    expect_cursor(state, 0, 4, "expected tb to stop before target");
    state.handle_key(gpa, .{ Byte: b';' });
    expect_cursor(state, 0, 4, "expected repeated tb without another match to stay put");

    state.handle_key(gpa, .{ Byte: b'G' });
    state.handle_key(gpa, .{ Byte: b'k' });
    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b'$' });
    expect_cursor(state, 4, 4, "expected $ to set preferred column");
    state.handle_key(gpa, .{ Byte: b'k' });
    expect_cursor(state, 3, 4, "expected k to preserve preferred column on long line");
    state.handle_key(gpa, .{ Byte: b'k' });
    expect_cursor(state, 2, 2, "expected k to clamp on short line");
    state.handle_key(gpa, .{ Byte: b'k' });
    expect_cursor(state, 1, 4, "expected preferred column to restore on longer line");

    state.resize(5, 80).should().sum(@loc(), t);
    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .CtrlD);
    expect_cursor(state, 2, 2, "expected ctrl-d to move half a screen down");
    state.handle_key(gpa, .{ Byte: b'L' });
    expect_cursor(state, 5, 4, "expected L to jump to bottom visible row");
    state.handle_key(gpa, .{ Byte: b'H' });
    expect_cursor(state, 2, 2, "expected H to jump to top visible row");
    state.handle_key(gpa, .{ Byte: b'M' });
    expect_cursor(state, 4, 4, "expected M to jump to middle visible row");
    state.handle_key(gpa, .CtrlU);
    expect_cursor(state, 0, 4, "expected ctrl-u to move half a screen up");

    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b'2' });
    state.handle_key(gpa, .{ Byte: b'w' });
    expect_cursor(state, 0, 5, "expected count prefix to repeat w");
    state.handle_key(gpa, .{ Byte: b'5' });
    state.handle_key(gpa, .{ Byte: b'G' });
    expect_cursor(state, 4, 4, "expected count prefix to target G line");
    state.handle_key(gpa, .{ Byte: b'2' });
    state.handle_key(gpa, .{ Byte: b'k' });
    expect_cursor(state, 2, 2, "expected count prefix to repeat vertical motion");
}

fn check_command_line_viewport_render() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(2, 8).should().sum(@loc(), t);
    state.handle_key(gpa, .{ Byte: b':' });
    let mut i = usize.{0};
    while (i < #"abcdefghij") {
        state.handle_key(gpa, .{ Byte: "abcdefghij".[i] });
        i += 1;
    }

    let frame = String.{}..&;
    defer frame.deinit(gpa);
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), ":efghij").should().sum(@loc(), t);
    contains(frame.as_str(), "\x1b[2;8H").should().sum(@loc(), t);
}

fn check_insert_tab_and_line_number_render() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(8, 32).should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'i' });
    state.handle_key(gpa, .{ Byte: b'\t' });
    type_text(state, gpa, "a");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "b");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "c");
    state.handle_key(gpa, .Escape);

    state.line(0).should().eq("    a").sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b':' });
    type_text(state, gpa, "set number");
    state.handle_key(gpa, .Enter);
    state.handle_key(gpa, .{ Byte: b':' });
    type_text(state, gpa, "set relativenumber");
    state.handle_key(gpa, .Enter);

    state.handle_key(gpa, .{ Byte: b'k' });

    let frame = String.{}..&;
    defer frame.deinit(gpa);
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "1     a").should().sum(@loc(), t);
    contains(frame.as_str(), "2 b").should().sum(@loc(), t);
    contains(frame.as_str(), "1 c").should().sum(@loc(), t);
}

fn check_split_window_and_window_commands() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(12, 40).should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'i' });
    type_text(state, gpa, "one");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "two");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "three");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "four");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "five");
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'g' });

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b's' });

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'w' });

    let frame = String.{}..&;
    defer frame.deinit(gpa);
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "[window W2/2]").should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W1/2] --").should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'o' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "[window W2/2]").not().should().sum(@loc(), t);
}

fn check_split_window_keeps_window_local_buffers() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let path_a = smoke_temp_path(gpa, "bed-window-a.txt")..&;
    let path_b = smoke_temp_path(gpa, "bed-window-b.txt")..&;
    defer path_a.deinit(gpa);
    defer path_b.deinit(gpa);

    _ = path_a.as_str().path().remove_file_if_exists(gpa);
    _ = path_b.as_str().path().remove_file_if_exists(gpa);
    defer {
        _ = path_a.as_str().path().remove_file_if_exists(gpa);
    };
    defer {
        _ = path_b.as_str().path().remove_file_if_exists(gpa);
    };

    _ = path_a.as_str().path().write_all(gpa, "alpha\none").should_ok().sum(@loc(), t);
    _ = path_b.as_str().path().write_all(gpa, "beta\ntwo").should_ok().sum(@loc(), t);

    let state = editor.open(gpa, path_a.as_str()).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(10, 48).should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b's' });
    run_edit_command(state, gpa, path_b.as_str());

    let frame = String.{}..&;
    defer frame.deinit(gpa);

    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), path_b.as_str()).should().sum(@loc(), t);
    state.line(0).should().eq("beta").sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'w' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), path_a.as_str()).should().sum(@loc(), t);
    state.line(0).should().eq("alpha").sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'w' });
    state.line(0).should().eq("beta").sum(@loc(), t);
    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'q' });

    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), path_a.as_str()).should().sum(@loc(), t);
    state.line(0).should().eq("alpha").sum(@loc(), t);
}

fn check_multi_window_cycle_and_close() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(18, 48).should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'i' });
    type_text(state, gpa, "one");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "two");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "three");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "four");
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b's' });
    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b's' });

    let frame = String.{}..&;
    defer frame.deinit(gpa);

    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "[window W2/3]").should().sum(@loc(), t);
    contains(frame.as_str(), "[WINDOW W3/3]").should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W3/3] --").should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'w' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W1/3] --").should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'w' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W2/3] --").should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'q' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W2/2] --").should().sum(@loc(), t);
    (contains(frame.as_str(), "[window W2/2]") or contains(frame.as_str(), "[WINDOW W2/2]")).should().sum(@loc(), t);
}

fn check_ctrl_w_navigation_commands() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(16, 48).should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'i' });
    type_text(state, gpa, "one");
    state.handle_key(gpa, .Escape);

    ctrl_w(state, gpa, b's');
    ctrl_w(state, gpa, b's');

    let frame = String.{}..&;
    defer frame.deinit(gpa);

    ctrl_w(state, gpa, b'p');
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W2/3] --").should().sum(@loc(), t);

    ctrl_w(state, gpa, b'p');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W3/3] --").should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'2' });
    ctrl_w(state, gpa, b'w');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W2/3] --").should().sum(@loc(), t);

    ctrl_w(state, gpa, b'W');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W1/3] --").should().sum(@loc(), t);

    ctrl_w(state, gpa, b'b');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W3/3] --").should().sum(@loc(), t);

    ctrl_w(state, gpa, b't');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W1/3] --").should().sum(@loc(), t);
