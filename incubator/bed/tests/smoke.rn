fn check_window_and_layout_slots_are_reused() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(12, 48).should().sum(@loc(), t);

    let mut i = 0;
    while (i < 8) {
        ctrl_w(state, gpa, b's');
        state.window_slots().should().eq(2).sum(@loc(), t);
        state.layout_node_slots().should().eq(3).sum(@loc(), t);
        ctrl_w(state, gpa, b'q');
        state.window_slots().should().eq(2).sum(@loc(), t);
        state.layout_node_slots().should().eq(3).sum(@loc(), t);
        i += 1;
    }
}

fn check_vsplit_layout_and_window_resize_commands() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let path_a = smoke_temp_path(gpa, "bed-vsplit-a.txt")..&;
    let path_b = smoke_temp_path(gpa, "bed-vsplit-b.txt")..&;
    defer path_a.deinit(gpa);
    defer path_b.deinit(gpa);

    _ = path_a.as_str().path().remove_file_if_exists(gpa);
    _ = path_b.as_str().path().remove_file_if_exists(gpa);
    defer {
        _ = path_a.as_str().path().remove_file_if_exists(gpa);
    };
    defer {
        _ = path_b.as_str().path().remove_file_if_exists(gpa);
    };

    _ = path_a.as_str().path().write_all(gpa, "left").should_ok().sum(@loc(), t);
    _ = path_b.as_str().path().write_all(gpa, "right").should_ok().sum(@loc(), t);

    let state = editor.open(gpa, path_a.as_str()).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(8, 48).should().sum(@loc(), t);
    run_ex_command(state, gpa, "vsplit");
    run_edit_command(state, gpa, path_b.as_str());

    let frame = String.{}..&;
    defer frame.deinit(gpa);

    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let text = frame.as_str();
    let left_index = find_index(text, "left");
    let right_index = find_index(text, "right");
    let first_newline = find_byte(text, b'\n');
    (left_index < first_newline and right_index < first_newline).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W2/2] --").should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'h' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W1/2] --").should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'l' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W2/2] --").should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'>' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let grown = frame.as_str();
    let left_grown = find_index(grown, "left");
    let right_grown = find_index(grown, "right");
    let first_grown_newline = find_byte(grown, b'\n');
    (left_grown < first_grown_newline and right_grown < first_grown_newline).should().sum(@loc(), t);

    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b'=' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let equalized = frame.as_str();
    let left_equalized = find_index(equalized, "left");
    let right_equalized = find_index(equalized, "right");
    let first_equalized_newline = find_byte(equalized, b'\n');
    (left_equalized < first_equalized_newline and right_equalized < first_equalized_newline).should().sum(@loc(), t);
}

fn check_nested_split_tree_layout() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let path_left = smoke_temp_path(gpa, "bed-tree-left.txt")..&;
    let path_top = smoke_temp_path(gpa, "bed-tree-top.txt")..&;
    let path_bottom = smoke_temp_path(gpa, "bed-tree-bottom.txt")..&;
    defer path_left.deinit(gpa);
    defer path_top.deinit(gpa);
    defer path_bottom.deinit(gpa);

    _ = path_left.as_str().path().remove_file_if_exists(gpa);
    _ = path_top.as_str().path().remove_file_if_exists(gpa);
    _ = path_bottom.as_str().path().remove_file_if_exists(gpa);
    defer {
        _ = path_left.as_str().path().remove_file_if_exists(gpa);
    };
    defer {
        _ = path_top.as_str().path().remove_file_if_exists(gpa);
    };
    defer {
        _ = path_bottom.as_str().path().remove_file_if_exists(gpa);
    };

    _ = path_left.as_str().path().write_all(gpa, "L0\nL1\nL2\nL3").should_ok().sum(@loc(), t);
    _ = path_top.as_str().path().write_all(gpa, "T0\nT1").should_ok().sum(@loc(), t);
    _ = path_bottom.as_str().path().write_all(gpa, "B0\nB1").should_ok().sum(@loc(), t);

    let state = editor.open(gpa, path_left.as_str()).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(12, 52).should().sum(@loc(), t);
    run_ex_command(state, gpa, "vsplit");
    run_edit_command(state, gpa, path_top.as_str());
    state.handle_key(gpa, .CtrlW);
    state.handle_key(gpa, .{ Byte: b's' });
    run_edit_command(state, gpa, path_bottom.as_str());

    let frame = String.{}..&;
    defer frame.deinit(gpa);

    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let first = line_slice(frame.as_str(), 0);
    let bottom_line = find_line_with(frame.as_str(), "B0", 10);
    let nested_line = line_slice(frame.as_str(), bottom_line);
    (contains(first, "L0") and contains(first, "T0")).should().sum(@loc(), t);
    (find_line_with(frame.as_str(), "L2", 10) < 10).should().sum(@loc(), t);
    (bottom_line > 0 and bottom_line < 10).should().sum(@loc(), t);
    (contains(nested_line, "B0") and !contains(nested_line, "T0")).should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR W3/3] --").should().sum(@loc(), t);
}

fn check_ctrl_w_rearrange_commands() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let path_left = smoke_temp_path(gpa, "bed-tree-left.txt")..&;
    let path_top = smoke_temp_path(gpa, "bed-tree-top.txt")..&;
    let path_bottom = smoke_temp_path(gpa, "bed-tree-bottom.txt")..&;
    defer path_left.deinit(gpa);
    defer path_top.deinit(gpa);
    defer path_bottom.deinit(gpa);

    _ = path_left.as_str().path().remove_file_if_exists(gpa);
    _ = path_top.as_str().path().remove_file_if_exists(gpa);
    _ = path_bottom.as_str().path().remove_file_if_exists(gpa);
    defer {
        _ = path_left.as_str().path().remove_file_if_exists(gpa);
    };
    defer {
        _ = path_top.as_str().path().remove_file_if_exists(gpa);
    };
    defer {
        _ = path_bottom.as_str().path().remove_file_if_exists(gpa);
    };

    _ = path_left.as_str().path().write_all(gpa, "L0\nL1\nL2\nL3").should_ok().sum(@loc(), t);
    _ = path_top.as_str().path().write_all(gpa, "T0\nT1").should_ok().sum(@loc(), t);
    _ = path_bottom.as_str().path().write_all(gpa, "B0\nB1").should_ok().sum(@loc(), t);

    let state = editor.open(gpa, path_left.as_str()).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(12, 52).should().sum(@loc(), t);
    run_ex_command(state, gpa, "vsplit");
    run_edit_command(state, gpa, path_top.as_str());
    ctrl_w(state, gpa, b's');
    run_edit_command(state, gpa, path_bottom.as_str());

    let frame = String.{}..&;
    defer frame.deinit(gpa);

    ctrl_w(state, gpa, b'H');
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let first_left = line_slice(frame.as_str(), 0);
    (contains(first_left, "B0") and contains(first_left, "L0")).should().sum(@loc(), t);
    (find_index(first_left, "B0") < find_index(first_left, "L0")).should().sum(@loc(), t);

    ctrl_w(state, gpa, b'L');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let first_right = line_slice(frame.as_str(), 0);
    (contains(first_right, "B0") and contains(first_right, "L0")).should().sum(@loc(), t);
    (find_index(first_right, "L0") < find_index(first_right, "B0")).should().sum(@loc(), t);

    ctrl_w(state, gpa, b'K');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let first_top = line_slice(frame.as_str(), 0);
    contains(first_top, "B0").should().sum(@loc(), t);
    contains(first_top, "L0").not().should().sum(@loc(), t);

    ctrl_w(state, gpa, b'J');
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    let first_bottom = line_slice(frame.as_str(), 0);
    let moved_line = find_line_with(frame.as_str(), "B0", 10);
    contains(first_bottom, "L0").should().sum(@loc(), t);
    (moved_line > 0 and moved_line < 10).should().sum(@loc(), t);
}

fn check_additional_jump_keys() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(6, 40).should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'i' });
    type_text(state, gpa, "(abc)");
    state.handle_key(gpa, .Enter);
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "para");
    state.handle_key(gpa, .Enter);
    type_text(state, gpa, "tail");
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'g' });
    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b'%' });
    expect_cursor(state, 0, 4, "expected % to jump to matching delimiter");

    state.handle_key(gpa, .{ Byte: b'0' });
    state.handle_key(gpa, .{ Byte: b'}' });
    expect_cursor(state, 2, 0, "expected } to jump to next paragraph start");
    state.handle_key(gpa, .{ Byte: b'{' });
    expect_cursor(state, 0, 0, "expected { to jump back to previous paragraph start");

    state.handle_key(gpa, .{ Byte: b'G' });
    state.handle_key(gpa, .CtrlB);
    expect_cursor(state, 0, 0, "expected ctrl-b to page upward");
    state.handle_key(gpa, .CtrlF);
    expect_cursor(state, 3, 0, "expected ctrl-f to page downward");
}

fn check_prompt_history_navigation() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(8, 24).should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b':' });
    type_text(state, gpa, "w");
    state.handle_key(gpa, .Enter);

    state.handle_key(gpa, .{ Byte: b':' });
    type_text(state, gpa, "draft");
    state.handle_key(gpa, .ArrowUp);

    let frame = String.{}..&;
    defer frame.deinit(gpa);
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), ":w").should().sum(@loc(), t);

    state.handle_key(gpa, .ArrowDown);
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), ":draft").should().sum(@loc(), t);
    state.handle_key(gpa, .Escape);

    state.handle_key(gpa, .{ Byte: b'>' });
    type_text(state, gpa, "echo prompt_history");
    state.handle_key(gpa, .Enter);
    state.handle_key(gpa, .{ Byte: b'>' });
    state.handle_key(gpa, .ArrowUp);
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), ">echo prompt_history").should().sum(@loc(), t);
}

fn check_cursor_shape_changes_with_mode() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(4, 16).should().sum(@loc(), t);

    let frame = String.{}..&;
    defer frame.deinit(gpa);

    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "\x1b[2 q").should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'i' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "\x1b[6 q").should().sum(@loc(), t);

    state.handle_key(gpa, .Escape);
    state.handle_key(gpa, .{ Byte: b':' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "\x1b[6 q").should().sum(@loc(), t);
}

fn check_shell_prompt_and_output_render() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let state = editor.empty(gpa).should_ok().sum(@loc(), t)..&;
    defer state.deinit(gpa);

    state.resize(8, 64).should().sum(@loc(), t);
    state.handle_key(gpa, .{ Byte: b'>' });
    type_text(state, gpa, "echo hi");
    state.handle_key(gpa, .Enter);
    state.handle_key(gpa, .{ Byte: b'>' });
    type_text(state, gpa, "echo two");
    state.handle_key(gpa, .Enter);

    let frame = String.{}..&;
    defer frame.deinit(gpa);
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    (contains(frame.as_str(), "[OUTPUT TEMP 2/2] > echo two [exit 0]")).should().sum(@loc(), t);
    contains(frame.as_str(), "two").should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [OUTPUT] --").should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'[' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    (contains(frame.as_str(), "[OUTPUT TEMP 1/2] > echo hi [exit 0]")).should().sum(@loc(), t);
    contains(frame.as_str(), "hi").should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'q' });

    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "[OUTPUT TEMP").not().should().sum(@loc(), t);
    contains(frame.as_str(), "-- NORMAL [EDITOR] --").should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'\t' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    (contains(frame.as_str(), "[OUTPUT TEMP 1/2] > echo hi [exit 0]")).should().sum(@loc(), t);

    state.handle_key(gpa, .{ Byte: b'\t' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    (contains(frame.as_str(), "[output temp 1/2] > echo hi [exit 0]")).should().sum(@loc(), t);
    state.handle_key(gpa, .{ Byte: b'Q' });
    frame.clear();
    state.render_into(gpa, frame, true).should().sum(@loc(), t);
    contains(frame.as_str(), "[OUTPUT TEMP").not().should().sum(@loc(), t);
}

fn main() i32 {
    check_command_parse();
    check_buffer_editing();
    check_escape_decode();
    check_editor_resize_and_command_cursor();
    check_editor_normal_mode_subset();
    check_editor_extended_normal_motions();
    check_command_line_viewport_render();
    check_insert_tab_and_line_number_render();
    check_split_window_and_window_commands();
    check_split_window_keeps_window_local_buffers();
    check_multi_window_cycle_and_close();
    check_window_and_layout_slots_are_reused();
    check_ctrl_w_navigation_commands();
    check_vsplit_layout_and_window_resize_commands();
    check_nested_split_tree_layout();
    check_ctrl_w_rearrange_commands();
    check_additional_jump_keys();
    check_prompt_history_navigation();
    check_cursor_shape_changes_with_mode();
    check_shell_prompt_and_output_render();
    return 0;
}
