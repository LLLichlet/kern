fn bench_lookup_packed_indexed_document(iterations: usize, input_label: &[u8], text: &[u8]) bool {
    let .{ Ok: mut document } = parse_packed_indexed_object_document(text) else return false;
    defer document..&.deinit();
    let indexed = document.&.view();

    let mut sink = usize.{0};
    let start = time.monotonic().now();

    let mut i = usize.{0};
    while (i < iterations) {
        sink += test_packed_indexed_document_lookup_body(indexed);
        i += 1;
    }

    print_stats("lookup_packed_indexed_doc", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn run_bench(name: &[u8], iterations: usize, input_label: &[u8], text: &[u8]) bool {
    if (name == "parse") return bench_parse(iterations, input_label, text);
    if (name == "parse_packed_doc") return bench_parse_packed_document(iterations, input_label, text);
    if (name == "clone_doc") return bench_clone_document(iterations, input_label, text);
    if (name == "materialize") return bench_materialize(iterations, input_label, text);
    if (name == "clone_gpa") return bench_clone_gpa(iterations, input_label, text);
    if (name == "clone_arena") return bench_clone_arena(iterations, input_label, text);
    if (name == "clone_indexed_doc") return bench_clone_indexed_document(iterations, input_label, text);
    if (name == "parse_packed_indexed_doc") return bench_parse_packed_indexed_document(iterations, input_label, text);
    if (name == "render_borrowed") return bench_render_borrowed(iterations, input_label, text);
    if (name == "render_owned") return bench_render_owned(iterations, input_label, text);
    if (name == "lookup_borrowed") return bench_lookup_borrowed(iterations, input_label, text);
    if (name == "lookup_owned") return bench_lookup_owned(iterations, input_label, text);
    if (name == "lookup_packed_doc") return bench_lookup_packed_document(iterations, input_label, text);
    if (name == "build_indexed") return bench_build_indexed(iterations, input_label, text);
    if (name == "build_indexed_arena") return bench_build_indexed_arena(iterations, input_label, text);
    if (name == "lookup_indexed") return bench_lookup_indexed(iterations, input_label, text);
    if (name == "lookup_indexed_doc") return bench_lookup_indexed_document(iterations, input_label, text);
    if (name == "lookup_packed_indexed_doc") return bench_lookup_packed_indexed_document(iterations, input_label, text);
    return false;
}

fn main(argc: i32, argv: &&u8) i32 {
    let args = proc.args(argc, argv);
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let iterations = match (args.get(1)) {
        .{ Some: value } => {
            let parsed = parse_iterations(value);
            if (parsed == 0) {
                io.println("invalid iteration count: {}", .{ value, });
                return 1;
            }
            parsed
        },
        .None => DEFAULT_ITERATIONS,
    };
    let mode = args.get(2);
    let input_path = args.get(3);
    let mut input = match (input_path) {
        .{ Some: path } => {
            let .{ Ok: input } = load_input(gpa, path) else {
                io.println("failed to read input: {}", .{ path, });
                return 1;
            };
            input
        },
        .None => BenchInput.{},
    };
    defer input..&.deinit(gpa);

    if (mode.is_some()) {
        let .{ Some: mode } = mode else return 1;
        if (!run_bench(mode, iterations, input.label, input.text)) {
            io.println("unknown or failed bench: {}", .{ mode, });
            return 1;
        }
        return 0;
    }

    if (!bench_parse(iterations, input.label, input.text)) return 1;
    if (!bench_parse_packed_document(iterations, input.label, input.text)) return 1;
    if (!bench_clone_document(iterations, input.label, input.text)) return 1;
    if (!bench_materialize(iterations, input.label, input.text)) return 1;
    if (!bench_clone_indexed_document(iterations, input.label, input.text)) return 1;
    if (!bench_parse_packed_indexed_document(iterations, input.label, input.text)) return 1;
    if (!bench_render_borrowed(iterations, input.label, input.text)) return 1;
    if (!bench_render_owned(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_borrowed(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_owned(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_packed_document(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_indexed_document(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_packed_indexed_document(iterations, input.label, input.text)) return 1;
    return 0;
}
