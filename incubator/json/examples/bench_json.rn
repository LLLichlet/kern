        let .{ Some: user_name } = user.get_string("name") else return false;
        let .{ Some: sku0 } = item0.get_string("sku") else return false;
        let .{ Ok: .{ Some: qty0 } } = item0.get_u64("qty") else return false;
        let .{ Ok: .{ Some: price0 } } = item0.get_f64("price") else return false;
        let .{ Some: sku1 } = item1.get_string("sku") else return false;
        let .{ Ok: .{ Some: qty1 } } = item1.get_u64("qty") else return false;
        let .{ Ok: .{ Some: price1 } } = item1.get_f64("price") else return false;
        sink += user_id as usize;
        sink += #user_name + #sku0 + #sku1;
        sink += qty0 as usize + qty1 as usize;
        sink += price0 as usize + price1 as usize;
        i += 1;
