fn bench_render_borrowed(iterations: usize, input_label: &[u8], text: &[u8]) bool {
    let .{ Ok: value } = parse(text) else return false;
    let .{ Ok: render_size } = compact_size(value) else return false;
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let out = String.{}..&;
    defer out.deinit(gpa);
    let .{ Some: _ } = out.append_uninit(gpa, render_size)
        else return false;
    let mut sink = usize.{0};
    let start = time.monotonic().now();

    let mut i = usize.{0};
    while (i < iterations) {
        let .{ Ok: written } = render_compact(value, out.as_mut_bytes()) else return false;
        sink += written + render_size;
        i += 1;
    }

    print_stats("render_borrowed", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn bench_render_owned(iterations: usize, input_label: &[u8], text: &[u8]) bool {
    let .{ Ok: value } = parse(text) else return false;
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let .{ Ok: mut document } = clone_owned_document(value) else return false;
    defer document..&.deinit();
    let root = document.&.root();

    let render_size = root.compact_size();
    let out = String.{}..&;
    defer out.deinit(gpa);
    let .{ Some: _ } = out.append_uninit(gpa, render_size)
        else return false;
    let mut sink = usize.{0};
    let start = time.monotonic().now();

    let mut i = usize.{0};
    while (i < iterations) {
        let .{ Ok: written } = root.render_compact(out.as_mut_bytes()) else return false;
        sink += written + render_size;
        i += 1;
    }

    print_stats("render_owned", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn test_borrowed_lookup_body(value: Value) usize {
    let .{ Ok: .{ Some: items } } = value.get_array_field("items") else return 0;
    let .{ Ok: .{ Some: item0 } } = items.get_object_index(0) else return 0;
    let .{ Ok: .{ Some: item1 } } = items.get_object_index(1) else return 0;

    let mut sink = usize.{0};
    let .{ Ok: .{ Some: ok } } = value.get_bool_field("ok") else return 0;
    sink += if (ok) usize.{1} else usize.{0};
    let .{ Ok: .{ Some: user } } = value.get_object_field("user") else return 0;
    let .{ Ok: .{ Some: user_id } } = user.get_u64_field("id") else return 0;
    let .{ Ok: .{ Some: user_name } } = user.get_string_text_field("name") else return 0;
    let .{ Ok: .{ Some: sku0 } } = item0.get_string_text_field("sku") else return 0;
    let .{ Ok: .{ Some: qty0 } } = item0.get_u64_field("qty") else return 0;
    let .{ Ok: .{ Some: price0 } } = item0.get_f64_field("price") else return 0;
    let .{ Ok: .{ Some: sku1 } } = item1.get_string_text_field("sku") else return 0;
    let .{ Ok: .{ Some: qty1 } } = item1.get_u64_field("qty") else return 0;
    let .{ Ok: .{ Some: price1 } } = item1.get_f64_field("price") else return 0;
    sink += user_id as usize;
    sink += #user_name + #sku0 + #sku1;
    sink += qty0 as usize + qty1 as usize;
    sink += price0 as usize + price1 as usize;
    return sink;
}

fn bench_lookup_borrowed(iterations: usize, input_label: &[u8], text: &[u8]) bool {
    let .{ Ok: value } = parse(text) else return false;
    let mut sink = usize.{0};
    let start = time.monotonic().now();

    let mut i = usize.{0};
    while (i < iterations) {
        sink += test_borrowed_lookup_body(value);
        i += 1;
    }

    print_stats("lookup_borrowed", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn test_owned_lookup_body(value: DocumentValue) usize {
    let .{ Some: items } = value.get_array("items") else return 0;
    let .{ Some: item0 } = items.get_index(0) else return 0;
    let .{ Some: item1 } = items.get_index(1) else return 0;

    let mut sink = usize.{0};
    let .{ Some: ok } = value.get_bool("ok") else return 0;
    sink += if (ok) usize.{1} else usize.{0};
    let .{ Some: user } = value.get_object("user") else return 0;
    let .{ Ok: .{ Some: user_id } } = user.get_u64("id") else return 0;
    let .{ Some: user_name } = user.get_string("name") else return 0;
    let .{ Some: sku0 } = item0.get_string("sku") else return 0;
    let .{ Ok: .{ Some: qty0 } } = item0.get_u64("qty") else return 0;
    let .{ Ok: .{ Some: price0 } } = item0.get_f64("price") else return 0;
    let .{ Some: sku1 } = item1.get_string("sku") else return 0;
    let .{ Ok: .{ Some: qty1 } } = item1.get_u64("qty") else return 0;
    let .{ Ok: .{ Some: price1 } } = item1.get_f64("price") else return 0;
    sink += user_id as usize;
    sink += #user_name + #sku0 + #sku1;
    sink += qty0 as usize + qty1 as usize;
    sink += price0 as usize + price1 as usize;
    return sink;
}

