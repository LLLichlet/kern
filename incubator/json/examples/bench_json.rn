fn bench_build_indexed(iterations: usize, input_label: []u8, text: []u8) bool {
    let value = match (parse(text)) {
        .{ Ok: parsed } => parsed,
        .{ Err: _ } => return false,
    };
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        let mut owned = match (value.clone_owned(gpa)) {
            .{ Ok: parsed } => parsed,
            .{ Err: _ } => return false,
        };
        let mut indexed = match (owned..&.build_indexed_object_view(gpa)) {
            .{ Ok: .{ Some: view } } => view,
            _ => {
                owned..&.deinit(gpa);
                return false;
            },
        };
        sink += indexed.&.len();
        indexed..&.deinit(gpa);
        owned..&.deinit(gpa);
    }

    print_stats("build_indexed", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

