use base.coll.String;
use base.mem.alloc.{Arena, GPA};
use sys.mem.Page;
use std.fs;
use std.io;
use std.proc;
use std.time;
use json.{
    DocumentValue,
    IndexedDocumentView,
    PackedIndexedObjectView,
    PackedValue,
    Value,
    clone_owned_document,
    clone_indexed_object_document,
    compact_size,
    parse,
    parse_packed_document,
    parse_packed_indexed_object_document,
    render_compact,
};

const DEFAULT_ITERATIONS = usize.{200000};
const DEFAULT_INPUT_LABEL = "sample";

const SAMPLE =
    "{\n  \"ok\": true,\n  \"user\": { \"id\": 7, \"name\": \"kern\", \"roles\": [\"admin\", \"ops\"] },\n  \"items\": [\n    { \"sku\": \"abc\", \"qty\": 1, \"price\": 12.5 },\n    { \"sku\": \"xyz\", \"qty\": 4, \"price\": 5.75 }\n  ],\n  \"meta\": { \"trace\": \"bench-7\", \"region\": \"ap-south\" }\n}";

type BenchInput = struct {
    storage: String = String.{},
    label: []u8 = DEFAULT_INPUT_LABEL,
    text: []u8 = SAMPLE,
};

impl *mut BenchInput {
    fn deinit(alloc: *mut base.mem.alloc.Allocator) void {
        self.*.storage..&.deinit(alloc);
        self.* = BenchInput.{};
    }
}

fn parse_iterations(text: []u8) usize {
    if (#text == 0) {
        return usize.{0};
    }

    let mut value = usize.{0};
    for (let mut i = usize.{0}; i < #text; i += 1) {
        let byte = text.[i];
        if (byte < b'0' or byte > b'9') {
            return usize.{0};
        }
        let next = value * usize.{10} + (byte - b'0') as usize;
        if (next < value) {
            return usize.{0};
        }
        value = next;
    }
    return value;
}

fn print_stats(
    label: []u8,
    input_label: []u8,
    bytes_per_iter: usize,
    iterations: usize,
    elapsed: time.Duration,
    sink: usize,
) void {
    let total_bytes = (bytes_per_iter as u64) * (iterations as u64);
    io.println(
        "{} input={} bytes={} iterations={} elapsed_ms={} ops_per_sec={} bytes_per_sec={} sink={}",
        .{
            label,
            input_label,
            bytes_per_iter,
            iterations,
            elapsed.as_millis(),
            elapsed.units_per_sec(iterations as u64),
            elapsed.units_per_sec(total_bytes),
            sink,
        }
    );
}

fn load_input(alloc: *mut base.mem.alloc.Allocator, path: []u8) BenchInput!fs.Error {
    if (path.eq("-")) {
        let mut stdin = fs.stdin();
        let storage = match (stdin..&.read_to_string(alloc)) {
            .{ Ok: text } => text,
            .{ Err: err } => return .{ Err: err },
        };
        return .{ Ok: BenchInput.{ storage: storage, label: "<stdin>", text: storage.&.as_str() } };
    }

    let storage = match (fs.read_to_string(alloc, path)) {
        .{ Ok: text } => text,
        .{ Err: err } => return .{ Err: err },
    };
    return .{ Ok: BenchInput.{ storage: storage, label: path, text: storage.&.as_str() } };
}

fn bench_parse(iterations: usize, input_label: []u8, text: []u8) bool {
    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        let value = match (parse(text)) {
            .{ Ok: parsed } => parsed,
            .{ Err: _ } => return false,
        };
        sink += #value.raw;
        sink += if (value.is_scalar()) usize.{1} else usize.{0};
    }

    print_stats("parse", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn bench_materialize(iterations: usize, input_label: []u8, text: []u8) bool {
    let value = match (parse(text)) {
        .{ Ok: parsed } => parsed,
        .{ Err: _ } => return false,
    };
    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        let mut document = match (clone_owned_document(value)) {
            .{ Ok: document } => document,
            .{ Err: _ } => return false,
        };
        let root = document.&.root();
        sink += root.compact_size();
        sink += test_owned_lookup_body(root);
        document..&.deinit();
    }

    print_stats("materialize", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn bench_clone_document(iterations: usize, input_label: []u8, text: []u8) bool {
    let value = match (parse(text)) {
        .{ Ok: parsed } => parsed,
        .{ Err: _ } => return false,
    };
    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        let mut document = match (clone_owned_document(value)) {
            .{ Ok: document } => document,
            .{ Err: _ } => return false,
        };
        sink += if (document.&.root().is_object()) usize.{1} else usize.{0};
        document..&.deinit();
    }

    print_stats("clone_doc", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

