    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        let mut owned = match (value.clone_owned(gpa)) {
            .{ Ok: parsed } => parsed,
            .{ Err: _ } => return false,
        };
        sink += if (owned..&.is_object()) usize.{1} else usize.{0};
        owned..&.deinit(gpa);
    }

    print_stats("clone_gpa", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn bench_clone_arena(iterations: usize, input_label: []u8, text: []u8) bool {
    let value = match (parse(text)) {
        .{ Ok: parsed } => parsed,
        .{ Err: _ } => return false,
    };
    let page = Page.{}..&;
    let mut arena = Arena.{ backing: page };
    defer arena..&.deinit();
    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        let mut owned = match (value.clone_owned(arena..&)) {
            .{ Ok: parsed } => parsed,
            .{ Err: _ } => return false,
        };
        sink += if (owned..&.is_object()) usize.{1} else usize.{0};
        arena..&.reset();
    }

    print_stats("clone_arena", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

