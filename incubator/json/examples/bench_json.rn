fn bench_build_indexed(iterations: usize, input_label: &[u8], text: &[u8]) bool {
    let .{ Ok: value } = parse(text) else return false;
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut sink = usize.{0};
    let start = time.monotonic().now();

    let mut i = usize.{0};
    while (i < iterations) {
        let .{ Ok: mut owned } = value.clone_owned(gpa) else return false;
        let .{ Ok: .{ Some: mut indexed } } = owned..&.build_indexed_object_view(gpa) else {
            owned..&.deinit(gpa);
            return false;
        };
        sink += indexed.&.len();
        indexed..&.deinit(gpa);
        owned..&.deinit(gpa);
        i += 1;
    }

    print_stats("build_indexed", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

