fn bench_lookup_indexed(iterations: usize, input_label: []u8, text: []u8) bool {
    let value = match (parse(text)) {
        .{ Ok: parsed } => parsed,
        .{ Err: _ } => return false,
    };
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut owned = match (value.clone_owned(gpa)) {
        .{ Ok: parsed } => parsed,
        .{ Err: _ } => return false,
    };
    defer owned..&.deinit(gpa);
    let mut indexed = match (owned..&.build_indexed_object_view(gpa)) {
        .{ Ok: .{ Some: view } } => view,
        _ => return false,
    };
    defer indexed..&.deinit(gpa);

    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        let .{ Some: ok } = indexed.&.get_bool("ok") else return false;
        let .{ Some: user } = indexed.&.get_object("user") else return false;
        let .{ Some: items } = indexed.&.get_array("items") else return false;
        let .{ Some: item0 } = items.get_index(usize.{0}) else return false;
        let .{ Some: item1 } = items.get_index(usize.{1}) else return false;
        sink += if (ok) usize.{1} else usize.{0};
        let .{ Ok: .{ Some: user_id } } = user.get_u64("id") else return false;
        let .{ Some: user_name } = user.get_string("name") else return false;
        let .{ Some: sku0 } = item0.get_string("sku") else return false;
        let .{ Ok: .{ Some: qty0 } } = item0.get_u64("qty") else return false;
        let .{ Ok: .{ Some: price0 } } = item0.get_f64("price") else return false;
        let .{ Some: sku1 } = item1.get_string("sku") else return false;
        let .{ Ok: .{ Some: qty1 } } = item1.get_u64("qty") else return false;
        let .{ Ok: .{ Some: price1 } } = item1.get_f64("price") else return false;
        sink += user_id as usize;
        sink += #user_name + #sku0 + #sku1;
        sink += qty0 as usize + qty1 as usize;
        sink += price0 as usize + price1 as usize;
    }

    print_stats("lookup_indexed", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn bench_lookup_indexed_document(iterations: usize, input_label: []u8, text: []u8) bool {
    let value = match (parse(text)) {
        .{ Ok: parsed } => parsed,
        .{ Err: _ } => return false,
    };
    let mut document = match (clone_indexed_object_document(value)) {
        .{ Ok: document } => document,
        .{ Err: _ } => return false,
    };
    defer document..&.deinit();
    let indexed = document.&.view();

    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        sink += test_indexed_document_lookup_body(indexed);
    }

    print_stats("lookup_indexed_doc", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn bench_lookup_packed_indexed_document(iterations: usize, input_label: []u8, text: []u8) bool {
    let mut document = match (parse_packed_indexed_object_document(text)) {
        .{ Ok: document } => document,
        .{ Err: _ } => return false,
    };
    defer document..&.deinit();
    let indexed = document.&.view();

    let mut sink = usize.{0};
    let start = time.now();

    for (let mut i = usize.{0}; i < iterations; i += 1) {
        sink += test_packed_indexed_document_lookup_body(indexed);
    }

    print_stats("lookup_packed_indexed_doc", input_label, #text, iterations, start.elapsed(), sink);
    return true;
}

fn run_bench(name: []u8, iterations: usize, input_label: []u8, text: []u8) bool {
    if (name.eq("parse")) return bench_parse(iterations, input_label, text);
    if (name.eq("parse_packed_doc")) return bench_parse_packed_document(iterations, input_label, text);
    if (name.eq("clone_doc")) return bench_clone_document(iterations, input_label, text);
    if (name.eq("materialize")) return bench_materialize(iterations, input_label, text);
    if (name.eq("clone_gpa")) return bench_clone_gpa(iterations, input_label, text);
    if (name.eq("clone_arena")) return bench_clone_arena(iterations, input_label, text);
    if (name.eq("clone_indexed_doc")) return bench_clone_indexed_document(iterations, input_label, text);
    if (name.eq("parse_packed_indexed_doc")) return bench_parse_packed_indexed_document(iterations, input_label, text);
    if (name.eq("render_borrowed")) return bench_render_borrowed(iterations, input_label, text);
    if (name.eq("render_owned")) return bench_render_owned(iterations, input_label, text);
    if (name.eq("lookup_borrowed")) return bench_lookup_borrowed(iterations, input_label, text);
    if (name.eq("lookup_owned")) return bench_lookup_owned(iterations, input_label, text);
    if (name.eq("lookup_packed_doc")) return bench_lookup_packed_document(iterations, input_label, text);
    if (name.eq("build_indexed")) return bench_build_indexed(iterations, input_label, text);
    if (name.eq("build_indexed_arena")) return bench_build_indexed_arena(iterations, input_label, text);
    if (name.eq("lookup_indexed")) return bench_lookup_indexed(iterations, input_label, text);
    if (name.eq("lookup_indexed_doc")) return bench_lookup_indexed_document(iterations, input_label, text);
    if (name.eq("lookup_packed_indexed_doc")) return bench_lookup_packed_indexed_document(iterations, input_label, text);
    return false;
}

fn main(argc: i32, argv: **u8) i32 {
    let args = proc.args(argc, argv);
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let iterations = match (args.get(1)) {
        .{ Some: value } => {
            let parsed = parse_iterations(value);
            if (parsed == usize.{0}) {
                io.println("invalid iteration count: {}", .{ value, });
                return 1;
            }
            parsed
        },
        .None => DEFAULT_ITERATIONS,
    };
    let mode = args.get(2);
    let input_path = args.get(3);
    let mut input = match (input_path) {
        .{ Some: path } => match (load_input(gpa, path)) {
            .{ Ok: input } => input,
            .{ Err: _ } => {
                io.println("failed to read input: {}", .{ path, });
                return 1;
            },
        },
        .None => BenchInput.{},
    };
    defer input..&.deinit(gpa);

    if (mode.is_some()) {
        let .{ Some: mode } = mode else return 1;
        if (!run_bench(mode, iterations, input.label, input.text)) {
            io.println("unknown or failed bench: {}", .{ mode, });
            return 1;
        }
        return 0;
    }

    if (!bench_parse(iterations, input.label, input.text)) return 1;
    if (!bench_parse_packed_document(iterations, input.label, input.text)) return 1;
    if (!bench_clone_document(iterations, input.label, input.text)) return 1;
    if (!bench_materialize(iterations, input.label, input.text)) return 1;
    if (!bench_clone_indexed_document(iterations, input.label, input.text)) return 1;
    if (!bench_parse_packed_indexed_document(iterations, input.label, input.text)) return 1;
    if (!bench_render_borrowed(iterations, input.label, input.text)) return 1;
    if (!bench_render_owned(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_borrowed(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_owned(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_packed_document(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_indexed_document(iterations, input.label, input.text)) return 1;
    if (!bench_lookup_packed_indexed_document(iterations, input.label, input.text)) return 1;
    return 0;
}
