    pub fn require_object(name: &[u8]) DocumentValue!FieldDecodeError {
        let .{ Ok: value } = self.value_ptr().require_object(name)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value(value) };
    }

    pub fn require_u64(name: &[u8]) u64!FieldDecodeError {
        return self.value_ptr().require_u64(name);
    }

    pub fn require_u32(name: &[u8]) u32!FieldDecodeError {
