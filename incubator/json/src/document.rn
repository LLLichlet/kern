    pub fn get_f32(name: &[u8]) ?f32!FloatDecodeError {
        return self.value_ptr().get_f32(name);
    }

    pub fn has_field(name: &[u8]) bool {
        return self.value_ptr().has_field(name);
    }

    pub fn require_value(name: &[u8]) DocumentValue!FieldDecodeError {
        let .{ Ok: value } = self.value_ptr().require_value(name)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value(value) };
    }

    pub fn require_bool(name: &[u8]) bool!FieldDecodeError {
        return self.value_ptr().require_bool(name);
    }

    pub fn require_number_text(name: &[u8]) (&[u8])!FieldDecodeError {
