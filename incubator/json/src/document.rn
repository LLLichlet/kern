        return self.value_ptr().render_compact(out);
    }

    pub fn replace(value: OwnedValue) void {
        self.value_ptr().replace(self.state_ptr().arena..&, value);
    }

    pub fn try_reserve_array_items(additional: usize) void!OwnedBuildError {
        return self.value_ptr().try_reserve_array_items(self.state_ptr().arena..&, additional);
    }

    pub fn push_array_item(
        value: OwnedValue,
    ) ?DocumentValueMut!OwnedBuildError {
        let .{ Ok: item } = self.value_ptr().push_array_item(self.state_ptr().arena..&, value)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value_mut_option(self.state_ptr(), item) };
    }

    pub fn push_array_string(
        text: &[u8],
    ) ?DocumentValueMut!OwnedBuildError {
        let .{ Ok: item } = self.value_ptr().push_array_string(self.state_ptr().arena..&, text)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value_mut_option(self.state_ptr(), item) };
    }

    pub fn push_array_number_text(
        text: &[u8],
    ) ?DocumentValueMut!OwnedBuildError {
        let .{ Ok: item } = self.value_ptr().push_array_number_text(self.state_ptr().arena..&, text)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value_mut_option(self.state_ptr(), item) };
    }

    pub fn pop_array_item() bool {
        return match (self.value_ptr().*) {
            .{ Array: mut array } => {
                let popped = array..&.pop(self.state_ptr().arena..&).is_some();
                self.value_ptr().* = .{ Array: array };
                popped
            },
            _ => false,
        };
    }

    pub fn remove_array_index(index: usize) bool {
        return match (self.value_ptr().*) {
            .{ Array: mut array } => {
                let removed = array..&.remove(index, self.state_ptr().arena..&).is_some();
                self.value_ptr().* = .{ Array: array };
                removed
            },
            _ => false,
        };
    }

    pub fn clear_array_items() bool {
        return match (self.value_ptr().*) {
            .{ Array: mut array } => {
                array..&.clear(self.state_ptr().arena..&);
                self.value_ptr().* = .{ Array: array };
                true
            },
            _ => false,
        };
    }

    pub fn try_reserve_object_fields(additional: usize) void!OwnedBuildError {
        return self.value_ptr().try_reserve_object_fields(self.state_ptr().arena..&, additional);
    }

    pub fn append_object_field(
        key: &[u8],
        value: OwnedValue,
    ) ?DocumentValueMut!OwnedBuildError {
        let .{ Ok: item } = self.value_ptr().append_object_field(self.state_ptr().arena..&, key, value)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value_mut_option(self.state_ptr(), item) };
    }

    pub fn append_object_string(
        key: &[u8],
        text: &[u8],
    ) ?DocumentValueMut!OwnedBuildError {
        let .{ Ok: item } = self.value_ptr().append_object_string(self.state_ptr().arena..&, key, text)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value_mut_option(self.state_ptr(), item) };
    }

    pub fn append_object_number_text(
        key: &[u8],
        text: &[u8],
    ) ?DocumentValueMut!OwnedBuildError {
        let .{ Ok: item } = self.value_ptr().append_object_number_text(self.state_ptr().arena..&, key, text)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value_mut_option(self.state_ptr(), item) };
    }

    pub fn set_object_field(
        key: &[u8],
        value: OwnedValue,
    ) ?DocumentValueMut!OwnedBuildError {
        let .{ Ok: item } = self.value_ptr().set_object_field(self.state_ptr().arena..&, key, value)
            else {
                .{ Err: err } => return .{ Err: err },
            };
        return .{ Ok: wrap_document_value_mut_option(self.state_ptr(), item) };
    }

    pub fn remove_object_field(key: &[u8]) bool {
        return self.value_ptr().remove_object_field(self.state_ptr().arena..&, key);
    }

    pub fn clear_object_fields() bool {
        return match (self.value_ptr().*) {
            .{ Object: mut object } => {
                object..&.clear(self.state_ptr().arena..&);
                self.value_ptr().* = .{ Object: object };
                true
            },
            _ => false,
        };
    }
}

impl IndexedDocumentView {
    fn view_ptr() &IndexedObjectView {
        return require_indexed_document_view_ptr(self.view);
    }

    pub fn len() usize {
        return self.view_ptr().len();
    }

    pub fn is_empty() bool {
        return self.view_ptr().is_empty();
    }

    pub fn get_entry(index: usize) ?DocumentObjectEntryRef {
        return wrap_document_object_entry_ref_option(self.view_ptr().get_entry(index));
    }

    pub fn get_field(name: &[u8]) ?DocumentObjectEntryRef {
        return wrap_document_object_entry_ref_option(self.view_ptr().get_field(name));
    }

    pub fn get_last_field(name: &[u8]) ?DocumentObjectEntryRef {
        return wrap_document_object_entry_ref_option(self.view_ptr().get_last_field(name));
    }

    pub fn count_fields(name: &[u8]) usize {
        return self.view_ptr().count_fields(name);
    }

    pub fn collect_fields(name: &[u8], out: &mut [DocumentObjectEntryRef]) usize {
        let mut total = usize.{0};
        let mut i = usize.{0};
        while (i < self.view_ptr().len()) {
            let .{ Some: entry } = self.view_ptr().get_entry(i) else { i += 1; continue; };
            if (!entry.key_eq(name)) {
            i += 1;
                continue;
            }
            if (total < #out) {
                out.[total] = wrap_document_object_entry_ref(entry);
            }
            total += 1;
            i += 1;
        }
        return total;
    }

    pub fn get_bool(name: &[u8]) ?bool {
        return self.view_ptr().get_bool(name);
    }

    pub fn get_number_text(name: &[u8]) ?&[u8] {
        return self.view_ptr().get_number_text(name);
    }

    pub fn get_string(name: &[u8]) ?&[u8] {
        return self.view_ptr().get_string(name);
    }

    pub fn get_array(name: &[u8]) ?DocumentValue {
        return wrap_document_value_option(self.view_ptr().get_array(name));
