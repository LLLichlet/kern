impl &mut IndexedObjectDocument {
    pub fn deinit() void {
        let .{ Some: state } = self.*.state else return;
        let page = Page.{}..&;
        let layout = layout_of[IndexedObjectDocumentState]();
        state.arena..&.deinit();
        page.free(state as &mut u8, layout);
        self.* = IndexedObjectDocument.{};
    }
}
