            .{ Object: object } => object.&.has_field(name),
            _ => false,
        };
    }

    pub fn deinit(alloc: &mut Allocator) void {
        match (self.*) {
            .Null => {},
            .{ Bool: _ } => {},
            .{ Number: mut text } => {
                text..&.deinit(alloc);
            },
            .{ String: mut text } => {
                text..&.deinit(alloc);
            },
            .{ Array: mut array } => {
                array..&.deinit(alloc);
            },
            .{ Object: mut object } => {
                object..&.deinit(alloc);
            },
        }
    }
}
