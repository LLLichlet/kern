    pub fn require_field(name: []u8) ObjectEntry!BorrowedFieldDecodeError {
        if (self.kind != Kind.Object) {
            return .{ Err: .{ UnexpectedKind: self.kind } };
        }

        let .{ Some: mut cursor } = self.object_cursor()
            else return .{ Err: .{ UnexpectedKind: self.kind } };
        let mut found = ?ObjectEntry.None;
        let mut total = usize.{0};

        for (;;) {
            let .{ Ok: item } = cursor..&.next()
                else .{ Err: err } => return .{ Err: .{ Parse: err } };
            let .{ Some: entry } = item else break;
            if (!entry.key_eq(name)) {
                continue;
            }
            total += 1;
            if (total == usize.{1}) {
                found = .{ Some: entry };
            }
        }

        if (total == usize.{0}) {
            return .{ Err: .Missing };
        }
        if (total != usize.{1}) {
            return .{ Err: .{ Duplicate: total } };
        }
        let .{ Some: found } = found else return .{ Err: .Missing };
        return .{ Ok: found };
    }

    pub fn require_bool_field(name: []u8) bool!BorrowedFieldDecodeError {
        let .{ Ok: entry } = self.require_field(name)
            else .{ Err: err } => return .{ Err: err };
        let .{ Some: out } = require_bool_value(entry.value)
            else return .{ Err: .{ UnexpectedKind: entry.value.kind } };
        return .{ Ok: out };
    }

