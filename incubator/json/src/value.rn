        let .{ Ok: entry } = self.require_field(name)
            else .{ Err: err } => return .{ Err: err };
        let .{ Some: out } = require_string_text_value(entry.value)
            else return .{ Err: .{ UnexpectedKind: entry.value.kind } };
        return .{ Ok: out };
    }

    pub fn require_decoded_string_size_field(name: []u8) usize!BorrowedFieldDecodeError {
        let .{ Ok: raw } = self.require_string_raw_field(name)
            else .{ Err: err } => return .{ Err: err };
        let .{ Ok: out } = decoded_string_size_raw(raw)
            else .{ Err: err } => return .{ Err: .{ String: err } };
        return .{ Ok: out };
    }

    pub fn write_required_decoded_string_field(
        name: []u8,
        out: []mut u8,
    ) usize!BorrowedFieldDecodeError {
        let .{ Ok: raw } = self.require_string_raw_field(name)
            else .{ Err: err } => return .{ Err: err };
        let .{ Ok: written } = write_decoded_string_raw(raw, out)
            else .{ Err: err } => return .{ Err: .{ String: err } };
        return .{ Ok: written };
    }

    pub fn clone_required_decoded_string_field(
        name: []u8,
        alloc: *mut Allocator,
    ) String!BorrowedFieldDecodeError {
        let .{ Ok: raw } = self.require_string_raw_field(name)
            else .{ Err: err } => return .{ Err: err };
        let .{ Ok: text } = clone_decoded_string_raw(alloc, raw)
            else .{ Err: err } => return .{ Err: .{ String: err } };
        return .{ Ok: text };
    }

    pub fn require_array_field(name: []u8) Value!BorrowedFieldDecodeError {
        let .{ Ok: entry } = self.require_field(name)
            else .{ Err: err } => return .{ Err: err };
        let .{ Some: out } = require_array_value(entry.value)
            else return .{ Err: .{ UnexpectedKind: entry.value.kind } };
        return .{ Ok: out };
