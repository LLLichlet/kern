        let .{ Ok: out } = entry.value.f32_value()
            else .{ Err: err } => return .{ Err: .{ Float: err } };
        return out.ok_or(.{ UnexpectedKind: entry.value.kind });
    }

    pub fn get_last_field(name: []u8) ?ObjectEntry!ParseError {
        let .{ Some: mut cursor } = self.object_cursor() else return .{ Ok: .None };
        let mut found = ?ObjectEntry.None;

        for (;;) {
            let .{ Ok: item } = cursor..&.next()
                else .{ Err: err } => return .{ Err: err };
            let .{ Some: entry } = item else return .{ Ok: found };
            if (entry.key_eq(name)) {
                found = .{ Some: entry };
            }
        }
    }

    pub fn count_fields(name: []u8) ?usize!ParseError {
        let .{ Some: mut cursor } = self.object_cursor() else return .{ Ok: .None };
        let mut total = usize.{0};

        for (;;) {
            let .{ Ok: item } = cursor..&.next()
                else .{ Err: err } => return .{ Err: err };
            let .{ Some: entry } = item else return .{ Ok: .{ Some: total } };
            if (entry.key_eq(name)) {
                total += 1;
            }
        }
    }

    pub fn collect_fields(name: []u8, out: []mut ObjectEntry) ?usize!ParseError {
        let .{ Some: mut cursor } = self.object_cursor() else return .{ Ok: .None };
        let mut total = usize.{0};

        for (;;) {
            let .{ Ok: item } = cursor..&.next()
                else .{ Err: err } => return .{ Err: err };
            let .{ Some: entry } = item else return .{ Ok: .{ Some: total } };
            if (!entry.key_eq(name)) {
                continue;
            }
            if (total < #out) {
                out.[total] = entry;
            }
            total += 1;
        }
    }

    pub fn has_field(name: []u8) bool!ParseError {
        let .{ Ok: entry } = self.get_field(name)
            else .{ Err: err } => return .{ Err: err };
        return .{ Ok: entry.is_some() };
    }

    pub fn object_len() ?usize!ParseError {
        let .{ Some: mut cursor } = self.object_cursor() else return .{ Ok: .None };
        let mut count = usize.{0};

        for (;;) {
            let .{ Ok: item } = cursor..&.next()
                else .{ Err: err } => return .{ Err: err };
            if (item.is_none()) {
                return .{ Ok: .{ Some: count } };
            }
            count += 1;
        }
    }
}
