    pub fn array_len() ?usize!ParseError {
        let .{ Some: mut cursor } = self.array_cursor() else return .{ Ok: .None };
        let mut count = usize.{0};

        for (;;) {
            let .{ Ok: item } = cursor..&.next()
                else .{ Err: err } => return .{ Err: err };
            if (item.is_none()) {
                return .{ Ok: .{ Some: count } };
            }
            count += 1;
        }
    }

