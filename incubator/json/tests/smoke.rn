        test.assert(
            test.expect_some(view.&.get_string("msg")) == ("hi"),
            "expected arena-indexed string helper",
            .{}
        );
        test.eq(view.&.count_fields("dup"), usize.{2});
        test.eq(test.expect_some(test.expect_ok(test.expect_some(view.&.get_field("a")).u64_value())), u64.{1});
        arena.reset();
        round += 1;
    }
}

