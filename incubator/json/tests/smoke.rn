fn check_owned_document_schema_and_duplicate_helpers() void {
    let mut doc = test.expect_ok(
        parse_owned_document("{\"flag\":true,\"count\":12,\"msg\":\"hi\",\"nested\":{\"ok\":false},\"items\":[1,2],\"dup\":1,\"dup\":2,\"flt\":1.5}")
    );
    defer doc..&.deinit();

    let root = doc.&.root();
    test.assert(root.has_field("msg"), "expected document-bound field presence helper", .{});
    test.assert(!root.has_field("missing"), "expected document-bound missing-field miss", .{});
    test.eq(test.expect_some(root.count_fields("dup")), usize.{2});

    let msg = test.expect_some(root.get_field("msg"));
    test.assert(msg.key_eq("msg"), "expected document-bound entry key_eq", .{});
    test.assert(test.expect_some(msg.string_text()) == ("hi"), "expected document-bound entry string helper", .{});

    let last_dup = test.expect_some(root.get_last_field("dup"));
    test.eq(test.expect_some(test.expect_ok(last_dup.u64_value())), u64.{2});
    let mut collected = [1]json.DocumentObjectEntryRef.{ undef };
    let total = test.expect_some(root.collect_fields("dup", collected..[0 .. 1]));
    test.eq(total, usize.{2});
    test.eq(test.expect_some(test.expect_ok(collected.[0].u64_value())), u64.{1});

    test.eq(test.expect_ok(root.require_bool("flag")), true);
    test.eq(test.expect_ok(root.require_u64("count")), u64.{12});
    test.eq(test.expect_ok(root.require_f64("flt")), 1.5);
    let nested = test.expect_ok(root.require_object("nested"));
    test.eq(test.expect_ok(nested.require_bool("ok")), false);
    let items = test.expect_ok(root.require_array("items"));
    let second = test.expect_some(items.get_index(usize.{1}));
    test.eq(test.expect_some(test.expect_ok(second.u64_value())), u64.{2});

    match (test.expect_err(root.require_bool("missing"))) {
        .Missing => {},
        _ => test.fail("expected document-bound required missing-field error", .{}),
    }
    match (test.expect_err(root.require_bool("dup"))) {
        .{ Duplicate: count } => test.eq(count, usize.{2}),
        _ => test.fail("expected document-bound required duplicate-field error", .{}),
    }
    match (test.expect_err(root.require_bool("msg"))) {
        .{ UnexpectedKind: kind } => test.eq(kind, Kind.String),
        _ => test.fail("expected document-bound required wrong-kind error", .{}),
    }
}

