    let root = doc.&.root();
    root
        .is_object()
        .should()
        .sum(@loc(), t);
    root
        .object_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(3)
        .sum(@loc(), t);
    root
        .get_bool("flag")
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
