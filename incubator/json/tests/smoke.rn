fn check_owned_compact_render_round_trip() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"msg\":\"hi\\n\\t\\\"\\\\\",\"ctrl\":\"\\u0001\",\"items\":[true,null,12],\"nested\":{\"ok\":false}}").should_ok().sum(
        @loc(),
        t,
    );
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let owned = value.clone_owned(gpa).should_ok().sum(@loc(), t)..&;
    defer owned.deinit(gpa);

    let expected = "{\"msg\":\"hi\\n\\t\\\"\\\\\",\"ctrl\":\"\\u0001\",\"items\":[true,null,12],\"nested\":{\"ok\":false}}";
    owned
        .compact_size()
        .should()
        .eq(compact_size_owned(owned))
        .sum(@loc(), t);
    owned
        .compact_size()
        .should()
        .eq(#expected)
        .sum(@loc(), t);

    let mut out = [256]u8.{undef};
    let written = owned
        .render_compact(out..&[0 .. 256])
        .should_ok()
        .sum(@loc(), t);
    written
        .should()
        .eq(owned.compact_size())
        .sum(@loc(), t);
    out.&[0 .. written]
        .should()
        .eq((expected))
        .sum(@loc(), t);

    let written2 = render_compact_owned(owned, out..&[0 .. 256]).should_ok().sum(@loc(), t);
    written2
        .should()
        .eq(written)
        .sum(@loc(), t);
    out.&[0 .. written2]
        .should()
        .eq((expected))
        .sum(@loc(), t);
}

fn check_owned_compact_render_reports_small_buffer() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"msg\":\"hi\"}").should_ok().sum(@loc(), t);
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let owned = value.clone_owned(gpa).should_ok().sum(@loc(), t)..&;
    defer owned.deinit(gpa);

    let mut out = [4]u8.{undef};
    match (owned.render_compact(out..&[0 .. 4]).should_err().sum(@loc(), t)) {
        .BufferTooSmall => {},
    }
    match (render_compact_owned(owned, out..&[0 .. 4]).should_err().sum(@loc(), t)) {
        .BufferTooSmall => {},
    }
}

fn check_owned_dom_build_and_mutation() void {
    let t = test.report(io.stderr())..&;
    let mut doc = parse_owned_document("{}").should_ok().sum(@loc(), t);
    defer doc..&.deinit();
    let root = doc..&.root_mut();

    root
        .try_reserve_object_fields(5)
        .should_ok()
        .sum(@loc(), t);

    let msg = root.append_object_string("msg", [3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3]).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    msg.string_text().should_some().sum(@loc(), t).should().eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3])).sum(
        @loc(),
        t,
    );
    _ = root.append_object_number_text("count", "12").should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    let flag = root.append_object_field("flag", .{ Bool: false }).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    flag
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);

    let nested = root.append_object_field("nested", .{ Object: json.OwnedObject.{} }).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    _ = nested.append_object_field("ok", .{ Bool: true }).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );

    let items = root.append_object_field("items", .{ Array: json.OwnedArray.{} }).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    items
        .try_reserve_array_items(2)
        .should_ok()
        .sum(@loc(), t);
    _ = items.push_array_item(.{ Bool: true }).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    _ = items
        .push_array_number_text("7")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    items
        .pop_array_item()
        .should()
        .sum(@loc(), t);
    _ = items
        .push_array_number_text("9")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    items
        .remove_array_index(1)
        .should()
        .sum(@loc(), t);
    items
        .remove_array_index(9)
        .not()
        .should()
        .sum(@loc(), t);

    let flag2 = root.set_object_field("flag", .{ Bool: true }).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    flag2
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    root
        .remove_object_field("msg")
        .should()
        .sum(@loc(), t);
    root
        .remove_object_field("missing")
        .not()
        .should()
        .sum(@loc(), t);

    root
        .get_string("msg")
        .is_none()
        .should()
        .sum(@loc(), t);
    root.get_u64("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    root
        .get_bool("flag")
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    items
        .array_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(1)
        .sum(@loc(), t);
    items.get_index(0).should_some().sum(@loc(), t).bool_value().should_some().sum(@loc(), t).should().sum(
        @loc(),
        t,
    );

    let mut out = [128]u8.{undef};
    let written = root
        .render_compact(out..&[0 .. 128])
        .should_ok()
        .sum(@loc(), t);
    out.&[0 .. written].should().eq(("{\"count\":12,\"flag\":true,\"nested\":{\"ok\":true},\"items\":[true]}")).sum(
        @loc(),
        t,
    );

    nested
        .clear_object_fields()
        .should()
        .sum(@loc(), t);
    nested
        .object_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(0)
        .sum(@loc(), t);
    items
        .clear_array_items()
        .should()
        .sum(@loc(), t);
    items
        .array_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(0)
        .sum(@loc(), t);
}

fn check_owned_dom_node_pool_reuse() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;

    let mut array = json.OwnedArray.{};
    defer array..&.deinit(gpa);

    let first = array
        ..&.push_number_text(gpa, "1")
        .should_ok()
        .sum(@loc(), t);
    first
        .number_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("1"))
        .sum(@loc(), t);
    let mut removed = array
        ..&.pop(gpa)
        .should_some()
        .sum(@loc(), t);
    defer removed..&.deinit(gpa);
    removed
        ..&.number_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("1"))
        .sum(@loc(), t);

    let second = array
        ..&.push_string(gpa, "two")
        .should_ok()
        .sum(@loc(), t);
    second
        .string_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("two"))
        .sum(@loc(), t);
    _ = array
        ..&.push(gpa, .{ Bool: true })
        .should_ok()
        .sum(@loc(), t);
    array.&.len()
        .should()
        .eq(2)
        .sum(@loc(), t);
    array.&.get(0).should_some().sum(@loc(), t).string_text().should_some().sum(@loc(), t).should().eq(("two")).sum(
        @loc(),
        t,
    );
    array.&.get(1).should_some().sum(@loc(), t).bool_value().should_some().sum(@loc(), t).should().sum(
        @loc(),
        t,
    );

    let mut object = json.OwnedObject.{};
    defer object..&.deinit(gpa);

    let count = object
        ..&.append_number_text(gpa, "count", "1")
        .should_ok()
        .sum(@loc(), t);
    count.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    object
        ..&.remove_field(gpa, "count")
        .should()
        .sum(@loc(), t);

    let label = object
        ..&.append_string(gpa, "label", "fresh")
        .should_ok()
        .sum(@loc(), t);
    label
        .string_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("fresh"))
        .sum(@loc(), t);
    let flag = object
        ..&.append(gpa, "flag", .{ Bool: true })
        .should_ok()
        .sum(@loc(), t);
    flag
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    object.&.get_value("flag").should_some().sum(@loc(), t).bool_value().should_some().sum(@loc(), t).should().sum(
        @loc(),
        t,
    );
    object.&.get_string("label")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("fresh"))
        .sum(@loc(), t);
}

fn check_parse_scalar_kinds() void {
    let t = test.report(io.stderr())..&;
    parse("null")
        .should_ok()
        .sum(@loc(), t)
        .kind
        .should()
        .eq(Kind.Null)
        .sum(@loc(), t);
    parse("true")
        .should_ok()
        .sum(@loc(), t)
        .kind
        .should()
        .eq(Kind.Bool)
        .sum(@loc(), t);
    parse("-12.5e+2")
        .should_ok()
        .sum(@loc(), t)
        .kind
        .should()
        .eq(Kind.Number)
        .sum(@loc(), t);
    parse("\"hi\"")
        .should_ok()
        .sum(@loc(), t)
        .kind
        .should()
        .eq(Kind.String)
        .sum(@loc(), t);
}

fn check_parse_trims_outer_whitespace_and_preserves_raw_value() void {
    let t = test.report(io.stderr())..&;
    let value = parse(" \n\t { \"ok\" : true } \r\n").should_ok().sum(@loc(), t);
    value.kind
        .should()
        .eq(Kind.Object)
        .sum(@loc(), t);
    value.raw
        .should()
        .eq(("{ \"ok\" : true }"))
        .sum(@loc(), t);
}

fn check_parse_prefix_returns_remaining_suffix() void {
    let t = test.report(io.stderr())..&;
    let parsed = parse_prefix(" [1, 2] tail").should_ok().sum(@loc(), t);
    parsed.value.kind
        .should()
        .eq(Kind.Array)
        .sum(@loc(), t);
    parsed.remaining
        .should()
        .eq((" tail"))
        .sum(@loc(), t);
}

fn check_validate_accepts_complete_document() void {
    let t = test.report(io.stderr())..&;
    _ = validate("{\"ok\":true,\"items\":[1,2,3]}").should_ok().sum(@loc(), t);
}

fn check_parse_rejects_trailing_data() void {
    let t = test.report(io.stderr())..&;
    match (parse("true false").should_err().sum(@loc(), t)) {
        .{ TrailingData: _ } => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_parse_rejects_bad_escape() void {
    let t = test.report(io.stderr())..&;
    match (parse("\"\\x\"").should_err().sum(@loc(), t)) {
        .{ InvalidEscape: _ } => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_parse_rejects_leading_zero_number() void {
    let t = test.report(io.stderr())..&;
    match (parse("01").should_err().sum(@loc(), t)) {
        .{ TrailingData: _ } => {},
        .{ InvalidNumber: _ } => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_direct_owned_document_parse_rejects_trailing_commas() void {
    let t = test.report(io.stderr())..&;
    match (parse_owned_document("[1,]").should_err().sum(@loc(), t)) {
        .{ Parse: .{ UnexpectedByte: _ } } => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (parse_owned_document("{\"a\":1,}").should_err().sum(@loc(), t)) {
        .{ Parse: .{ UnexpectedByte: _ } } => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_direct_indexed_document_parse_rejects_trailing_commas() void {
    let t = test.report(io.stderr())..&;
    match (parse_indexed_object_document("{\"a\":1,}").should_err().sum(@loc(), t)) {
        .{ Materialize: .{ Parse: .{ UnexpectedByte: _ } } } => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_compact_render_strips_insignificant_whitespace() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{ \"ok\" : [ 1, 2 , 3 ], \"msg\" : \"hi\\n\" }").should_ok().sum(@loc(), t);
    let mut out = [128]u8.{undef};
    let written = render_compact(value, out..&[0 .. 128]).should_ok().sum(@loc(), t);
    out.&[0 .. written]
        .should()
        .eq(("{\"ok\":[1,2,3],\"msg\":\"hi\\n\"}"))
        .sum(@loc(), t);
}

fn check_compact_size_matches_rendered_size() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{ \"ok\" : [ 1, 2 , 3 ], \"msg\" : \"hi\\n\" }").should_ok().sum(@loc(), t);
    let expected = compact_size(value).should_ok().sum(@loc(), t);
    let mut out = [128]u8.{undef};
    let written = render_compact(value, out..&[0 .. 128]).should_ok().sum(@loc(), t);
    written
        .should()
        .eq(expected)
        .sum(@loc(), t);
}

fn check_compact_render_reports_small_buffer() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"ok\":true}").should_ok().sum(@loc(), t);
    let mut out = [4]u8.{undef};
    match (render_compact(value, out..&[0 .. 4]).should_err().sum(@loc(), t)) {
        .BufferTooSmall => {},
        .{ Parse: _ } => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_error_location_reports_line_and_column() void {
    let t = test.report(io.stderr())..&;
    let input = "{\n  \"ok\" true\n}";
    let err = parse(input).should_err().sum(@loc(), t);
    let offset = error_offset(err).should_some().sum(@loc(), t);
    offset
        .should()
        .eq(9)
        .sum(@loc(), t);
    let loc = locate_error(input, err).should_some().sum(@loc(), t);
    loc.offset
        .should()
        .eq(9)
        .sum(@loc(), t);
    loc.line
        .should()
        .eq(2)
        .sum(@loc(), t);
    loc.column
        .should()
        .eq(8)
        .sum(@loc(), t);
}

fn main() i32 {
    check_parse_scalar_kinds();
    check_parse_trims_outer_whitespace_and_preserves_raw_value();
    check_parse_prefix_returns_remaining_suffix();
    check_validate_accepts_complete_document();
    check_parse_rejects_trailing_data();
    check_parse_rejects_bad_escape();
    check_parse_rejects_leading_zero_number();
    check_direct_owned_document_parse_rejects_trailing_commas();
    check_direct_indexed_document_parse_rejects_trailing_commas();
    check_compact_render_strips_insignificant_whitespace();
    check_compact_size_matches_rendered_size();
    check_compact_render_reports_small_buffer();
    check_error_location_reports_line_and_column();
    check_array_cursor_iterates_values();
    check_object_cursor_iterates_fields();
    check_value_lookup_helpers();
    check_borrowed_required_field_and_index_helpers();
    check_borrowed_optional_schema_helpers();
    check_empty_cursor_exhaustion();
    check_container_helpers();
    check_kind_helpers_and_scalar_accessors();
    check_container_count_and_presence_helpers();
    check_typed_integer_accessors();
    check_typed_integer_errors();
    check_typed_float_accessors();
    check_typed_float_errors();
    check_raw_integer_parse_helpers();
    check_raw_float_parse_helpers();
    check_decoded_string_helpers();
    check_decoded_string_errors();
    check_decoded_object_key_helpers();
    check_borrowed_object_entry_value_helpers();
    check_owned_materialization();
    check_owned_materialization_with_arena_reset();
    check_indexed_object_view();
    check_indexed_object_view_with_arena_reset();
    check_owned_document_api();
    check_packed_document_lookup_helpers();
    check_packed_indexed_object_document_api();
    check_packed_document_string_decode_errors();
    check_owned_document_schema_and_duplicate_helpers();
    check_indexed_object_document_api();
    check_indexed_object_document_nested_lookup();
    check_arena_mark_rewind_with_json_materialization();
    check_owned_compact_render_round_trip();
    check_owned_compact_render_reports_small_buffer();
    check_owned_dom_build_and_mutation();
    check_owned_dom_node_pool_reuse();
    check_required_field_decode_helpers();
    return 0;
}
