};

fn next_array_item(cursor: *mut ArrayCursor) json.Value {
    return test.expect_some(test.expect_ok(cursor.next()));
}

fn next_object_entry(cursor: *mut json.ObjectCursor) ObjectEntry {
    return test.expect_some(test.expect_ok(cursor.next()));
}

fn check_array_cursor_iterates_values() void {
    let value = test.expect_ok(parse("[1, true, {\"ok\":false}]"));
    let mut cursor = test.expect_some(value.array_cursor());

    let first = next_array_item(cursor..&);
    let second = next_array_item(cursor..&);
    let third = next_array_item(cursor..&);
    test.assert(first.raw == ("1"), "expected first array item", .{});
    test.assert(second.raw == ("true"), "expected second array item", .{});
    test.assert(third.raw == ("{\"ok\":false}"), "expected third array item", .{});
    test.assert(test.expect_ok(cursor..&.next()).is_none(), "expected exhausted array cursor", .{});
    test.assert(cursor.is_done(), "expected array cursor done after exhaustion", .{});
}

fn check_object_cursor_iterates_fields() void {
    let value = test.expect_ok(parse("{\"ok\":true,\"msg\":\"hi\"}"));
    let mut cursor = test.expect_some(value.object_cursor());

    let first = next_object_entry(cursor..&);
    let second = next_object_entry(cursor..&);
    test.assert(first.key_raw == ("\"ok\""), "expected raw object key", .{});
    test.assert(first.key_text == ("ok"), "expected unquoted key text", .{});
    test.assert(first.value.raw == ("true"), "expected first object value", .{});
    test.assert(second.key_eq("msg"), "expected key_eq helper", .{});
    test.assert(second.value.raw == ("\"hi\""), "expected second object value", .{});
    test.assert(test.expect_ok(cursor..&.next()).is_none(), "expected exhausted object cursor", .{});
    test.assert(cursor.is_done(), "expected object cursor done after exhaustion", .{});
}

fn check_value_lookup_helpers() void {
    let array = test.expect_ok(parse("[10, 20, 30]"));
    test.assert(
        test.expect_some(test.expect_ok(array.get_index(usize.{1}))).raw == ("20"),
        "expected borrowed array lookup",
        .{}
    );
    test.assert(
        test.expect_ok(array.get_index(usize.{9})).is_none(),
        "expected out-of-range array lookup to return none",
        .{}
    );

    let object = test.expect_ok(parse("{\"ok\":true,\"msg\":\"hi\"}"));
    let msg = test.expect_some(test.expect_ok(object.get_field("msg")));
    test.assert(msg.value.raw == ("\"hi\""), "expected borrowed object lookup", .{});
    test.assert(
        test.expect_ok(object.get_field("missing")).is_none(),
        "expected missing object lookup to return none",
        .{}
    );

    test.assert(
        test.expect_ok(object.get_index(usize.{0})).is_none(),
        "expected non-array index lookup to return none",
        .{}
    );
    test.assert(
        test.expect_ok(array.get_field("ok")).is_none(),
        "expected non-object field lookup to return none",
        .{}
    );

    let duplicates = test.expect_ok(parse("{\"dup\":1,\"dup\":2,\"ok\":true,\"dup\":3}"));
    test.eq(test.expect_some(test.expect_ok(duplicates.count_fields("dup"))), usize.{3});
    let last_dup = test.expect_some(test.expect_ok(duplicates.get_last_field("dup")));
    test.assert(last_dup.value.raw == ("3"), "expected borrowed last duplicate field helper", .{});
    let mut collected = [2]ObjectEntry.{ undef, undef };
    let total = test.expect_some(test.expect_ok(duplicates.collect_fields("dup", collected..[0 .. 2])));
    test.eq(total, usize.{3});
    test.assert(collected.[0].value.raw == ("1"), "expected borrowed collect first duplicate", .{});
    test.assert(collected.[1].value.raw == ("2"), "expected borrowed collect second duplicate", .{});
}

fn check_borrowed_required_field_and_index_helpers() void {
    let value = test.expect_ok(
        parse("{\"msg\":\"hi\\n\",\"count\":12,\"items\":[\"x\\n\",7,{\"ok\":true}],\"dup\":1,\"dup\":2,\"flt\":1.5}")
    );
    test.eq(test.expect_ok(value.require_u64_field("count")), u64.{12});
    test.eq(test.expect_ok(value.require_u32_field("count")), u32.{12});
    test.eq(test.expect_ok(value.require_u16_field("count")), u16.{12});
    test.eq(test.expect_ok(value.require_u8_field("count")), u8.{12});
    test.eq(test.expect_ok(value.require_i64_field("count")), i64.{12});
    test.eq(test.expect_ok(value.require_i32_field("count")), i32.{12});
    test.eq(test.expect_ok(value.require_i16_field("count")), i16.{12});
    test.eq(test.expect_ok(value.require_i8_field("count")), i8.{12});
    test.eq(test.expect_ok(value.require_usize_field("count")), usize.{12});
    test.eq(test.expect_ok(value.require_isize_field("count")), isize.{12});
    test.eq(test.expect_ok(value.require_f64_field("flt")), 1.5);
    test.eq(test.expect_ok(value.require_f32_field("flt")), f32.{1.5});
    test.assert(
        test.expect_ok(value.require_string_text_field("msg")) == ("hi\\n"),
        "expected borrowed required string-text helper",
        .{}
    );

    let decoded_size = test.expect_ok(value.require_decoded_string_size_field("msg"));
    test.eq(decoded_size, usize.{3});
    let mut out = [8]u8.{undef};
    let written = test.expect_ok(value.write_required_decoded_string_field("msg", out..[0 .. 8]));
    test.eq(written, decoded_size);
    test.assert(
        out.[0 .. written] == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected borrowed required decoded-string write",
        .{}
    );

    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut cloned = test.expect_ok(value.clone_required_decoded_string_field("msg", gpa));
    defer cloned..&.deinit(gpa);
    test.assert(
        cloned.&.as_str() == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected borrowed required decoded-string clone",
        .{}
    );

    let items = test.expect_ok(value.require_array_field("items"));
    test.assert(items.is_array(), "expected borrowed required array helper", .{});
    test.assert(test.expect_ok(items.require_string_raw_index(0)) == ("\"x\\n\""), "expected borrowed string raw index", .{});
    test.eq(test.expect_ok(items.require_u64_index(1)), u64.{7});
    test.eq(test.expect_ok(items.require_u32_index(1)), u32.{7});
    test.eq(test.expect_ok(items.require_u16_index(1)), u16.{7});
    test.eq(test.expect_ok(items.require_u8_index(1)), u8.{7});
    test.eq(test.expect_ok(items.require_i64_index(1)), i64.{7});
    test.eq(test.expect_ok(items.require_i32_index(1)), i32.{7});
    test.eq(test.expect_ok(items.require_i16_index(1)), i16.{7});
    test.eq(test.expect_ok(items.require_i8_index(1)), i8.{7});
    test.eq(test.expect_ok(items.require_usize_index(1)), usize.{7});
    test.eq(test.expect_ok(items.require_isize_index(1)), isize.{7});
    let nested = test.expect_ok(items.require_object_index(2));
    test.eq(test.expect_ok(nested.require_bool_field("ok")), true);

    let mut cloned_item = test.expect_ok(items.clone_required_decoded_string_index(0, gpa));
    defer cloned_item..&.deinit(gpa);
    test.assert(
        cloned_item.&.as_str() == ([2]u8.{ b'x', b'\n' }.[0 .. 2]),
        "expected borrowed decoded array string clone",
        .{}
    );

    match (test.expect_err(value.require_bool_field("missing"))) {
        .Missing => {},
        _ => test.fail("expected borrowed required missing-field error", .{}),
    }
    match (test.expect_err(value.require_bool_field("dup"))) {
        .{ Duplicate: count } => test.eq(count, usize.{2}),
        _ => test.fail("expected borrowed required duplicate-field error", .{}),
    }
    match (test.expect_err(value.require_bool_field("msg"))) {
        .{ UnexpectedKind: kind } => test.eq(kind, Kind.String),
        _ => test.fail("expected borrowed required wrong-kind field error", .{}),
    }
    match (test.expect_err(items.require_index(usize.{9}))) {
        .OutOfRange => {},
        _ => test.fail("expected borrowed required out-of-range error", .{}),
    }
    match (test.expect_err(items.require_u64_index(0))) {
        .{ UnexpectedKind: kind } => test.eq(kind, Kind.String),
        _ => test.fail("expected borrowed required wrong-kind index error", .{}),
    }

    let scalar = test.expect_ok(parse("true"));
    match (test.expect_err(scalar.require_field("x"))) {
        .{ UnexpectedKind: kind } => test.eq(kind, Kind.Bool),
        _ => test.fail("expected non-object borrowed field access to report root kind", .{}),
    }
    match (test.expect_err(scalar.require_index(usize.{0}))) {
        .{ UnexpectedKind: kind } => test.eq(kind, Kind.Bool),
        _ => test.fail("expected non-array borrowed index access to report root kind", .{}),
    }
}

fn check_empty_cursor_exhaustion() void {
    let empty_array = test.expect_ok(parse("[]"));
    let mut array_cursor = test.expect_some(empty_array.array_cursor());
    test.assert(
        test.expect_ok(array_cursor..&.next()).is_none(),
        "expected empty array cursor to yield none immediately",
        .{}
    );
    test.assert(array_cursor.is_done(), "expected empty array cursor done", .{});

    let empty_object = test.expect_ok(parse("{}"));
    let mut object_cursor = test.expect_some(empty_object.object_cursor());
    test.assert(
        test.expect_ok(object_cursor..&.next()).is_none(),
        "expected empty object cursor to yield none immediately",
        .{}
    );
    test.assert(object_cursor.is_done(), "expected empty object cursor done", .{});
}

fn check_packed_document_lookup_helpers() void {
    let doc = test.expect_ok(
        parse_packed_document("{\"ok\":true,\"user\":{\"id\":7,\"name\":\"kern\"},\"items\":[{\"sku\":\"abc\",\"qty\":1,\"price\":12.5},{\"sku\":\"xyz\",\"qty\":4,\"price\":5.75}],\"dup\":1,\"dup\":2,\"flt\":1.5}")
    )..&;
    defer doc.deinit();
    let root = doc.root();

    test.assert(root.is_object(), "expected packed root object", .{});
    test.eq(test.expect_some(root.object_len()), usize.{6});
    test.eq(test.expect_some(root.get_bool("ok")), true);
    test.assert(root.has_field("user"), "expected packed has_field helper", .{});
    test.eq(test.expect_some(root.count_fields("dup")), usize.{2});
    let mut collected = [2]json.PackedObjectEntry.{ undef, undef };
    let total = test.expect_some(root.collect_fields("dup", collected..[0 .. 2]));
    test.eq(total, usize.{2});
    test.eq(test.expect_some(test.expect_ok(collected.[0].u64_value())), u64.{1});
    test.eq(test.expect_some(test.expect_ok(collected.[1].u64_value())), u64.{2});
    let last_dup = test.expect_some(root.get_last_field("dup"));
    test.eq(test.expect_some(test.expect_ok(last_dup.u64_value())), u64.{2});
    test.eq(test.expect_ok(root.require_bool("ok")), true);
    test.eq(test.expect_ok(root.require_f64("flt")), 1.5);

    let user = test.expect_some(root.get_object("user"));
    test.eq(test.expect_some(test.expect_ok(user.get_u64("id"))), u64.{7});
    test.eq(test.expect_some(test.expect_ok(user.get_u32("id"))), u32.{7});
    test.assert(
        test.expect_some(user.get_string("name")) == ("kern"),
        "expected packed string field",
        .{}
    );
    test.assert(
        test.expect_ok(user.require_string("name")) == ("kern"),
        "expected packed required string field",
        .{}
    );

    let items = test.expect_some(root.get_array("items"));
    test.eq(test.expect_some(items.array_len()), usize.{2});
    let item0 = test.expect_some(items.get_index(usize.{0}));
    let item1 = test.expect_some(items.get_index(usize.{1}));
    test.assert(
        test.expect_some(item0.get_string("sku")) == ("abc"),
        "expected packed first item string field",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(item1.get_u64("qty"))), u64.{4});
    test.eq(test.expect_some(test.expect_ok(item1.get_i64("qty"))), i64.{4});
    test.eq(test.expect_some(test.expect_ok(item1.get_f64("price"))), 5.75);
    test.eq(test.expect_some(test.expect_ok(item1.get_f32("price"))), f32.{5.75});

    match (test.expect_err(root.require_bool("dup"))) {
        .{ Duplicate: count } => test.eq(count, usize.{2}),
        _ => test.fail("expected packed duplicate-field error", .{}),
    }
    match (test.expect_err(root.require_u64("user"))) {
        .{ UnexpectedKind: kind } => test.eq(kind, Kind.Object),
        _ => test.fail("expected packed wrong-kind field error", .{}),
    }
}

fn check_packed_indexed_object_document_api() void {
    let doc = test.expect_ok(
        parse_packed_indexed_object_document("{\"ok\":true,\"user\":{\"id\":7,\"name\":\"kern\"},\"items\":[{\"sku\":\"abc\",\"qty\":1,\"price\":12.5},{\"sku\":\"xyz\",\"qty\":4,\"price\":5.75}],\"dup\":1,\"dup\":2,\"flt\":1.5}")
    )..&;
    defer doc.deinit();

    let root = doc.root();
    test.assert(root.is_object(), "expected packed indexed root object", .{});
    test.eq(test.expect_some(root.object_len()), usize.{6});

    let view = doc.view();
    test.eq(view.len(), usize.{6});
    test.assert(!view.is_empty(), "expected packed indexed view non-empty", .{});
    test.eq(test.expect_some(view.get_bool("ok")), true);
    test.assert(view.has_field("user"), "expected packed indexed has_field helper", .{});
    test.eq(view.count_fields("dup"), usize.{2});

    let first = test.expect_some(view.get_entry(usize.{0}));
    test.assert(first.key_eq("ok"), "expected packed indexed ordered entry access", .{});
    let dup = test.expect_some(view.get_field("dup"));
    test.eq(test.expect_some(test.expect_ok(dup.u64_value())), u64.{1});
    let last_dup = test.expect_some(view.get_last_field("dup"));
    test.eq(test.expect_some(test.expect_ok(last_dup.u64_value())), u64.{2});

    let mut collected = [1]json.PackedObjectEntry.{ undef };
    let total = view.collect_fields("dup", collected..[0 .. 1]);
    test.eq(total, usize.{2});
    test.eq(test.expect_some(test.expect_ok(collected.[0].u64_value())), u64.{1});

    test.eq(test.expect_ok(view.require_bool("ok")), true);
    test.eq(test.expect_ok(view.require_f64("flt")), 1.5);
    let user = test.expect_ok(view.require_object("user"));
    test.eq(test.expect_some(test.expect_ok(user.get_u64("id"))), u64.{7});
    test.assert(
        test.expect_some(user.get_string("name")) == ("kern"),
        "expected packed indexed nested object access",
        .{}
    );

    let items = test.expect_ok(view.require_array("items"));
    let item0 = test.expect_some(items.get_index(usize.{0}));
    let item1 = test.expect_some(items.get_index(usize.{1}));
    test.assert(
        test.expect_some(item0.get_string("sku")) == ("abc"),
        "expected packed indexed first item string field",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(item1.get_u64("qty"))), u64.{4});
    test.eq(test.expect_some(test.expect_ok(item1.get_f64("price"))), 5.75);

    match (test.expect_err(view.require_u64("dup"))) {
        .{ Duplicate: count } => test.eq(count, usize.{2}),
        _ => test.fail("expected packed indexed duplicate-field error", .{}),
    }
    match (test.expect_err(view.require_u64("user"))) {
        .{ UnexpectedKind: kind } => test.eq(kind, Kind.Object),
        _ => test.fail("expected packed indexed wrong-kind error", .{}),
    }
    match (test.expect_err(parse_packed_indexed_object_document("[1,2,3]"))) {
        .RootNotObject => {},
        _ => test.fail("expected packed indexed non-object root error", .{}),
    }
}

fn check_packed_document_string_decode_errors() void {
    match (test.expect_err(parse_packed_document("\"\\uD800\""))) {
        .{ String: .{ InvalidUnicodeEscape: offset } } => test.eq(offset, usize.{1}),
        _ => test.fail("expected packed string invalid surrogate rejection", .{}),
    }

    match (test.expect_err(parse_packed_document("{\"\\uD800\":1}"))) {
        .{ String: .{ InvalidUnicodeEscape: offset } } => test.eq(offset, usize.{1}),
        _ => test.fail("expected packed object-key invalid surrogate rejection", .{}),
    }

    match (test.expect_err(parse_packed_indexed_object_document("{\"\\uD800\":1}"))) {
        .{ Materialize: .{ String: .{ InvalidUnicodeEscape: offset } } } => test.eq(offset, usize.{1}),
        _ => test.fail("expected packed indexed object-key invalid surrogate rejection", .{}),
    }
}

fn check_borrowed_optional_schema_helpers() void {
    let value = test.expect_ok(
        parse("{\"flag\":true,\"count\":12,\"msg\":\"hi\\n\",\"items\":[\"x\\n\",7,{\"ok\":false}],\"nested\":{\"ok\":false},\"dup\":1,\"dup\":2,\"flt\":1.5}")
    );

    test.eq(test.expect_some(test.expect_ok(value.get_bool_field("flag"))), true);
    test.eq(test.expect_some(test.expect_ok(value.get_u64_field("count"))), u64.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_u32_field("count"))), u32.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_u16_field("count"))), u16.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_u8_field("count"))), u8.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_i64_field("count"))), i64.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_i32_field("count"))), i32.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_i16_field("count"))), i16.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_i8_field("count"))), i8.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_usize_field("count"))), usize.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_isize_field("count"))), isize.{12});
    test.eq(test.expect_some(test.expect_ok(value.get_f64_field("flt"))), 1.5);
    test.eq(test.expect_some(test.expect_ok(value.get_f32_field("flt"))), f32.{1.5});
    test.assert(
        test.expect_some(test.expect_ok(value.get_number_text_field("count"))) == ("12"),
        "expected borrowed optional number-text field helper",
        .{}
    );
    test.assert(
        test.expect_some(test.expect_ok(value.get_string_raw_field("msg"))) == ("\"hi\\n\""),
        "expected borrowed optional string-raw field helper",
        .{}
    );
    test.assert(
        test.expect_some(test.expect_ok(value.get_string_text_field("msg"))) == ("hi\\n"),
        "expected borrowed optional string-text field helper",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(value.get_decoded_string_size_field("msg"))), usize.{3});

    let mut out = [8]u8.{undef};
    let written = test.expect_some(test.expect_ok(value.write_decoded_string_field("msg", out..[0 .. 8])));
    test.eq(written, usize.{3});
    test.assert(
        out.[0 .. written] == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected borrowed optional decoded-string field write",
        .{}
    );

    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut cloned = test.expect_some(test.expect_ok(value.clone_decoded_string_field("msg", gpa)));
    defer cloned..&.deinit(gpa);
    test.assert(
        cloned.&.as_str() == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected borrowed optional decoded-string field clone",
        .{}
    );

    let items = test.expect_some(test.expect_ok(value.get_array_field("items")));
    test.assert(items.is_array(), "expected borrowed optional array field helper", .{});
    test.assert(
        test.expect_some(test.expect_ok(items.get_string_raw_index(0))) == ("\"x\\n\""),
        "expected borrowed optional string-raw index helper",
        .{}
    );
    test.assert(
        test.expect_some(test.expect_ok(items.get_string_text_index(0))) == ("x\\n"),
        "expected borrowed optional string-text index helper",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(items.get_decoded_string_size_index(0))), usize.{2});
    let written_item = test.expect_some(test.expect_ok(items.write_decoded_string_index(0, out..[0 .. 8])));
    test.eq(written_item, usize.{2});
    test.assert(
        out.[0 .. written_item] == ([2]u8.{ b'x', b'\n' }.[0 .. 2]),
        "expected borrowed optional decoded-string index write",
        .{}
    );

    let mut cloned_item = test.expect_some(test.expect_ok(items.clone_decoded_string_index(0, gpa)));
    defer cloned_item..&.deinit(gpa);
    test.assert(
        cloned_item.&.as_str() == ([2]u8.{ b'x', b'\n' }.[0 .. 2]),
        "expected borrowed optional decoded-string index clone",
        .{}
    );

    test.eq(test.expect_some(test.expect_ok(items.get_u64_index(1))), u64.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_u32_index(1))), u32.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_u16_index(1))), u16.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_u8_index(1))), u8.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_i64_index(1))), i64.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_i32_index(1))), i32.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_i16_index(1))), i16.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_i8_index(1))), i8.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_usize_index(1))), usize.{7});
    test.eq(test.expect_some(test.expect_ok(items.get_isize_index(1))), isize.{7});
    let nested_item = test.expect_some(test.expect_ok(items.get_object_index(2)));
    test.eq(test.expect_some(test.expect_ok(nested_item.get_bool_field("ok"))), false);

    let nested = test.expect_some(test.expect_ok(value.get_object_field("nested")));
    test.eq(test.expect_some(test.expect_ok(nested.get_bool_field("ok"))), false);
    test.eq(test.expect_some(test.expect_ok(value.get_u64_field("dup"))), u64.{1});

    test.assert(
        test.expect_ok(value.get_bool_field("msg")).is_none(),
        "expected borrowed optional field helper none for wrong kind",
        .{}
    );
    test.assert(
        test.expect_ok(value.get_string_text_field("missing")).is_none(),
        "expected borrowed optional field helper none for missing field",
        .{}
    );
    test.assert(
        test.expect_ok(items.get_bool_index(usize.{9})).is_none(),
        "expected borrowed optional index helper none for out of range",
        .{}
    );
    test.assert(
        test.expect_ok(items.get_u64_index(usize.{0})).is_none(),
        "expected borrowed optional index helper none for wrong kind",
        .{}
    );

    let scalar = test.expect_ok(parse("true"));
    test.assert(
        test.expect_ok(scalar.get_bool_field("x")).is_none(),
        "expected scalar borrowed optional field helper to return none",
        .{}
    );
    test.assert(
        test.expect_ok(scalar.get_u64_index(usize.{0})).is_none(),
        "expected scalar borrowed optional index helper to return none",
        .{}
    );
}

fn check_container_helpers() void {
    let array = test.expect_ok(parse("[1]"));
    let object = test.expect_ok(parse("{\"ok\":true}"));
    let scalar = test.expect_ok(parse("\"hi\""));

    test.assert(array.is_container(), "expected array to be container", .{});
    test.assert(object.is_container(), "expected object to be container", .{});
    test.assert(!scalar.is_container(), "expected string not to be container", .{});
}

fn check_kind_helpers_and_scalar_accessors() void {
    let null_value = test.expect_ok(parse("null"));
    let true_value = test.expect_ok(parse("true"));
    let false_value = test.expect_ok(parse("false"));
    let number_value = test.expect_ok(parse("-12.5e+2"));
    let string_value = test.expect_ok(parse("\"hi\\n\""));
    let array_value = test.expect_ok(parse("[1]"));
    let object_value = test.expect_ok(parse("{\"ok\":true}"));

    test.assert(null_value.is_null(), "expected null helper", .{});
    test.assert(true_value.is_bool(), "expected bool helper", .{});
    test.assert(number_value.is_number(), "expected number helper", .{});
    test.assert(string_value.is_string(), "expected string helper", .{});
    test.assert(array_value.is_array(), "expected array helper", .{});
    test.assert(object_value.is_object(), "expected object helper", .{});

    test.eq(test.expect_some(true_value.bool_value()), true);
    test.eq(test.expect_some(false_value.bool_value()), false);
    test.assert(number_value.bool_value().is_none(), "expected non-bool bool_value none", .{});

    test.assert(
        test.expect_some(number_value.number_text()) == ("-12.5e+2"),
        "expected borrowed number text",
        .{}
    );
    test.assert(
        test.expect_some(string_value.string_raw()) == ("\"hi\\n\""),
        "expected borrowed string raw slice",
        .{}
    );
    test.assert(
        test.expect_some(string_value.string_text()) == ("hi\\n"),
        "expected borrowed string text without quotes",
        .{}
    );
    test.assert(null_value.string_text().is_none(), "expected non-string string_text none", .{});
}

fn check_container_count_and_presence_helpers() void {
    let array = test.expect_ok(parse("[10, 20, 30]"));
    let object = test.expect_ok(parse("{\"ok\":true,\"msg\":\"hi\"}"));
    let scalar = test.expect_ok(parse("true"));

    test.eq(test.expect_some(test.expect_ok(array.array_len())), usize.{3});
    test.eq(test.expect_some(test.expect_ok(object.object_len())), usize.{2});
    test.assert(
        test.expect_ok(object.has_field("msg")),
        "expected object field presence helper",
        .{}
    );
    test.assert(
        !test.expect_ok(object.has_field("missing")),
        "expected missing object field helper",
        .{}
    );
    test.assert(
        test.expect_ok(array.has_field("msg")) == false,
        "expected non-object field presence helper to be false",
        .{}
    );
    test.assert(
        test.expect_ok(scalar.array_len()).is_none(),
        "expected non-array array_len to return none",
        .{}
    );
    test.assert(
        test.expect_ok(scalar.object_len()).is_none(),
        "expected non-object object_len to return none",
        .{}
    );
}

fn check_typed_integer_accessors() void {
    let unsigned = test.expect_ok(parse("18446744073709551615"));
    let signed = test.expect_ok(parse("-9223372036854775808"));
    let small = test.expect_ok(parse("42"));
    let byte = test.expect_ok(parse("255"));
    let neg_byte = test.expect_ok(parse("-128"));
    let scalar = test.expect_ok(parse("true"));

    test.eq(test.expect_some(test.expect_ok(unsigned.u64_value())), u64.{18446744073709551615});
    test.eq(test.expect_some(test.expect_ok(signed.i64_value())), i64.{-9223372036854775808});
    test.eq(test.expect_some(test.expect_ok(small.u32_value())), u32.{42});
    test.eq(test.expect_some(test.expect_ok(small.i32_value())), i32.{42});
    test.eq(test.expect_some(test.expect_ok(small.u16_value())), u16.{42});
    test.eq(test.expect_some(test.expect_ok(small.i16_value())), i16.{42});
    test.eq(test.expect_some(test.expect_ok(byte.u8_value())), u8.{255});
    test.eq(test.expect_some(test.expect_ok(neg_byte.i8_value())), i8.{-128});
    test.eq(test.expect_some(test.expect_ok(small.usize_value())), usize.{42});
    test.eq(test.expect_some(test.expect_ok(small.isize_value())), isize.{42});

    test.assert(
        test.expect_ok(scalar.u64_value()).is_none(),
        "expected non-number u64_value none",
        .{}
    );
    test.assert(
        test.expect_ok(scalar.i64_value()).is_none(),
        "expected non-number i64_value none",
        .{}
    );
}

fn check_typed_integer_errors() void {
    let negative = test.expect_ok(parse("-1"));
    let decimal = test.expect_ok(parse("12.5"));
    let exponent = test.expect_ok(parse("1e9"));
    let huge_unsigned = test.expect_ok(parse("18446744073709551616"));
    let huge_signed = test.expect_ok(parse("9223372036854775808"));
    let u32_wide = test.expect_ok(parse("4294967296"));
    let i8_wide = test.expect_ok(parse("128"));

    match (test.expect_err(negative.u64_value())) {
        .NegativeUnsigned => {},
        _ => test.fail("expected negative unsigned rejection", .{}),
    }
    match (test.expect_err(decimal.u64_value())) {
        .NotInteger => {},
        _ => test.fail("expected decimal integer rejection", .{}),
    }
    match (test.expect_err(exponent.i64_value())) {
        .NotInteger => {},
        _ => test.fail("expected exponent integer rejection", .{}),
    }
    match (test.expect_err(huge_unsigned.u64_value())) {
        .Overflow => {},
        _ => test.fail("expected unsigned overflow", .{}),
    }
    match (test.expect_err(huge_signed.i64_value())) {
        .Overflow => {},
        _ => test.fail("expected signed overflow", .{}),
    }
    match (test.expect_err(u32_wide.u32_value())) {
        .Overflow => {},
        _ => test.fail("expected u32 overflow", .{}),
    }
    match (test.expect_err(i8_wide.i8_value())) {
        .Overflow => {},
        _ => test.fail("expected i8 overflow", .{}),
    }

    let invalid = json.Value.{ kind: Kind.Number, raw: "01" };
    match (test.expect_err(invalid.u64_value())) {
        .{ Parse: err } => match (err) {
            .{ InvalidNumber: offset } => test.eq(offset, usize.{1}),
            _ => test.fail("expected malformed raw number invalid-number rejection", .{}),
        },
        _ => test.fail("expected malformed raw number parse rejection", .{}),
    }
}

fn check_typed_float_accessors() void {
    let integer = test.expect_ok(parse("42"));
    let fraction = test.expect_ok(parse("1.5"));
    let exact_exp = test.expect_ok(parse("125e-3"));
    let negative = test.expect_ok(parse("-12.5e+2"));
    let scalar = test.expect_ok(parse("false"));

    test.eq(test.expect_some(test.expect_ok(integer.f64_value())), 42.0);
    test.eq(test.expect_some(test.expect_ok(fraction.f64_value())), 1.5);
    test.eq(test.expect_some(test.expect_ok(exact_exp.f64_value())), 0.125);
    test.eq(test.expect_some(test.expect_ok(negative.f64_value())), -1250.0);
    test.eq(test.expect_some(test.expect_ok(integer.f32_value())), 42.0 as f32);
    test.eq(test.expect_some(test.expect_ok(fraction.f32_value())), 1.5 as f32);
    test.eq(test.expect_some(test.expect_ok(exact_exp.f32_value())), 0.125 as f32);
    test.eq(test.expect_some(test.expect_ok(negative.f32_value())), -1250.0 as f32);
    test.assert(
        test.expect_ok(scalar.f64_value()).is_none(),
        "expected non-number f64_value none",
        .{}
    );
    test.assert(
        test.expect_ok(scalar.f32_value()).is_none(),
        "expected non-number f32_value none",
        .{}
    );
}

fn check_typed_float_errors() void {
    let huge = test.expect_ok(parse("1e400"));
    let wide = test.expect_ok(parse("1e39"));

    match (huge.f64_value()) {
        .{ Err: .Overflow } => {},
        .{ Err: _ } => test.fail("expected f64 overflow error kind", .{}),
        .{ Ok: _ } => test.fail("expected f64 overflow to return err", .{}),
    }
    match (wide.f32_value()) {
        .{ Err: .Overflow } => {},
        .{ Err: _ } => test.fail("expected f32 overflow error kind", .{}),
        .{ Ok: _ } => test.fail("expected f32 overflow to return err", .{}),
    }

    let invalid = json.Value.{ kind: Kind.Number, raw: "01" };
    match (test.expect_err(invalid.f64_value())) {
        .{ Parse: .{ InvalidNumber: offset } } => test.eq(offset, usize.{1}),
        _ => test.fail("expected malformed raw float parse rejection", .{}),
    }
    match (test.expect_err(invalid.f32_value())) {
        .{ Parse: .{ InvalidNumber: offset } } => test.eq(offset, usize.{1}),
        _ => test.fail("expected malformed raw f32 parse rejection", .{}),
    }
}

fn check_raw_integer_parse_helpers() void {
    test.eq(test.expect_ok(parse_u32_raw("42")), u32.{42});
    test.eq(test.expect_ok(parse_i32_raw("-17")), i32.{-17});
    test.eq(test.expect_ok(parse_u16_raw("99")), u16.{99});
    test.eq(test.expect_ok(parse_i16_raw("-99")), i16.{-99});
    test.eq(test.expect_ok(parse_u8_raw("255")), u8.{255});
    test.eq(test.expect_ok(parse_i8_raw("-128")), i8.{-128});
    test.eq(test.expect_ok(parse_u64_raw("0")), u64.{0});
    test.eq(test.expect_ok(parse_i64_raw("-17")), i64.{-17});
    test.eq(test.expect_ok(parse_usize_raw("99")), usize.{99});
    test.eq(test.expect_ok(parse_isize_raw("-99")), isize.{-99});

    match (test.expect_err(parse_u64_raw("-7"))) {
        .NegativeUnsigned => {},
        _ => test.fail("expected raw unsigned negative rejection", .{}),
    }
    match (test.expect_err(parse_i64_raw("1.0"))) {
        .NotInteger => {},
        _ => test.fail("expected raw integer decimal rejection", .{}),
    }
    match (test.expect_err(parse_u64_raw("18446744073709551616"))) {
        .Overflow => {},
        _ => test.fail("expected raw unsigned overflow", .{}),
    }
    match (test.expect_err(parse_u32_raw("4294967296"))) {
        .Overflow => {},
        _ => test.fail("expected raw u32 overflow", .{}),
    }
    match (test.expect_err(parse_i8_raw("128"))) {
        .Overflow => {},
        _ => test.fail("expected raw i8 overflow", .{}),
    }
    match (test.expect_err(parse_u64_raw("01"))) {
        .{ Parse: err } => match (err) {
            .{ InvalidNumber: offset } => test.eq(offset, usize.{1}),
            _ => test.fail("expected raw malformed invalid-number rejection", .{}),
        },
        _ => test.fail("expected raw malformed number parse rejection", .{}),
    }
}

fn check_raw_float_parse_helpers() void {
    test.eq(test.expect_ok(parse_f32_raw("0")), 0.0 as f32);
    test.eq(test.expect_ok(parse_f32_raw("1.5")), 1.5 as f32);
    test.eq(test.expect_ok(parse_f32_raw("125e-3")), 0.125 as f32);
    test.eq(test.expect_ok(parse_f32_raw("-12.5e+2")), -1250.0 as f32);
    test.eq(test.expect_ok(parse_f32_raw("1e-50")), 0.0 as f32);
    test.eq(test.expect_ok(parse_f64_raw("0")), 0.0);
    test.eq(test.expect_ok(parse_f64_raw("1.5")), 1.5);
    test.eq(test.expect_ok(parse_f64_raw("125e-3")), 0.125);
    test.eq(test.expect_ok(parse_f64_raw("-12.5e+2")), -1250.0);
    test.eq(test.expect_ok(parse_f64_raw("100000000000000000000")), 1e20);
    test.eq(test.expect_ok(parse_f64_raw("1e-400")), 0.0);

    match (test.expect_err(parse_f64_raw("1e400"))) {
        .Overflow => {},
        _ => test.fail("expected raw float overflow", .{}),
    }
    match (parse_f32_raw("1e39")) {
        .{ Err: .Overflow } => {},
        .{ Err: _ } => test.fail("expected raw f32 overflow error kind", .{}),
        .{ Ok: _ } => test.fail("expected raw f32 overflow to return err", .{}),
    }
    match (test.expect_err(parse_f64_raw("01"))) {
        .{ Parse: .{ InvalidNumber: offset } } => test.eq(offset, usize.{1}),
        _ => test.fail("expected raw malformed float rejection", .{}),
    }
    match (test.expect_err(parse_f32_raw("01"))) {
        .{ Parse: .{ InvalidNumber: offset } } => test.eq(offset, usize.{1}),
        _ => test.fail("expected raw malformed f32 rejection", .{}),
    }
}

fn check_decoded_string_helpers() void {
    let escaped = test.expect_ok(parse("\"hi\\n\\u4F60\\u597D\\uD83D\\uDE03\""));
    let decoded_size = test.expect_some(test.expect_ok(escaped.decoded_string_size()));
    test.eq(decoded_size, usize.{13});

    let mut out = [32]u8.{undef};
    let written = test.expect_some(test.expect_ok(escaped.write_decoded_string(out..[0 .. 32])));
    test.eq(written, decoded_size);
    test.assert(
        out.[0 .. written] == ([
            13
        ]u8.{
            b'h',
            b'i',
            b'\n',
            u8.{0xE4},
            u8.{0xBD},
            u8.{0xA0},
            u8.{0xE5},
            u8.{0xA5},
            u8.{0xBD},
            u8.{0xF0},
            u8.{0x9F},
            u8.{0x98},
            u8.{0x83},
        }.[0 .. 13]),
        "expected decoded UTF-8 string bytes",
        .{}
    );

    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut owned = test.expect_some(test.expect_ok(escaped.clone_decoded_string(gpa)));
    defer owned..&.deinit(gpa);
    test.assert(
        owned.&.as_str() == (out.[0 .. written]),
        "expected allocator-backed decoded string",
        .{}
    );
}

fn check_decoded_string_errors() void {
    let escaped = test.expect_ok(parse("\"\\u0041\""));
    let mut small = [1]u8.{undef};
    match (test.expect_err(escaped.write_decoded_string(small..[0 .. 0]))) {
        .BufferTooSmall => {},
        _ => test.fail("expected decoded string buffer-too-small error", .{}),
    }

    let scalar = test.expect_ok(parse("true"));
    let mut out = [4]u8.{undef};
    test.assert(
        test.expect_ok(scalar.write_decoded_string(out..[0 .. 4])).is_none(),
        "expected non-string decoded write to return none",
        .{}
    );
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    test.assert(
        test.expect_ok(scalar.clone_decoded_string(gpa)).is_none(),
        "expected non-string decoded clone to return none",
        .{}
    );

    let invalid = json.Value.{ kind: Kind.String, raw: "\"\\uD800\"" };
    match (test.expect_err(invalid.decoded_string_size())) {
        .{ InvalidUnicodeEscape: offset } => test.eq(offset, usize.{1}),
        _ => test.fail("expected invalid surrogate pair error", .{}),
    }
    match (test.expect_err(invalid.write_decoded_string([16]u8.{undef}..[0 .. 16]))) {
        .{ InvalidUnicodeEscape: offset } => test.eq(offset, usize.{1}),
        _ => test.fail("expected invalid surrogate pair write error", .{}),
    }
}

fn check_decoded_object_key_helpers() void {
    let object = test.expect_ok(parse("{\"a\\u0042\\uD83D\\uDE03\":1}"));
    let entry = test.expect_some(test.expect_ok(object.get_field("a\\u0042\\uD83D\\uDE03")));
    let decoded_size = test.expect_ok(entry.decoded_key_size());
    test.eq(decoded_size, usize.{6});

    let mut out = [16]u8.{undef};
    let written = test.expect_ok(entry.write_decoded_key(out..[0 .. 16]));
    test.eq(written, decoded_size);
    test.assert(
        out.[0 .. written] == ([6]u8.{ b'a', b'B', u8.{0xF0}, u8.{0x9F}, u8.{0x98}, u8.{0x83} }.[0 .. 6]),
        "expected decoded object key bytes",
        .{}
    );

    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut owned = test.expect_ok(entry.clone_decoded_key(gpa));
    defer owned..&.deinit(gpa);
    test.assert(
        owned.&.as_str() == (out.[0 .. written]),
        "expected allocator-backed decoded object key",
        .{}
    );

    test.assert(
        test.expect_some(entry.number_text()) == ("1"),
        "expected borrowed entry value forwarding helper",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(entry.u64_value())), u64.{1});
}

fn check_borrowed_object_entry_value_helpers() void {
    let object = test.expect_ok(
        parse("{\"flag\":true,\"count\":12,\"msg\":\"hi\\n\",\"flt\":1.5}")
    );

    let flag = test.expect_some(test.expect_ok(object.get_field("flag")));
    test.eq(test.expect_some(flag.bool_value()), true);

    let count = test.expect_some(test.expect_ok(object.get_field("count")));
    test.assert(
        test.expect_some(count.number_text()) == ("12"),
        "expected borrowed entry number-text helper",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(count.u64_value())), u64.{12});
    test.eq(test.expect_some(test.expect_ok(count.i32_value())), i32.{12});
    test.eq(test.expect_some(test.expect_ok(count.usize_value())), usize.{12});

    let msg = test.expect_some(test.expect_ok(object.get_field("msg")));
    test.assert(
        test.expect_some(msg.string_raw()) == ("\"hi\\n\""),
        "expected borrowed entry string-raw helper",
        .{}
    );
    test.assert(
        test.expect_some(msg.string_text()) == ("hi\\n"),
        "expected borrowed entry string-text helper",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(msg.decoded_string_size())), usize.{3});
    let mut out = [8]u8.{undef};
    let written = test.expect_some(test.expect_ok(msg.write_decoded_string(out..[0 .. 8])));
    test.eq(written, usize.{3});
    test.assert(
        out.[0 .. written] == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected borrowed entry decoded-string write helper",
        .{}
    );

    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut cloned = test.expect_some(test.expect_ok(msg.clone_decoded_string(gpa)));
    defer cloned..&.deinit(gpa);
    test.assert(
        cloned.&.as_str() == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected borrowed entry decoded-string clone helper",
        .{}
    );

    let flt = test.expect_some(test.expect_ok(object.get_field("flt")));
    test.eq(test.expect_some(test.expect_ok(flt.f64_value())), 1.5);
    test.eq(test.expect_some(test.expect_ok(flt.f32_value())), f32.{1.5});
    match (test.expect_err(flt.u64_value())) {
        .NotInteger => {},
        _ => test.fail("expected borrowed entry integer decode error for float", .{}),
    }
}

fn check_owned_materialization() void {
    let value = test.expect_ok(
        parse(
            "{\"msg\":\"hi\\n\",\"items\":[true,12],\"nested\":{\"ok\":false},\"count\":12,\"pi\":1.25,\"flag\":false}"
        )
    );
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let mut owned = test.expect_ok(value.clone_owned(gpa));
    defer owned..&.deinit(gpa);

    test.assert(owned..&.is_object(), "expected owned root object helper", .{});
    test.eq(test.expect_some(owned..&.object_len()), usize.{6});
    test.assert(owned..&.has_field("msg"), "expected owned object lookup helper", .{});
    test.assert(!owned..&.has_field("missing"), "expected owned missing-field helper", .{});
    test.assert(
        test.expect_some(owned..&.get_string("msg")) == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected owned root string convenience helper",
        .{}
    );
    test.assert(
        test.expect_some(owned..&.get_array("items")).is_array(),
        "expected owned root optional array helper",
        .{}
    );
    test.assert(
        test.expect_some(owned..&.get_object("nested")).is_object(),
        "expected owned root optional object helper",
        .{}
    );
    test.assert(
        owned..&.get_array("msg").is_none(),
        "expected owned optional array helper none for wrong kind",
        .{}
    );
    test.eq(test.expect_some(owned..&.get_bool("flag")), false);

    let msg = test.expect_some(owned..&.get_field("msg"));
    test.assert(msg.key_eq("msg"), "expected owned entry key_eq helper", .{});
    test.assert(
        test.expect_some(msg.string_text()) == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
        "expected owned entry string helper",
        .{}
    );
    test.assert(
        test.expect_ok(msg.u64_value()).is_none(),
        "expected owned entry non-number typed accessor none",
        .{}
    );

    let items = test.expect_some(owned..&.get_field("items"));
    test.assert(items.key_eq("items"), "expected owned array entry key", .{});
    test.eq(test.expect_some(items.value.array_len()), usize.{2});
    test.eq(test.expect_some(test.expect_some(items.value.get_index(0)).bool_value()), true);
    let item1 = test.expect_some(items.value.get_index(1));
    test.assert(test.expect_some(item1.number_text()) == ("12"), "expected owned array number text helper", .{});
    test.eq(test.expect_some(test.expect_ok(item1.u64_value())), u64.{12});
    test.eq(test.expect_some(test.expect_ok(item1.f64_value())), 12.0);

    let nested = test.expect_some(owned..&.get_field("nested"));
    test.assert(nested.key_eq("nested"), "expected nested owned entry key", .{});
    let ok = test.expect_some(nested.value.get_field("ok"));
    test.assert(ok.key_eq("ok"), "expected nested object lookup helper", .{});
    test.eq(test.expect_some(ok.value.bool_value()), false);

    let object = match (owned) {
        .{ Object: object } => object,
        _ => test.fail("expected materialized object", .{}),
    };
    test.eq(test.expect_some(object.&.get_bool("flag")), false);
    test.assert(
        object.&.get_bool("missing").is_none(),
        "expected owned object bool lookup to return none for missing field",
        .{}
    );
    test.assert(
        object.&.get_string("items").is_none(),
        "expected owned object string lookup to return none for wrong field kind",
        .{}
    );
    test.assert(
        test.expect_some(object.&.get_number_text("count")) == ("12"),
        "expected owned object number-text helper",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(object.&.get_u64("count"))), u64.{12});
    test.eq(test.expect_some(test.expect_ok(object.&.get_i32("count"))), i32.{12});
    test.eq(test.expect_some(test.expect_ok(object.&.get_f64("count"))), 12.0);
    test.eq(test.expect_some(test.expect_ok(object.&.get_f32("pi"))), 1.25 as f32);
    test.assert(
        test.expect_ok(object.&.get_u64("msg")).is_none(),
        "expected owned object typed accessor none for wrong field kind",
        .{}
    );

    let dup_value = test.expect_ok(parse("{\"dup\":1,\"dup\":2,\"dup\":3}"));
    let mut dup_owned = test.expect_ok(dup_value.clone_owned(gpa));
    defer dup_owned..&.deinit(gpa);
    test.eq(test.expect_some(dup_owned..&.count_fields("dup")), usize.{3});
    let last_dup = test.expect_some(dup_owned..&.get_last_field("dup"));
    test.eq(test.expect_some(test.expect_ok(last_dup.u64_value())), u64.{3});
    let mut collected = [2]json.OwnedObjectEntry.{ undef, undef };
    let total = test.expect_some(dup_owned..&.collect_fields("dup", collected..[0 .. 2]));
    test.eq(total, usize.{3});
    test.eq(test.expect_some(test.expect_ok(collected.[0].u64_value())), u64.{1});
    test.eq(test.expect_some(test.expect_ok(collected.[1].u64_value())), u64.{2});
}

fn check_owned_materialization_with_arena_reset() void {
    let value = test.expect_ok(
        parse("{\"msg\":\"hi\\n\",\"items\":[true,12],\"nested\":{\"ok\":false},\"flag\":false}")
    );
    let page = Page.{}..&;
    let mut arena = Arena.{ backing: page };
    defer arena..&.deinit();

    let mut round = usize.{0};
    while (round < usize.{2}) {
        let mut owned = test.expect_ok(value.clone_owned(arena..&));
        test.assert(owned..&.is_object(), "expected arena-owned root object helper", .{});
        test.eq(test.expect_some(owned..&.object_len()), usize.{4});
        test.eq(test.expect_some(owned..&.get_bool("flag")), false);
        test.assert(
            test.expect_some(owned..&.get_string("msg")) == ([3]u8.{ b'h', b'i', b'\n' }.[0 .. 3]),
            "expected arena-owned decoded string",
            .{}
        );
        test.assert(
            test.expect_some(owned..&.get_array("items")).is_array(),
            "expected arena-owned nested array helper",
            .{}
        );
        arena..&.reset();
        round += 1;
    }
}

fn check_indexed_object_view() void {
    let value = test.expect_ok(parse("{\"a\":1,\"dup\":1,\"dup\":2,\"msg\":\"hi\",\"flag\":true}"));
    let page = Page.{}..&;
    let gpa = GPA.{ backing: page }..&;
    let owned = test.expect_ok(value.clone_owned(gpa))..&;
    defer owned.deinit(gpa);

    let view = test.expect_some(test.expect_ok(owned.build_indexed_object_view(gpa)))..&;
    defer view.deinit(gpa);

    test.eq(view.len(), usize.{5});
    test.assert(!view.is_empty(), "expected indexed object view to report non-empty", .{});
    test.assert(view.has_field("msg"), "expected indexed lookup hit", .{});
    test.assert(!view.has_field("missing"), "expected indexed lookup miss", .{});
    test.eq(test.expect_some(view.get_bool("flag")), true);
    test.assert(
        test.expect_some(view.get_string("msg")) == ("hi"),
        "expected indexed string convenience helper",
        .{}
    );
    test.assert(
        view.get_array("msg").is_none(),
        "expected indexed optional array helper none for wrong kind",
        .{}
    );
    test.assert(
        test.expect_some(view.get_number_text("a")) == ("1"),
        "expected indexed number-text convenience helper",
        .{}
    );
    test.eq(test.expect_some(test.expect_ok(view.get_u64("a"))), u64.{1});
    test.eq(test.expect_some(test.expect_ok(view.get_i32("dup"))), i32.{1});
    test.eq(test.expect_some(test.expect_ok(view.get_f64("a"))), 1.0);
    test.assert(
        test.expect_ok(view.get_u64("msg")).is_none(),
        "expected indexed typed accessor none for wrong field kind",
        .{}
    );

    let dup = test.expect_some(view.get_field("dup"));
    test.eq(test.expect_some(test.expect_ok(dup.u64_value())), u64.{1});
    let second = test.expect_some(view.get_entry(usize.{1}));
    test.eq(test.expect_some(test.expect_ok(second.u64_value())), u64.{1});
    test.eq(view.count_fields("dup"), usize.{2});
    let last_dup = test.expect_some(view.get_last_field("dup"));
    test.eq(test.expect_some(test.expect_ok(last_dup.u64_value())), u64.{2});
    let mut collected = [1]json.OwnedObjectEntry.{ undef };
    let total = view.collect_fields("dup", collected..[0 .. 1]);
    test.eq(total, usize.{2});
    test.eq(test.expect_some(test.expect_ok(collected.[0].u64_value())), u64.{1});

    let scalar = test.expect_ok(parse("true"));
    let scalar_owned = test.expect_ok(scalar.clone_owned(gpa))..&;
    defer scalar_owned.deinit(gpa);
    test.assert(
        test.expect_ok(scalar_owned.build_indexed_object_view(gpa)).is_none(),
        "expected non-object indexed view request to return none",
        .{}
    );

    let nested_value = test.expect_ok(parse("{\"items\":[1],\"nested\":{\"ok\":false}}"));
    let nested_owned = test.expect_ok(nested_value.clone_owned(gpa))..&;
    defer nested_owned.deinit(gpa);
    test.assert(
        test.expect_some(nested_owned.get_array("items")).is_array(),
        "expected owned optional array helper on nested object",
        .{}
    );
    let nested_view = test.expect_some(test.expect_ok(nested_owned.build_indexed_object_view(gpa)))..&;
    defer nested_view.deinit(gpa);
    test.assert(
        test.expect_some(nested_view.get_object("nested")).is_object(),
        "expected indexed optional object helper",
        .{}
    );
}

fn check_indexed_object_view_with_arena_reset() void {
    let value = test.expect_ok(parse("{\"a\":1,\"dup\":1,\"dup\":2,\"msg\":\"hi\",\"flag\":true}"));
    let page = Page.{}..&;
    let arena = Arena.{ backing: page }..&;
