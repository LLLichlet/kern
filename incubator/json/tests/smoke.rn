fn check_owned_document_schema_and_duplicate_helpers() void {
    let t = test.report(io.stderr())..&;
    let mut doc = parse_owned_document("{\"flag\":true,\"count\":12,\"msg\":\"hi\",\"nested\":{\"ok\":false},\"items\":[1,2],\"dup\":1,\"dup\":2,\"flt\":1.5}").should_ok().sum(
        @loc(),
        t,
    );
    defer doc..&.deinit();

    let root = doc.&.root();
    root
        .has_field("msg")
        .should()
        .sum(@loc(), t);
    root
        .has_field("missing")
        .not()
        .should()
        .sum(@loc(), t);
    root
        .count_fields("dup")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(2)
        .sum(@loc(), t);

    let msg = root
        .get_field("msg")
        .should_some()
        .sum(@loc(), t);
    msg
        .key_eq("msg")
        .should()
        .sum(@loc(), t);
    msg
        .string_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("hi"))
        .sum(@loc(), t);

    let last_dup = root
        .get_last_field("dup")
        .should_some()
        .sum(@loc(), t);
    last_dup.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );
    let mut collected = [1]json.DocumentObjectEntryRef.{ undef };
    let total = root
        .collect_fields("dup", collected..&[0 .. 1])
        .should_some()
        .sum(@loc(), t);
    total
        .should()
        .eq(2)
        .sum(@loc(), t);
    collected.[0].u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );

    root
        .require_bool("flag")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    root
        .require_u64("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    root
        .require_f64("flt")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(1.5)
        .sum(@loc(), t);
    let nested = root
        .require_object("nested")
        .should_ok()
        .sum(@loc(), t);
    nested
        .require_bool("ok")
        .should_ok()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);
    let items = root
        .require_array("items")
        .should_ok()
        .sum(@loc(), t);
    let second = items
        .get_index(1)
        .should_some()
        .sum(@loc(), t);
    second.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );

    match (root.require_bool("missing").should_err().sum(@loc(), t)) {
        .Missing => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (root.require_bool("dup").should_err().sum(@loc(), t)) {
        .{ Duplicate: count } => count.should().eq(2).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (root.require_bool("msg").should_err().sum(@loc(), t)) {
        .{ UnexpectedKind: kind } => kind.should().eq(Kind.String).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

