use base.mem.alloc.{Arena, arena, gpa};
use sys.mem.Page;
use base.test;
use std.io;
use json.{
    ArrayCursor,
    FieldDecodeError,
    FloatDecodeError,
    Kind,
    ObjectEntry,
    OwnedRenderError,
    ParseError,
    RenderError,
    compact_size,
    compact_size_owned,
    error_offset,
    locate_error,
    parse_indexed_object_document,
    parse_owned_document,
    parse,
    parse_i16_raw,
    parse_i32_raw,
    parse_i8_raw,
    parse_i64_raw,
    parse_isize_raw,
    parse_f64_raw,
    parse_f32_raw,
    parse_packed_document,
    parse_packed_indexed_object_document,
    parse_prefix,
    parse_u16_raw,
    parse_u32_raw,
    parse_u8_raw,
    parse_u64_raw,
    parse_usize_raw,
    render_compact,
    render_compact_owned,
    validate,
};

fn next_array_item(cursor: &mut ArrayCursor) json.Value {
    let t = test.report(io.stderr())..&;
    return cursor
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
}

fn next_object_entry(cursor: &mut json.ObjectCursor) ObjectEntry {
    let t = test.report(io.stderr())..&;
    return cursor
        .next()
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
}

fn check_array_cursor_iterates_values() void {
    let t = test.report(io.stderr())..&;
    let value = parse("[1, true, {\"ok\":false}]").should_ok().sum(@loc(), t);
    let mut cursor = value
        .array_cursor()
        .should_some()
        .sum(@loc(), t);

    let first = next_array_item(cursor..&);
    let second = next_array_item(cursor..&);
    let third = next_array_item(cursor..&);
    first.raw
        .should()
        .eq("1")
        .sum(@loc(), t);
    second.raw
        .should()
        .eq("true")
        .sum(@loc(), t);
    third.raw
        .should()
        .eq("{\"ok\":false}")
        .sum(@loc(), t);
    cursor
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    cursor
        .is_done()
        .should()
        .sum(@loc(), t);
}

fn check_object_cursor_iterates_fields() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"ok\":true,\"msg\":\"hi\"}").should_ok().sum(@loc(), t);
    let mut cursor = value
        .object_cursor()
        .should_some()
        .sum(@loc(), t);

    let first = next_object_entry(cursor..&);
    let second = next_object_entry(cursor..&);
    first.key_raw
        .should()
        .eq("\"ok\"")
        .sum(@loc(), t);
    first.key_text
        .should()
        .eq("ok")
        .sum(@loc(), t);
    first.value.raw
        .should()
        .eq("true")
        .sum(@loc(), t);
    second
        .key_eq("msg")
        .should()
        .sum(@loc(), t);
    second.value.raw
        .should()
        .eq("\"hi\"")
        .sum(@loc(), t);
    cursor
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    cursor
        .is_done()
        .should()
        .sum(@loc(), t);
}

fn check_value_lookup_helpers() void {
    let t = test.report(io.stderr())..&;
    let array = parse("[10, 20, 30]").should_ok().sum(@loc(), t);
    array.get_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).raw.should().eq("20").sum(
        @loc(),
        t,
    );
    array
        .get_index(9)
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    let object = parse("{\"ok\":true,\"msg\":\"hi\"}").should_ok().sum(@loc(), t);
    let msg = object
        .get_field("msg")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    msg.value.raw
        .should()
        .eq("\"hi\"")
        .sum(@loc(), t);
    object
        .get_field("missing")
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    object
        .get_index(0)
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    array
        .get_field("ok")
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    let duplicates = parse("{\"dup\":1,\"dup\":2,\"ok\":true,\"dup\":3}").should_ok().sum(
        @loc(),
        t,
    );
    duplicates.count_fields("dup").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(3).sum(
        @loc(),
        t,
    );
    let last_dup = duplicates.get_last_field("dup").should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    last_dup.value.raw
        .should()
        .eq("3")
        .sum(@loc(), t);
    let mut collected = [2]ObjectEntry.{ undef, undef };
    let total = duplicates.collect_fields("dup", collected..&[0 .. 2]).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    total
        .should()
        .eq(3)
        .sum(@loc(), t);
    collected.[0].value.raw
        .should()
        .eq("1")
        .sum(@loc(), t);
    collected.[1].value.raw
        .should()
        .eq("2")
        .sum(@loc(), t);
}

fn check_borrowed_required_field_and_index_helpers() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"msg\":\"hi\\n\",\"count\":12,\"items\":[\"x\\n\",7,{\"ok\":true}],\"dup\":1,\"dup\":2,\"flt\":1.5}").should_ok().sum(
        @loc(),
        t,
    );
    value
        .require_u64_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_u32_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_u16_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_u8_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_i64_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_i32_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_i16_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_i8_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_usize_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_isize_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(12)
        .sum(@loc(), t);
    value
        .require_f64_field("flt")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(1.5)
        .sum(@loc(), t);
    value
        .require_f32_field("flt")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(1.5)
        .sum(@loc(), t);
    value.require_string_text_field("msg").should_ok().sum(@loc(), t).should().eq(("hi\\n")).sum(
        @loc(),
        t,
    );

    let decoded_size = value
        .require_decoded_string_size_field("msg")
        .should_ok()
        .sum(@loc(), t);
    decoded_size
        .should()
        .eq(3)
        .sum(@loc(), t);
    let mut out = [8]u8.{undef};
    let written = value.write_required_decoded_string_field("msg", out..&[0 .. 8]).should_ok().sum(
        @loc(),
        t,
    );
    written
        .should()
        .eq(decoded_size)
        .sum(@loc(), t);
    out.&[0 .. written]
        .should()
        .eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3]))
        .sum(@loc(), t);

    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let mut cloned = value.clone_required_decoded_string_field("msg", gpa).should_ok().sum(
        @loc(),
        t,
    );
    defer cloned..&.deinit(gpa);
    cloned.&.as_str()
        .should()
        .eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3]))
        .sum(@loc(), t);

    let items = value
        .require_array_field("items")
        .should_ok()
        .sum(@loc(), t);
    items
        .is_array()
        .should()
        .sum(@loc(), t);
    items.require_string_raw_index(0).should_ok().sum(@loc(), t).should().eq(("\"x\\n\"")).sum(
        @loc(),
        t,
    );
    items
        .require_u64_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_u32_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_u16_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_u8_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_i64_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_i32_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_i16_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_i8_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_usize_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    items
        .require_isize_index(1)
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(7)
        .sum(@loc(), t);
    let nested = items
        .require_object_index(2)
        .should_ok()
        .sum(@loc(), t);
    nested
        .require_bool_field("ok")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);

    let mut cloned_item = items.clone_required_decoded_string_index(0, gpa).should_ok().sum(
        @loc(),
        t,
    );
    defer cloned_item..&.deinit(gpa);
    cloned_item.&.as_str()
        .should()
        .eq(([2]u8.{ b'x', b'\n' }.&[0 .. 2]))
        .sum(@loc(), t);

    match (value.require_bool_field("missing").should_err().sum(@loc(), t)) {
        .Missing => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (value.require_bool_field("dup").should_err().sum(@loc(), t)) {
        .{ Duplicate: count } => count.should().eq(2).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (value.require_bool_field("msg").should_err().sum(@loc(), t)) {
        .{ UnexpectedKind: kind } => kind.should().eq(Kind.String).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (items.require_index(9).should_err().sum(@loc(), t)) {
        .OutOfRange => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (items.require_u64_index(0).should_err().sum(@loc(), t)) {
        .{ UnexpectedKind: kind } => kind.should().eq(Kind.String).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    let scalar = parse("true").should_ok().sum(@loc(), t);
    match (scalar.require_field("x").should_err().sum(@loc(), t)) {
        .{ UnexpectedKind: kind } => kind.should().eq(Kind.Bool).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (scalar.require_index(0).should_err().sum(@loc(), t)) {
        .{ UnexpectedKind: kind } => kind.should().eq(Kind.Bool).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_empty_cursor_exhaustion() void {
    let t = test.report(io.stderr())..&;
    let empty_array = parse("[]").should_ok().sum(@loc(), t);
    let mut array_cursor = empty_array
        .array_cursor()
        .should_some()
        .sum(@loc(), t);
    array_cursor
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    array_cursor
        .is_done()
        .should()
        .sum(@loc(), t);

    let empty_object = parse("{}").should_ok().sum(@loc(), t);
    let mut object_cursor = empty_object
        .object_cursor()
        .should_some()
        .sum(@loc(), t);
    object_cursor
        ..&.next()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    object_cursor
        .is_done()
        .should()
        .sum(@loc(), t);
}

fn check_packed_document_lookup_helpers() void {
    let t = test.report(io.stderr())..&;
    let doc = parse_packed_document("{\"ok\":true,\"user\":{\"id\":7,\"name\":\"kern\"},\"items\":[{\"sku\":\"abc\",\"qty\":1,\"price\":12.5},{\"sku\":\"xyz\",\"qty\":4,\"price\":5.75}],\"dup\":1,\"dup\":2,\"flt\":1.5}").should_ok().sum(
        @loc(),
        t,
    )..&;
    defer doc.deinit();
    let root = doc.root();

    root
        .is_object()
        .should()
        .sum(@loc(), t);
    root
        .object_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(6)
        .sum(@loc(), t);
    root
        .get_bool("ok")
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    root
        .has_field("user")
        .should()
        .sum(@loc(), t);
    root
        .count_fields("dup")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(2)
        .sum(@loc(), t);
    let mut collected = [2]json.PackedObjectEntry.{ undef, undef };
    let total = root
        .collect_fields("dup", collected..&[0 .. 2])
        .should_some()
        .sum(@loc(), t);
    total
        .should()
        .eq(2)
        .sum(@loc(), t);
    collected.[0].u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    collected.[1].u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );
    let last_dup = root
        .get_last_field("dup")
        .should_some()
        .sum(@loc(), t);
    last_dup.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );
    root
        .require_bool("ok")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    root
        .require_f64("flt")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(1.5)
        .sum(@loc(), t);

    let user = root
        .get_object("user")
        .should_some()
        .sum(@loc(), t);
    user.get_u64("id").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    user.get_u32("id").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    user
        .get_string("name")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("kern"))
        .sum(@loc(), t);
    user
        .require_string("name")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(("kern"))
        .sum(@loc(), t);

    let items = root
        .get_array("items")
        .should_some()
        .sum(@loc(), t);
    items
        .array_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(2)
        .sum(@loc(), t);
    let item0 = items
        .get_index(0)
        .should_some()
        .sum(@loc(), t);
    let item1 = items
        .get_index(1)
        .should_some()
        .sum(@loc(), t);
    item0
        .get_string("sku")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("abc"))
        .sum(@loc(), t);
    item1.get_u64("qty").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(4).sum(
        @loc(),
        t,
    );
    item1.get_i64("qty").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(4).sum(
        @loc(),
        t,
    );
    item1.get_f64("price").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(5.75).sum(
        @loc(),
        t,
    );
    item1.get_f32("price").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(5.75).sum(
        @loc(),
        t,
    );

    match (root.require_bool("dup").should_err().sum(@loc(), t)) {
        .{ Duplicate: count } => count.should().eq(2).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (root.require_u64("user").should_err().sum(@loc(), t)) {
        .{ UnexpectedKind: kind } => kind.should().eq(Kind.Object).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_packed_indexed_object_document_api() void {
    let t = test.report(io.stderr())..&;
    let doc = parse_packed_indexed_object_document("{\"ok\":true,\"user\":{\"id\":7,\"name\":\"kern\"},\"items\":[{\"sku\":\"abc\",\"qty\":1,\"price\":12.5},{\"sku\":\"xyz\",\"qty\":4,\"price\":5.75}],\"dup\":1,\"dup\":2,\"flt\":1.5}").should_ok().sum(
        @loc(),
        t,
    )..&;
    defer doc.deinit();

    let root = doc.root();
    root
        .is_object()
        .should()
        .sum(@loc(), t);
    root
        .object_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(6)
        .sum(@loc(), t);

    let view = doc.view();
    view
        .len()
        .should()
        .eq(6)
        .sum(@loc(), t);
    view
        .is_empty()
        .not()
        .should()
        .sum(@loc(), t);
    view
        .get_bool("ok")
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    view
        .has_field("user")
        .should()
        .sum(@loc(), t);
    view
        .count_fields("dup")
        .should()
        .eq(2)
        .sum(@loc(), t);

    let first = view
        .get_entry(0)
        .should_some()
        .sum(@loc(), t);
    first
        .key_eq("ok")
        .should()
        .sum(@loc(), t);
    let dup = view
        .get_field("dup")
        .should_some()
        .sum(@loc(), t);
    dup.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    let last_dup = view
        .get_last_field("dup")
        .should_some()
        .sum(@loc(), t);
    last_dup.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );

    let mut collected = [1]json.PackedObjectEntry.{ undef };
    let total = view.collect_fields("dup", collected..&[0 .. 1]);
    total
        .should()
        .eq(2)
        .sum(@loc(), t);
    collected.[0].u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );

    view
        .require_bool("ok")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    view
        .require_f64("flt")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(1.5)
        .sum(@loc(), t);
    let user = view
        .require_object("user")
        .should_ok()
        .sum(@loc(), t);
    user.get_u64("id").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    user
        .get_string("name")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("kern"))
        .sum(@loc(), t);

    let items = view
        .require_array("items")
        .should_ok()
        .sum(@loc(), t);
    let item0 = items
        .get_index(0)
        .should_some()
        .sum(@loc(), t);
    let item1 = items
        .get_index(1)
        .should_some()
        .sum(@loc(), t);
    item0
        .get_string("sku")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("abc"))
        .sum(@loc(), t);
    item1.get_u64("qty").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(4).sum(
        @loc(),
        t,
    );
    item1.get_f64("price").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(5.75).sum(
        @loc(),
        t,
    );

    match (view.require_u64("dup").should_err().sum(@loc(), t)) {
        .{ Duplicate: count } => count.should().eq(2).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (view.require_u64("user").should_err().sum(@loc(), t)) {
        .{ UnexpectedKind: kind } => kind.should().eq(Kind.Object).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_packed_indexed_object_document("[1,2,3]").should_err().sum(@loc(), t)) {
        .RootNotObject => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_packed_document_string_decode_errors() void {
    let t = test.report(io.stderr())..&;
    match (parse_packed_document("\"\\uD800\"").should_err().sum(@loc(), t)) {
        .{ String: .{ InvalidUnicodeEscape: offset } } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (parse_packed_document("{\"\\uD800\":1}").should_err().sum(@loc(), t)) {
        .{ String: .{ InvalidUnicodeEscape: offset } } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    match (parse_packed_indexed_object_document("{\"\\uD800\":1}").should_err().sum(@loc(), t)) {
        .{ Materialize: .{ String: .{ InvalidUnicodeEscape: offset } } } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_borrowed_optional_schema_helpers() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"flag\":true,\"count\":12,\"msg\":\"hi\\n\",\"items\":[\"x\\n\",7,{\"ok\":false}],\"nested\":{\"ok\":false},\"dup\":1,\"dup\":2,\"flt\":1.5}").should_ok().sum(
        @loc(),
        t,
    );

    value.get_bool_field("flag").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().sum(
        @loc(),
        t,
    );
    value.get_u64_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_u32_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_u16_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_u8_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_i64_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_i32_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_i16_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_i8_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_usize_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_isize_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    value.get_f64_field("flt").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.5).sum(
        @loc(),
        t,
    );
    value.get_f32_field("flt").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.5).sum(
        @loc(),
        t,
    );
    value.get_number_text_field("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(("12")).sum(
        @loc(),
        t,
    );
    value.get_string_raw_field("msg").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(("\"hi\\n\"")).sum(
        @loc(),
        t,
    );
    value.get_string_text_field("msg").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(("hi\\n")).sum(
        @loc(),
        t,
    );
    value.get_decoded_string_size_field("msg").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(3).sum(
        @loc(),
        t,
    );

    let mut out = [8]u8.{undef};
    let written = value.write_decoded_string_field("msg", out..&[0 .. 8]).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    written
        .should()
        .eq(3)
        .sum(@loc(), t);
    out.&[0 .. written]
        .should()
        .eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3]))
        .sum(@loc(), t);

    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let mut cloned = value.clone_decoded_string_field("msg", gpa).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    defer cloned..&.deinit(gpa);
    cloned.&.as_str()
        .should()
        .eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3]))
        .sum(@loc(), t);

    let items = value.get_array_field("items").should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    items
        .is_array()
        .should()
        .sum(@loc(), t);
    items.get_string_raw_index(0).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(("\"x\\n\"")).sum(
        @loc(),
        t,
    );
    items.get_string_text_index(0).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(("x\\n")).sum(
        @loc(),
        t,
    );
    items.get_decoded_string_size_index(0).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );
    let written_item = items.write_decoded_string_index(0, out..&[0 .. 8]).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    written_item
        .should()
        .eq(2)
        .sum(@loc(), t);
    out.&[0 .. written_item]
        .should()
        .eq(([2]u8.{ b'x', b'\n' }.&[0 .. 2]))
        .sum(@loc(), t);

    let mut cloned_item = items.clone_decoded_string_index(0, gpa).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    defer cloned_item..&.deinit(gpa);
    cloned_item.&.as_str()
        .should()
        .eq(([2]u8.{ b'x', b'\n' }.&[0 .. 2]))
        .sum(@loc(), t);

    items.get_u64_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_u32_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_u16_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_u8_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_i64_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_i32_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_i16_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_i8_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_usize_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    items.get_isize_index(1).should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    let nested_item = items.get_object_index(2).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    nested_item.get_bool_field("ok").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).not().should().sum(
        @loc(),
        t,
    );

    let nested = value.get_object_field("nested").should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    nested.get_bool_field("ok").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).not().should().sum(
        @loc(),
        t,
    );
    value.get_u64_field("dup").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );

    value
        .get_bool_field("msg")
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    value.get_string_text_field("missing").should_ok().sum(@loc(), t).is_none().should().sum(
        @loc(),
        t,
    );
    items
        .get_bool_index(9)
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    items
        .get_u64_index(0)
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    let scalar = parse("true").should_ok().sum(@loc(), t);
    scalar
        .get_bool_field("x")
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    scalar
        .get_u64_index(0)
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
}

fn check_container_helpers() void {
    let t = test.report(io.stderr())..&;
    let array = parse("[1]").should_ok().sum(@loc(), t);
    let object = parse("{\"ok\":true}").should_ok().sum(@loc(), t);
    let scalar = parse("\"hi\"").should_ok().sum(@loc(), t);

    array
        .is_container()
        .should()
        .sum(@loc(), t);
    object
        .is_container()
        .should()
        .sum(@loc(), t);
    scalar
        .is_container()
        .not()
        .should()
        .sum(@loc(), t);
}

fn check_kind_helpers_and_scalar_accessors() void {
    let t = test.report(io.stderr())..&;
    let null_value = parse("null").should_ok().sum(@loc(), t);
    let true_value = parse("true").should_ok().sum(@loc(), t);
    let false_value = parse("false").should_ok().sum(@loc(), t);
    let number_value = parse("-12.5e+2").should_ok().sum(@loc(), t);
    let string_value = parse("\"hi\\n\"").should_ok().sum(@loc(), t);
    let array_value = parse("[1]").should_ok().sum(@loc(), t);
    let object_value = parse("{\"ok\":true}").should_ok().sum(@loc(), t);

    null_value
        .is_null()
        .should()
        .sum(@loc(), t);
    true_value
        .is_bool()
        .should()
        .sum(@loc(), t);
    number_value
        .is_number()
        .should()
        .sum(@loc(), t);
    string_value
        .is_string()
        .should()
        .sum(@loc(), t);
    array_value
        .is_array()
        .should()
        .sum(@loc(), t);
    object_value
        .is_object()
        .should()
        .sum(@loc(), t);

    true_value
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    false_value
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);
    number_value
        .bool_value()
        .is_none()
        .should()
        .sum(@loc(), t);

    number_value.number_text().should_some().sum(@loc(), t).should().eq(("-12.5e+2")).sum(
        @loc(),
        t,
    );
    string_value.string_raw().should_some().sum(@loc(), t).should().eq(("\"hi\\n\"")).sum(
        @loc(),
        t,
    );
    string_value
        .string_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("hi\\n"))
        .sum(@loc(), t);
    null_value
        .string_text()
        .is_none()
        .should()
        .sum(@loc(), t);
}

fn check_container_count_and_presence_helpers() void {
    let t = test.report(io.stderr())..&;
    let array = parse("[10, 20, 30]").should_ok().sum(@loc(), t);
    let object = parse("{\"ok\":true,\"msg\":\"hi\"}").should_ok().sum(@loc(), t);
    let scalar = parse("true").should_ok().sum(@loc(), t);

    array.array_len().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(3).sum(
        @loc(),
        t,
    );
    object.object_len().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );
    object
        .has_field("msg")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    object
        .has_field("missing")
        .should_ok()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);
    array
        .has_field("msg")
        .should_ok()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);
    scalar
        .array_len()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    scalar
        .object_len()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
}

fn check_typed_integer_accessors() void {
    let t = test.report(io.stderr())..&;
    let unsigned = parse("18446744073709551615").should_ok().sum(@loc(), t);
    let signed = parse("-9223372036854775808").should_ok().sum(@loc(), t);
    let small = parse("42").should_ok().sum(@loc(), t);
    let byte = parse("255").should_ok().sum(@loc(), t);
    let neg_byte = parse("-128").should_ok().sum(@loc(), t);
    let scalar = parse("true").should_ok().sum(@loc(), t);

    unsigned.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(18446744073709551615).sum(
        @loc(),
        t,
    );
    signed.i64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(-9223372036854775808).sum(
        @loc(),
        t,
    );
    small.u32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42).sum(
        @loc(),
        t,
    );
    small.i32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42).sum(
        @loc(),
        t,
    );
    small.u16_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42).sum(
        @loc(),
        t,
    );
    small.i16_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42).sum(
        @loc(),
        t,
    );
    byte.u8_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(255).sum(
        @loc(),
        t,
    );
    neg_byte.i8_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(-128).sum(
        @loc(),
        t,
    );
    small.usize_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42).sum(
        @loc(),
        t,
    );
    small.isize_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42).sum(
        @loc(),
        t,
    );

    scalar
        .u64_value()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    scalar
        .i64_value()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
}

fn check_typed_integer_errors() void {
    let t = test.report(io.stderr())..&;
    let negative = parse("-1").should_ok().sum(@loc(), t);
    let decimal = parse("12.5").should_ok().sum(@loc(), t);
    let exponent = parse("1e9").should_ok().sum(@loc(), t);
    let huge_unsigned = parse("18446744073709551616").should_ok().sum(@loc(), t);
    let huge_signed = parse("9223372036854775808").should_ok().sum(@loc(), t);
    let u32_wide = parse("4294967296").should_ok().sum(@loc(), t);
    let i8_wide = parse("128").should_ok().sum(@loc(), t);

    match (negative.u64_value().should_err().sum(@loc(), t)) {
        .NegativeUnsigned => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (decimal.u64_value().should_err().sum(@loc(), t)) {
        .NotInteger => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (exponent.i64_value().should_err().sum(@loc(), t)) {
        .NotInteger => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (huge_unsigned.u64_value().should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (huge_signed.i64_value().should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (u32_wide.u32_value().should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (i8_wide.i8_value().should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    let invalid = json.Value.{ kind: Kind.Number, raw: "01" };
    match (invalid.u64_value().should_err().sum(@loc(), t)) {
        .{ Parse: err } => match (err) {
            .{ InvalidNumber: offset } => offset.should().eq(1).sum(@loc(), t),
            _ => t.fail_at(@loc(), "unexpected match arm"),
        },
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_typed_float_accessors() void {
    let t = test.report(io.stderr())..&;
    let integer = parse("42").should_ok().sum(@loc(), t);
    let fraction = parse("1.5").should_ok().sum(@loc(), t);
    let exact_exp = parse("125e-3").should_ok().sum(@loc(), t);
    let negative = parse("-12.5e+2").should_ok().sum(@loc(), t);
    let scalar = parse("false").should_ok().sum(@loc(), t);

    integer.f64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42.0).sum(
        @loc(),
        t,
    );
    fraction.f64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.5).sum(
        @loc(),
        t,
    );
    exact_exp.f64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(0.125).sum(
        @loc(),
        t,
    );
    negative.f64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(-1250.0).sum(
        @loc(),
        t,
    );
    integer.f32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(42.0 as f32).sum(
        @loc(),
        t,
    );
    fraction.f32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.5 as f32).sum(
        @loc(),
        t,
    );
    exact_exp.f32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(0.125 as f32).sum(
        @loc(),
        t,
    );
    negative.f32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(-1250.0 as f32).sum(
        @loc(),
        t,
    );
    scalar
        .f64_value()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
    scalar
        .f32_value()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);
}

fn check_typed_float_errors() void {
    let t = test.report(io.stderr())..&;
    let huge = parse("1e400").should_ok().sum(@loc(), t);
    let wide = parse("1e39").should_ok().sum(@loc(), t);

    match (huge.f64_value()) {
        .{ Err: .Overflow } => {},
        .{ Err: _ } => t.fail_at(@loc(), "unexpected match arm"),
        .{ Ok: _ } => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (wide.f32_value()) {
        .{ Err: .Overflow } => {},
        .{ Err: _ } => t.fail_at(@loc(), "unexpected match arm"),
        .{ Ok: _ } => t.fail_at(@loc(), "unexpected match arm"),
    }

    let invalid = json.Value.{ kind: Kind.Number, raw: "01" };
    match (invalid.f64_value().should_err().sum(@loc(), t)) {
        .{ Parse: .{ InvalidNumber: offset } } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (invalid.f32_value().should_err().sum(@loc(), t)) {
        .{ Parse: .{ InvalidNumber: offset } } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_raw_integer_parse_helpers() void {
    let t = test.report(io.stderr())..&;
    parse_u32_raw("42")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(42)
        .sum(@loc(), t);
    parse_i32_raw("-17")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(-17)
        .sum(@loc(), t);
    parse_u16_raw("99")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(99)
        .sum(@loc(), t);
    parse_i16_raw("-99")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(-99)
        .sum(@loc(), t);
    parse_u8_raw("255")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(255)
        .sum(@loc(), t);
    parse_i8_raw("-128")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(-128)
        .sum(@loc(), t);
    parse_u64_raw("0")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(0)
        .sum(@loc(), t);
    parse_i64_raw("-17")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(-17)
        .sum(@loc(), t);
    parse_usize_raw("99")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(99)
        .sum(@loc(), t);
    parse_isize_raw("-99")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(-99)
        .sum(@loc(), t);

    match (parse_u64_raw("-7").should_err().sum(@loc(), t)) {
        .NegativeUnsigned => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_i64_raw("1.0").should_err().sum(@loc(), t)) {
        .NotInteger => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_u64_raw("18446744073709551616").should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_u32_raw("4294967296").should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_i8_raw("128").should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_u64_raw("01").should_err().sum(@loc(), t)) {
        .{ Parse: err } => match (err) {
            .{ InvalidNumber: offset } => offset.should().eq(1).sum(@loc(), t),
            _ => t.fail_at(@loc(), "unexpected match arm"),
        },
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_raw_float_parse_helpers() void {
    let t = test.report(io.stderr())..&;
    parse_f32_raw("0")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(0.0 as f32)
        .sum(@loc(), t);
    parse_f32_raw("1.5")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(1.5 as f32)
        .sum(@loc(), t);
    parse_f32_raw("125e-3")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(0.125 as f32)
        .sum(@loc(), t);
    parse_f32_raw("-12.5e+2")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(-1250.0 as f32)
        .sum(@loc(), t);
    parse_f32_raw("1e-50")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(0.0 as f32)
        .sum(@loc(), t);
    parse_f64_raw("0")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(0.0)
        .sum(@loc(), t);
    parse_f64_raw("1.5")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(1.5)
        .sum(@loc(), t);
    parse_f64_raw("125e-3")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(0.125)
        .sum(@loc(), t);
    parse_f64_raw("-12.5e+2")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(-1250.0)
        .sum(@loc(), t);
    parse_f64_raw("100000000000000000000").should_ok().sum(@loc(), t).should().eq(1e20).sum(
        @loc(),
        t,
    );
    parse_f64_raw("1e-400")
        .should_ok()
        .sum(@loc(), t)
        .should()
        .eq(0.0)
        .sum(@loc(), t);

    match (parse_f64_raw("1e400").should_err().sum(@loc(), t)) {
        .Overflow => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_f32_raw("1e39")) {
        .{ Err: .Overflow } => {},
        .{ Err: _ } => t.fail_at(@loc(), "unexpected match arm"),
        .{ Ok: _ } => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_f64_raw("01").should_err().sum(@loc(), t)) {
        .{ Parse: .{ InvalidNumber: offset } } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (parse_f32_raw("01").should_err().sum(@loc(), t)) {
        .{ Parse: .{ InvalidNumber: offset } } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_decoded_string_helpers() void {
    let t = test.report(io.stderr())..&;
    let escaped = parse("\"hi\\n\\u4F60\\u597D\\uD83D\\uDE03\"").should_ok().sum(@loc(), t);
    let decoded_size = escaped.decoded_string_size().should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    decoded_size
        .should()
        .eq(13)
        .sum(@loc(), t);

    let mut out = [32]u8.{undef};
    let written = escaped.write_decoded_string(out..&[0 .. 32]).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    written
        .should()
        .eq(decoded_size)
        .sum(@loc(), t);
    (out.&[0 .. written] == ([
            13
        ]u8.{
            b'h',
            b'i',
            b'\n',
            u8.{0xE4},
            u8.{0xBD},
            u8.{0xA0},
            u8.{0xE5},
            u8.{0xA5},
            u8.{0xBD},
            u8.{0xF0},
            u8.{0x9F},
            u8.{0x98},
            u8.{0x83},
        }.&[0 .. 13])).should().sum(@loc(), t);

    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let mut owned = escaped.clone_decoded_string(gpa).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    defer owned..&.deinit(gpa);
    owned.&.as_str()
        .should()
        .eq((out.&[0 .. written]))
        .sum(@loc(), t);
}

fn check_decoded_string_errors() void {
    let t = test.report(io.stderr())..&;
    let escaped = parse("\"\\u0041\"").should_ok().sum(@loc(), t);
    let mut small = [1]u8.{undef};
    match (escaped.write_decoded_string(small..&[0 .. 0]).should_err().sum(@loc(), t)) {
        .BufferTooSmall => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }

    let scalar = parse("true").should_ok().sum(@loc(), t);
    let mut out = [4]u8.{undef};
    scalar.write_decoded_string(out..&[0 .. 4]).should_ok().sum(@loc(), t).is_none().should().sum(
        @loc(),
        t,
    );
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    scalar
        .clone_decoded_string(gpa)
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    let invalid = json.Value.{ kind: Kind.String, raw: "\"\\uD800\"" };
    match (invalid.decoded_string_size().should_err().sum(@loc(), t)) {
        .{ InvalidUnicodeEscape: offset } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
    match (invalid.write_decoded_string([16]u8.{undef}..&[0 .. 16]).should_err().sum(@loc(), t)) {
        .{ InvalidUnicodeEscape: offset } => offset.should().eq(1).sum(@loc(), t),
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_decoded_object_key_helpers() void {
    let t = test.report(io.stderr())..&;
    let object = parse("{\"a\\u0042\\uD83D\\uDE03\":1}").should_ok().sum(@loc(), t);
    let entry = object.get_field("a\\u0042\\uD83D\\uDE03").should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    let decoded_size = entry
        .decoded_key_size()
        .should_ok()
        .sum(@loc(), t);
    decoded_size
        .should()
        .eq(6)
        .sum(@loc(), t);

    let mut out = [16]u8.{undef};
    let written = entry
        .write_decoded_key(out..&[0 .. 16])
        .should_ok()
        .sum(@loc(), t);
    written
        .should()
        .eq(decoded_size)
        .sum(@loc(), t);
    out.&[0 .. written].should().eq(([6]u8.{ b'a', b'B', u8.{0xF0}, u8.{0x9F}, u8.{0x98}, u8.{0x83} }.&[0 .. 6])).sum(
        @loc(),
        t,
    );

    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let mut owned = entry
        .clone_decoded_key(gpa)
        .should_ok()
        .sum(@loc(), t);
    defer owned..&.deinit(gpa);
    owned.&.as_str()
        .should()
        .eq((out.&[0 .. written]))
        .sum(@loc(), t);

    entry
        .number_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("1"))
        .sum(@loc(), t);
    entry.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
}

fn check_borrowed_object_entry_value_helpers() void {
    let t = test.report(io.stderr())..&;
    let object = parse("{\"flag\":true,\"count\":12,\"msg\":\"hi\\n\",\"flt\":1.5}").should_ok().sum(
        @loc(),
        t,
    );

    let flag = object
        .get_field("flag")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    flag
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);

    let count = object
        .get_field("count")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    count
        .number_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("12"))
        .sum(@loc(), t);
    count.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    count.i32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    count.usize_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );

    let msg = object
        .get_field("msg")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    msg
        .string_raw()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("\"hi\\n\""))
        .sum(@loc(), t);
    msg
        .string_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("hi\\n"))
        .sum(@loc(), t);
    msg.decoded_string_size().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(3).sum(
        @loc(),
        t,
    );
    let mut out = [8]u8.{undef};
    let written = msg.write_decoded_string(out..&[0 .. 8]).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    written
        .should()
        .eq(3)
        .sum(@loc(), t);
    out.&[0 .. written]
        .should()
        .eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3]))
        .sum(@loc(), t);

    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let mut cloned = msg.clone_decoded_string(gpa).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    );
    defer cloned..&.deinit(gpa);
    cloned.&.as_str()
        .should()
        .eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3]))
        .sum(@loc(), t);

    let flt = object
        .get_field("flt")
        .should_ok()
        .sum(@loc(), t)
        .should_some()
        .sum(@loc(), t);
    flt.f64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.5).sum(
        @loc(),
        t,
    );
    flt.f32_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.5).sum(
        @loc(),
        t,
    );
    match (flt.u64_value().should_err().sum(@loc(), t)) {
        .NotInteger => {},
        _ => t.fail_at(@loc(), "unexpected match arm"),
    }
}

fn check_owned_materialization() void {
    let t = test.report(io.stderr())..&;
    let value = parse(
            "{\"msg\":\"hi\\n\",\"items\":[true,12],\"nested\":{\"ok\":false},\"count\":12,\"pi\":1.25,\"flag\":false}"
        ).should_ok().sum(@loc(), t);
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let mut owned = value
        .clone_owned(gpa)
        .should_ok()
        .sum(@loc(), t);
    defer owned..&.deinit(gpa);

    owned
        ..&.is_object()
        .should()
        .sum(@loc(), t);
    owned
        ..&.object_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(6)
        .sum(@loc(), t);
    owned
        ..&.has_field("msg")
        .should()
        .sum(@loc(), t);
    owned
        ..&.has_field("missing")
        .not()
        .should()
        .sum(@loc(), t);
    owned..&.get_string("msg").should_some().sum(@loc(), t).should().eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3])).sum(
        @loc(),
        t,
    );
    owned
        ..&.get_array("items")
        .should_some()
        .sum(@loc(), t)
        .is_array()
        .should()
        .sum(@loc(), t);
    owned
        ..&.get_object("nested")
        .should_some()
        .sum(@loc(), t)
        .is_object()
        .should()
        .sum(@loc(), t);
    owned
        ..&.get_array("msg")
        .is_none()
        .should()
        .sum(@loc(), t);
    owned
        ..&.get_bool("flag")
        .should_some()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);

    let msg = owned
        ..&.get_field("msg")
        .should_some()
        .sum(@loc(), t);
    msg
        .key_eq("msg")
        .should()
        .sum(@loc(), t);
    msg.string_text().should_some().sum(@loc(), t).should().eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3])).sum(
        @loc(),
        t,
    );
    msg
        .u64_value()
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    let items = owned
        ..&.get_field("items")
        .should_some()
        .sum(@loc(), t);
    items
        .key_eq("items")
        .should()
        .sum(@loc(), t);
    items.value
        .array_len()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(2)
        .sum(@loc(), t);
    items.value.get_index(0).should_some().sum(@loc(), t).bool_value().should_some().sum(@loc(), t).should().sum(
        @loc(),
        t,
    );
    let item1 = items.value
        .get_index(1)
        .should_some()
        .sum(@loc(), t);
    item1
        .number_text()
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("12"))
        .sum(@loc(), t);
    item1.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    item1.f64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12.0).sum(
        @loc(),
        t,
    );

    let nested = owned
        ..&.get_field("nested")
        .should_some()
        .sum(@loc(), t);
    nested
        .key_eq("nested")
        .should()
        .sum(@loc(), t);
    let ok = nested.value
        .get_field("ok")
        .should_some()
        .sum(@loc(), t);
    ok
        .key_eq("ok")
        .should()
        .sum(@loc(), t);
    ok.value
        .bool_value()
        .should_some()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);

    let object = match (owned) {
        .{ Object: object } => object,
        _ => t.fail_at(@loc(), "unexpected match arm"),
    };
    object.&.get_bool("flag")
        .should_some()
        .sum(@loc(), t)
        .not()
        .should()
        .sum(@loc(), t);
    object.&.get_bool("missing")
        .is_none()
        .should()
        .sum(@loc(), t);
    object.&.get_string("items")
        .is_none()
        .should()
        .sum(@loc(), t);
    object.&.get_number_text("count").should_some().sum(@loc(), t).should().eq(("12")).sum(
        @loc(),
        t,
    );
    object.&.get_u64("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    object.&.get_i32("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12).sum(
        @loc(),
        t,
    );
    object.&.get_f64("count").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12.0).sum(
        @loc(),
        t,
    );
    object.&.get_f32("pi").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.25 as f32).sum(
        @loc(),
        t,
    );
    object.&.get_u64("msg")
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    let dup_value = parse("{\"dup\":1,\"dup\":2,\"dup\":3}").should_ok().sum(@loc(), t);
    let mut dup_owned = dup_value
        .clone_owned(gpa)
        .should_ok()
        .sum(@loc(), t);
    defer dup_owned..&.deinit(gpa);
    dup_owned
        ..&.count_fields("dup")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(3)
        .sum(@loc(), t);
    let last_dup = dup_owned
        ..&.get_last_field("dup")
        .should_some()
        .sum(@loc(), t);
    last_dup.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(3).sum(
        @loc(),
        t,
    );
    let mut collected = [2]json.OwnedObjectEntry.{ undef, undef };
    let total = dup_owned..&.collect_fields("dup", collected..&[0 .. 2]).should_some().sum(
        @loc(),
        t,
    );
    total
        .should()
        .eq(3)
        .sum(@loc(), t);
    collected.[0].u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    collected.[1].u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );
}

fn check_owned_materialization_with_arena_reset() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"msg\":\"hi\\n\",\"items\":[true,12],\"nested\":{\"ok\":false},\"flag\":false}").should_ok().sum(
        @loc(),
        t,
    );
    let page = Page.{}..&;
    let mut arena = arena().on(page);
    defer arena..&.deinit();

    let mut round = 0;
    while (round < 2) {
        let mut owned = value
            .clone_owned(arena..&)
            .should_ok()
            .sum(@loc(), t);
        owned
            ..&.is_object()
            .should()
            .sum(@loc(), t);
        owned
            ..&.object_len()
            .should_some()
            .sum(@loc(), t)
            .should()
            .eq(4)
            .sum(@loc(), t);
        owned
            ..&.get_bool("flag")
            .should_some()
            .sum(@loc(), t)
            .not()
            .should()
            .sum(@loc(), t);
        owned..&.get_string("msg").should_some().sum(@loc(), t).should().eq(([3]u8.{ b'h', b'i', b'\n' }.&[0 .. 3])).sum(
            @loc(),
            t,
        );
        owned
            ..&.get_array("items")
            .should_some()
            .sum(@loc(), t)
            .is_array()
            .should()
            .sum(@loc(), t);
        arena..&.reset();
        round += 1;
    }
}

fn check_indexed_object_view() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"a\":1,\"dup\":1,\"dup\":2,\"msg\":\"hi\",\"flag\":true}").should_ok().sum(
        @loc(),
        t,
    );
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let owned = value.clone_owned(gpa).should_ok().sum(@loc(), t)..&;
    defer owned.deinit(gpa);

    let view = owned.build_indexed_object_view(gpa).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    )..&;
    defer view.deinit(gpa);

    view
        .len()
        .should()
        .eq(5)
        .sum(@loc(), t);
    view
        .is_empty()
        .not()
        .should()
        .sum(@loc(), t);
    view
        .has_field("msg")
        .should()
        .sum(@loc(), t);
    view
        .has_field("missing")
        .not()
        .should()
        .sum(@loc(), t);
    view
        .get_bool("flag")
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    view
        .get_string("msg")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("hi"))
        .sum(@loc(), t);
    view
        .get_array("msg")
        .is_none()
        .should()
        .sum(@loc(), t);
    view
        .get_number_text("a")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("1"))
        .sum(@loc(), t);
    view.get_u64("a").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    view.get_i32("dup").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    view.get_f64("a").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1.0).sum(
        @loc(),
        t,
    );
    view
        .get_u64("msg")
        .should_ok()
        .sum(@loc(), t)
        .is_none()
        .should()
        .sum(@loc(), t);

    let dup = view
        .get_field("dup")
        .should_some()
        .sum(@loc(), t);
    dup.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    let second = view
        .get_entry(1)
        .should_some()
        .sum(@loc(), t);
    second.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    view
        .count_fields("dup")
        .should()
        .eq(2)
        .sum(@loc(), t);
    let last_dup = view
        .get_last_field("dup")
        .should_some()
        .sum(@loc(), t);
    last_dup.u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(2).sum(
        @loc(),
        t,
    );
    let mut collected = [1]json.OwnedObjectEntry.{ undef };
    let total = view.collect_fields("dup", collected..&[0 .. 1]);
    total
        .should()
        .eq(2)
        .sum(@loc(), t);
    collected.[0].u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );

    let scalar = parse("true").should_ok().sum(@loc(), t);
    let scalar_owned = scalar.clone_owned(gpa).should_ok().sum(@loc(), t)..&;
    defer scalar_owned.deinit(gpa);
    scalar_owned.build_indexed_object_view(gpa).should_ok().sum(@loc(), t).is_none().should().sum(
        @loc(),
        t,
    );

    let nested_value = parse("{\"items\":[1],\"nested\":{\"ok\":false}}").should_ok().sum(
        @loc(),
        t,
    );
    let nested_owned = nested_value.clone_owned(gpa).should_ok().sum(@loc(), t)..&;
    defer nested_owned.deinit(gpa);
    nested_owned
        .get_array("items")
        .should_some()
        .sum(@loc(), t)
        .is_array()
        .should()
        .sum(@loc(), t);
    let nested_view = nested_owned.build_indexed_object_view(gpa).should_ok().sum(@loc(), t).should_some().sum(
        @loc(),
        t,
    )..&;
    defer nested_view.deinit(gpa);
    nested_view.get_object("nested").should_some().sum(@loc(), t).is_object().should().sum(
        @loc(),
        t,
    );
}

fn check_indexed_object_view_with_arena_reset() void {
    let t = test.report(io.stderr())..&;
    let value = parse("{\"a\":1,\"dup\":1,\"dup\":2,\"msg\":\"hi\",\"flag\":true}").should_ok().sum(
        @loc(),
        t,
    );
    let page = Page.{}..&;
    let arena = arena().on(page)..&;
    defer arena.deinit();

    let mut round = 0;
    while (round < 2) {
        let owned = value.clone_owned(arena).should_ok().sum(@loc(), t)..&;
        let view = owned.build_indexed_object_view(arena).should_ok().sum(@loc(), t).should_some().sum(
            @loc(),
            t,
        );
        view.&.len()
            .should()
            .eq(5)
            .sum(@loc(), t);
        view.&.get_bool("flag")
            .should_some()
            .sum(@loc(), t)
            .should()
            .sum(@loc(), t);
        view.&.get_string("msg")
            .should_some()
            .sum(@loc(), t)
            .should()
            .eq(("hi"))
            .sum(@loc(), t);
        view.&.count_fields("dup")
            .should()
            .eq(2)
            .sum(@loc(), t);
        view.&.get_field("a").should_some().sum(@loc(), t).u64_value().should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
            @loc(),
            t,
        );
        arena.reset();
        round += 1;
    }
}

fn check_owned_document_api() void {
    let t = test.report(io.stderr())..&;
    let mut doc = parse_owned_document("{\"msg\":\"hi\\n\",\"items\":[1],\"flag\":true}").should_ok().sum(
        @loc(),
        t,
    );
