fn check_indexed_object_document_nested_lookup() void {
    let t = test.report(io.stderr())..&;
    let mut doc = parse_indexed_object_document("{\"ok\":true,\"user\":{\"id\":7,\"name\":\"kern\"},\"items\":[{\"sku\":\"abc\",\"qty\":1,\"price\":12.5},{\"sku\":\"xyz\",\"qty\":4,\"price\":5.75}]}").should_ok().sum(
        @loc(),
        t,
    );
    defer doc..&.deinit();

    let view = doc.&.view();
    view
        .get_bool("ok")
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);
    let user = view
        .get_object("user")
        .should_some()
        .sum(@loc(), t);
    user.get_u64("id").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(7).sum(
        @loc(),
        t,
    );
    user
        .get_string("name")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("kern"))
        .sum(@loc(), t);

    let items = view
        .get_array("items")
        .should_some()
        .sum(@loc(), t);
    let item0 = items
        .get_index(0)
        .should_some()
        .sum(@loc(), t);
    let item1 = items
        .get_index(1)
        .should_some()
        .sum(@loc(), t);
    item0
        .get_string("sku")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("abc"))
        .sum(@loc(), t);
    item0.get_u64("qty").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(1).sum(
        @loc(),
        t,
    );
    item0.get_f64("price").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(12.5).sum(
        @loc(),
        t,
    );
    item1
        .get_string("sku")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("xyz"))
        .sum(@loc(), t);
    item1.get_u64("qty").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(4).sum(
        @loc(),
        t,
    );
    item1.get_f64("price").should_ok().sum(@loc(), t).should_some().sum(@loc(), t).should().eq(5.75).sum(
        @loc(),
        t,
    );
}

fn check_arena_mark_rewind_with_json_materialization() void {
    let t = test.report(io.stderr())..&;
    let page = Page.{}..&;
    let arena = arena().on(page)..&;
    defer arena.deinit();

    let baseline = arena.mark();
    let value1 = parse("{\"flag\":true}").should_ok().sum(@loc(), t);
    let owned1 = value1.clone_owned(arena).should_ok().sum(@loc(), t)..&;
    owned1
        .get_bool("flag")
        .should_some()
        .sum(@loc(), t)
        .should()
        .sum(@loc(), t);

    let scratch = arena.mark();
    let value2 = parse("{\"msg\":\"hi\",\"items\":[1]}").should_ok().sum(@loc(), t);
    let owned2 = value2.clone_owned(arena).should_ok().sum(@loc(), t)..&;
    owned2
        .get_string("msg")
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(("hi"))
        .sum(@loc(), t);
    arena
        .rewind(scratch)
        .should()
        .sum(@loc(), t);
    arena
        .rewind(scratch)
        .not()
        .should()
        .sum(@loc(), t);

    let fresh = arena.mark();
    let owned3 = value2.clone_owned(arena).should_ok().sum(@loc(), t)..&;
    owned3
        .get_array("items")
        .should_some()
        .sum(@loc(), t)
        .is_array()
        .should()
        .sum(@loc(), t);
    arena
        .rewind(fresh)
        .should()
        .sum(@loc(), t);
    arena
        .rewind(baseline)
        .not()
        .should()
        .sum(@loc(), t);
}

