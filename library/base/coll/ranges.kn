//! Integer range iterator adapters.
//!
//! Ascending ranges use Kern's builtin range value types directly: `T...T`
//! and `T..=T`. Reverse traversal is a range adapter: `(a...b).rev()` and
//! `(a..=b).rev()` keep the range value as the single spelling for bounds.

use base.coll.{
    EnumerateItem,
    Iterator,
};
use ..iter.{
    consume_all,
    consume_any,
    consume_count,
    consume_find,
    consume_find_map,
    consume_fold,
    consume_for_each,
    consume_last,
    consume_nth,
    consume_position,
};

/// Reverse iterator state for a left-closed, right-open range.
pub struct RangeRev[T] {
    start: T,
    end: T,
};

pub struct RangeRevSkip[T] {
    inner: RangeRev[T],
    remaining: usize,
};

pub struct RangeRevEnumerate[T] {
    inner: RangeRev[T],
    index: usize = 0,
};

pub struct RangeRevSkipEnumerate[T] {
    inner: RangeRevSkip[T],
    index: usize = 0,
};

/// Reverse iterator state for a closed range.
pub struct RangeRevInclusive[T] {
    start: T,
    end: T,
    done: bool = false,
};

pub struct RangeRevInclusiveSkip[T] {
    inner: RangeRevInclusive[T],
    remaining: usize,
};

pub struct RangeRevInclusiveEnumerate[T] {
    inner: RangeRevInclusive[T],
    index: usize = 0,
};

pub struct RangeRevInclusiveSkipEnumerate[T] {
    inner: RangeRevInclusiveSkip[T],
    index: usize = 0,
};

pub struct RangeSkip[T] {
    inner: T...T,
    remaining: usize,
};

pub struct RangeEnumerate[T] {
    inner: T...T,
    index: usize = 0,
};

pub struct RangeSkipEnumerate[T] {
    inner: RangeSkip[T],
    index: usize = 0,
};

pub struct RangeInclusiveSkip[T] {
    inner: T..=T,
    remaining: usize,
};

pub struct RangeInclusiveEnumerate[T] {
    inner: T..=T,
    index: usize = 0,
};

pub struct RangeInclusiveSkipEnumerate[T] {
    inner: RangeInclusiveSkip[T],
    index: usize = 0,
};

impl[T] T...T
    where T: Integer,
{
    /// Returns an iterator that visits this half-open range from high to low.
    pub fn rev() RangeRev[T] {
        return .{ start: self.@start(), end: self.@end() };
    }
}

impl[T] T..=T
    where T: Integer,
{
    /// Returns an iterator that visits this inclusive range from high to low.
    pub fn rev() RangeRevInclusive[T] {
        return .{ start: self.@start(), end: self.@end() };
    }
}

impl[T] &mut (T...T) : Iterator
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    type Item = T;

    pub fn next() ?Item {
        if !(self.start < self.end) return .None;

        let item = self.start;
        self.start += 1;
        return .{ Some: item };
    }
}

impl[T] &mut (T...T)
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    pub fn count() usize {
        return consume_count[T]((self as &mut Iterator[Item = T]));
    }

    pub fn nth(n: usize) ?T {
        return consume_nth[T]((self as &mut Iterator[Item = T]), n);
    }

    pub fn last() ?T {
        return consume_last[T]((self as &mut Iterator[Item = T]));
    }

    pub fn for_each(visitor: &Fn(T) void) void {
        consume_for_each[T]((self as &mut Iterator[Item = T]), visitor);
    }

    pub fn fold[U](init: U, step: &Fn(U, T) U) U {
        return consume_fold[T, U]((self as &mut Iterator[Item = T]), init, step);
    }

    pub fn any(pred: &Fn(T) bool) bool {
        return consume_any[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn all(pred: &Fn(T) bool) bool {
        return consume_all[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn find(pred: &Fn(T) bool) ?T {
        return consume_find[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn position(pred: &Fn(T) bool) ?usize {
        return consume_position[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn find_map[U](call_back: &Fn(T) ?U) ?U {
        return consume_find_map[T, U]((self as &mut Iterator[Item = T]), call_back);
    }

    pub fn skip(count: usize) RangeSkip[T] {
        return .{ inner: self.*, remaining: count };
    }

    pub fn enumerate() RangeEnumerate[T] {
        return .{ inner: self.* };
    }
}

impl[T] T...T
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    pub fn skip(count: usize) RangeSkip[T] {
        return .{ inner: self, remaining: count };
    }

    pub fn enumerate() RangeEnumerate[T] {
        return .{ inner: self };
    }
}

impl[T] &mut RangeSkip[T] : Iterator
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    type Item = T;

    pub fn next() ?Item {
        while self.remaining != 0 {
            match self.inner..&.next() {
                .{ Some: _ } => self.remaining -= 1,
                .None => {
                    self.remaining = 0;
                    return .None;
                },
            }
        }
        return self.inner..&.next();
    }
}

impl[T] &mut RangeSkip[T]
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    pub fn skip(count: usize) RangeSkip[T] {
        self.remaining += count;
        return self.*;
    }

    pub fn enumerate() RangeSkipEnumerate[T] {
        return .{ inner: self.* };
    }
}

impl[T] RangeSkip[T]
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    pub fn enumerate() RangeSkipEnumerate[T] {
        return .{ inner: self };
    }
}

impl[T] &mut RangeEnumerate[T] : Iterator
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    type Item = EnumerateItem[T];

    pub fn next() ?Item {
        let value = match self.inner..&.next() {
            .{ Some: value } => value,
            .None => return .None,
        };
        let index = self.index;
        self.index += 1;
        return .{ Some: .{ index: index, value: value } };
    }
}

impl[T] &mut RangeSkipEnumerate[T] : Iterator
    where T: Integer + Lt[T] + Add[T, Out = T],
{
    type Item = EnumerateItem[T];

    pub fn next() ?Item {
        let value = match self.inner..&.next() {
            .{ Some: value } => value,
            .None => return .None,
        };
        let index = self.index;
        self.index += 1;
        return .{ Some: .{ index: index, value: value } };
    }
}

impl[T] &mut (T..=T) : Iterator
    where T: Integer + Eq[T] + Le[T] + Add[T, Out = T] + Sub[T, Out = T],
{
    type Item = T;

    pub fn next() ?Item {
        if !(self.start <= self.end) return .None;

        let item = self.start;
        if self.start == self.end {
            let zero: T = self.start - self.start;
            if self.start <= zero {
                self.start += 1;
            } else {
                self.end -= 1;
            }
        } else {
            self.start += 1;
        }
        return .{ Some: item };
    }
}

impl[T] &mut (T..=T)
    where T: Integer + Eq[T] + Le[T] + Add[T, Out = T] + Sub[T, Out = T],
{
    pub fn count() usize {
        return consume_count[T]((self as &mut Iterator[Item = T]));
    }

    pub fn nth(n: usize) ?T {
        return consume_nth[T]((self as &mut Iterator[Item = T]), n);
    }

    pub fn last() ?T {
        return consume_last[T]((self as &mut Iterator[Item = T]));
    }

    pub fn for_each(visitor: &Fn(T) void) void {
        consume_for_each[T]((self as &mut Iterator[Item = T]), visitor);
    }

    pub fn fold[U](init: U, step: &Fn(U, T) U) U {
        return consume_fold[T, U]((self as &mut Iterator[Item = T]), init, step);
    }

    pub fn any(pred: &Fn(T) bool) bool {
        return consume_any[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn all(pred: &Fn(T) bool) bool {
        return consume_all[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn find(pred: &Fn(T) bool) ?T {
        return consume_find[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn position(pred: &Fn(T) bool) ?usize {
        return consume_position[T]((self as &mut Iterator[Item = T]), pred);
    }

    pub fn find_map[U](call_back: &Fn(T) ?U) ?U {
        return consume_find_map[T, U]((self as &mut Iterator[Item = T]), call_back);
    }

    pub fn skip(count: usize) RangeInclusiveSkip[T] {
        return .{ inner: self.*, remaining: count };
    }

    pub fn enumerate() RangeInclusiveEnumerate[T] {
        return .{ inner: self.* };
    }
}

impl[T] T..=T
    where T: Integer + Eq[T] + Le[T] + Add[T, Out = T] + Sub[T, Out = T],
{
    pub fn skip(count: usize) RangeInclusiveSkip[T] {
        return .{ inner: self, remaining: count };
    }

    pub fn enumerate() RangeInclusiveEnumerate[T] {
        return .{ inner: self };
    }
}

