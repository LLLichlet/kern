    where T: Integer + Lt[T] + Sub[T, Out = T],
{
    type Item = T;

    pub fn next() ?Item {
        while self.remaining != 0 {
            match self.inner..&.next() {
                .{ Some: _ } => self.remaining -= 1,
                .None => {
                    self.remaining = 0;
                    return .None;
                },
            }
        }
        return self.inner..&.next();
    }
}

