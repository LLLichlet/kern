//! Runtime-independent formatting and byte-stream helpers.
//!
//! `base.io` contains only freestanding traits and adapters. Hosted output
//! streams such as stdout and stderr live in `std.io`.

mod impls;
mod traits;
mod fmt;
mod writers;
mod readers;

pub use .fmt.Format;
pub use .traits.{Formatable, Read, Write};
pub use .writers.{
    FixedBufferWriter,
    StringWriter,
    CountingWriter,
    NullWriter,
    discard,
};
pub use .readers.{
    SliceReader,
    LimitReader,
};
