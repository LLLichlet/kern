//! Formatting and byte-stream traits.

/// A byte sink used by the formatting subsystem.
pub/ trait Write {
    fn write(bytes: &[u8]) usize;
};

/// A byte source used by generic input helpers.
pub/ trait Read {
    fn read(buffer: &mut [u8]) usize;
};

/// A value that knows how to render itself into a `Write`.
pub/ trait Formatable {
    fn write_to(writer: &mut Write) void;
};
