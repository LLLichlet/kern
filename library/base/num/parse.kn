impl &[u8] : Parse[i128] {
    pub fn parse_text() i128!ParseIntError {
        return parse_i128_radix(self, 10);
    }

    pub fn parse_text_radix(radix: u8) i128!ParseIntError {
        return parse_i128_radix(self, radix);
    }
}

impl &[u8] : Parse[isize] {
    pub fn parse_text() isize!ParseIntError {
        return parse_isize_radix(self, 10);
    }

    pub fn parse_text_radix(radix: u8) isize!ParseIntError {
        return parse_isize_radix(self, radix);
    }
}
