//! Test assertion helpers.
//!
//! `base.test` is freestanding: it defines assertion vocabulary that can be
//! used by kernels, runtimes, hosted programs, and test targets without
//! depending on an operating-system output channel.

use base.io.{Printable, Writer, format_to};

/// Assertion context with an explicit output sink.
pub type Context = struct {
    writer: ?*mut Writer = .None,
};

fn write_location(
    writer: *mut Writer,
    loc: struct { file: []u8, line: usize, col: usize },
) void {
    _ = writer.write(loc.file);
    format_to(writer, ":{}:{}: ", .{loc.line, loc.col});
}

fn fail_with(
    writer: ?*mut Writer,
    loc: struct { file: []u8, line: usize, col: usize },
    fmt: []u8,
    args: []*Printable,
) ! {
    let .{ Some: out } = writer else {
        @trap();
    };

    write_location(out, loc);
    _ = out.write("test failed: ");
    format_to(out, fmt, args);
    _ = out.write("\n");
    @trap();
}

/// Creates an assertion context that reports failures to `writer`.
pub fn context(writer: *mut Writer) Context {
    return .{ writer: .{ Some: writer } };
}

/// Creates an assertion context that only traps on failure.
pub fn silent() Context {
    return .{};
}

impl *mut Context {
    /// Fails the current test immediately after writing a diagnostic when this
    /// context has a writer.
    pub fn fail(
        loc: struct { file: []u8, line: usize, col: usize },
        fmt: []u8,
        args: []*Printable,
    ) ! {
        fail_with(self.writer, loc, fmt, args);
    }

    /// Fails the current test when `ok` is false.
    pub fn assert(
        loc: struct { file: []u8, line: usize, col: usize },
        ok: bool,
        fmt: []u8,
        args: []*Printable,
    ) void {
        if (!ok) {
            self.fail(loc, fmt, args);
        }
    }

    /// Fails unless `actual` equals `expected`.
    pub fn eq[T](
        loc: struct { file: []u8, line: usize, col: usize },
        actual: T,
        expected: T,
        fmt: []u8,
        args: []*Printable,
    ) void
        where T: Eq[T],
    {
        if (!(actual == expected)) {
            self.fail(loc, fmt, args);
        }
    }

    /// Fails when `actual` equals `unexpected`.
    pub fn not_eq[T](
        loc: struct { file: []u8, line: usize, col: usize },
        actual: T,
        unexpected: T,
        fmt: []u8,
        args: []*Printable,
    ) void
        where T: Eq[T],
    {
        if (actual == unexpected) {
            self.fail(loc, fmt, args);
        }
    }

    /// Fails unless the option contains a value.
    pub fn assert_some[T](
        loc: struct { file: []u8, line: usize, col: usize },
        value: ?T,
        fmt: []u8,
        args: []*Printable,
    ) void {
        let .{ Some: _ } = value else self.fail(loc, fmt, args);
    }

    /// Fails unless the option is `None`.
    pub fn assert_none[T](
        loc: struct { file: []u8, line: usize, col: usize },
        value: ?T,
        fmt: []u8,
        args: []*Printable,
    ) void {
        let .None = value else self.fail(loc, fmt, args);
    }

    /// Returns the payload from `Some(T)` or fails when the option is `None`.
    pub fn expect_some[T](
        loc: struct { file: []u8, line: usize, col: usize },
        value: ?T,
        fmt: []u8,
        args: []*Printable,
    ) T {
        let .{ Some: payload } = value else self.fail(loc, fmt, args);
        return payload;
    }

    /// Fails unless the option is `None`.
    pub fn expect_none[T](
        loc: struct { file: []u8, line: usize, col: usize },
        value: ?T,
        fmt: []u8,
        args: []*Printable,
    ) void {
        let .None = value else self.fail(loc, fmt, args);
    }

    /// Fails unless the result is `Ok`.
    pub fn assert_ok[T, E](
        loc: struct { file: []u8, line: usize, col: usize },
        value: T!E,
        fmt: []u8,
        args: []*Printable,
    ) void {
        let .{ Ok: _ } = value else self.fail(loc, fmt, args);
    }

    /// Fails unless the result is `Err`.
    pub fn assert_err[T, E](
        loc: struct { file: []u8, line: usize, col: usize },
        value: T!E,
        fmt: []u8,
        args: []*Printable,
    ) void {
        let .{ Err: _ } = value else self.fail(loc, fmt, args);
    }

    /// Returns the payload from `Ok(T)` or fails when the result is `Err`.
    pub fn expect_ok[T, E](
        loc: struct { file: []u8, line: usize, col: usize },
        value: T!E,
        fmt: []u8,
        args: []*Printable,
    ) T {
        let .{ Ok: payload } = value else self.fail(loc, fmt, args);
        return payload;
    }

    /// Returns the payload from `Err(E)` or fails when the result is `Ok`.
    pub fn expect_err[T, E](
        loc: struct { file: []u8, line: usize, col: usize },
        value: T!E,
        fmt: []u8,
        args: []*Printable,
    ) E {
        let .{ Err: payload } = value else self.fail(loc, fmt, args);
        return payload;
    }
}
