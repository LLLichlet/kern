//! Test assertion helpers.
//!
//! `base.test` is freestanding: it defines assertion vocabulary that can be
//! used by kernels, runtimes, hosted programs, and test targets without
//! depending on an operating-system output channel.

use base.io.{Formatable, Write};

/// Source location used in test diagnostics.
pub type Loc = struct { file: &[u8], line: usize, col: usize };

/// Test reporter that owns its output sink.
pub struct Report[W] {
    writer: W,
};

/// Deferred assertion result.
pub struct Check {
    passed: bool,
    message: &[u8],
};

/// Creates a local test reporter.
pub fn report[W](writer: W) Report[W]
    where &mut W: Write,
{
    return .{ writer: writer };
}

impl[W] &mut Report[W]
    where &mut W: Write,
{
    pub fn fail_at(loc: Loc, message: &[u8]) ! {
        let out = &mut Write.{ self.writer..& };
        _ = out.write(loc.file);
        ":{}:{}: ".fmt(.{loc.line, loc.col}).write_to(out);
        _ = out.write("test failed: ");
        _ = out.write(message);
        _ = out.write("\n");
        @trap();
    }
}

impl Check {
    pub fn sum[W](loc: Loc, report: &mut Report[W]) void
        where &mut W: Write,
    {
        if (!self.passed) {
            report.fail_at(loc, self.message);
        }
    }
}

impl bool {
    pub fn should() Check {
        static message = "expected condition to be true";
        return .{ passed: self, message };
    }
}

pub struct ValueCheck[T] {
    passed: bool,
    value: ?T,
    message: &[u8],
};

impl[T] ValueCheck[T] {
    pub fn eq(expected: T) Check
        where T: Eq[T],
    {
        if (!self.passed) {
            return .{ passed: false, message: self.message };
        }

        let .{ Some: actual } = self.value else {
            static message = "expected a value before equality check";
            return .{ passed: false, message };
        };

        if (!(actual == expected)) {
            static message = "expected values to be equal";
            return .{ passed: false, message };
        }

        static message = "";
        return .{ passed: true, message };
    }

    pub fn sum[W](loc: Loc, report: &mut Report[W]) T
        where &mut W: Write,
    {
        if (!self.passed) {
            report.fail_at(loc, self.message);
        }

        let .{ Some: payload } = self.value else {
            report.fail_at(loc, "expected a value before finishing check");
        };
        return payload;
    }
}

impl[T] ?T {
    pub fn should_some() ValueCheck[T] {
        match (self) {
            .{ Some: payload } => {
                static message = "";
                return .{
                    passed: true,
                    value: .{ Some: payload },
                    message,
                };
            },
            .None => {
                static message = "expected option to contain a value";
                return .{
                    passed: false,
                    value: .None,
                    message,
                };
            },
        }
    }

    pub fn should_none() Check {
        match (self) {
            .None => {
                static message = "";
                return .{ passed: true, message };
            },
            .{ Some: _ } => {
                static message = "expected option to be None";
                return .{ passed: false, message };
            },
        }
    }
}

impl[T, E] T!E {
    pub fn should_ok() ValueCheck[T] {
        match (self) {
            .{ Ok: payload } => {
                static message = "";
                return .{
                    passed: true,
                    value: .{ Some: payload },
                    message,
                };
            },
            .{ Err: _ } => {
                static message = "expected result to be Ok";
                return .{
                    passed: false,
                    value: .None,
                    message,
                };
            },
        }
    }

    pub fn should_err() ValueCheck[E] {
        match (self) {
            .{ Err: payload } => {
                static message = "";
                return .{
                    passed: true,
                    value: .{ Some: payload },
                    message,
                };
            },
            .{ Ok: _ } => {
                static message = "expected result to be Err";
                return .{
                    passed: false,
                    value: .None,
                    message,
                };
            },
        }
    }
}
