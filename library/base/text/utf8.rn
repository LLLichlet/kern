//! UTF-8 scalar encoding and decoding.
//!
//! The APIs here operate on caller-provided storage and report explicit byte
//! offsets. They are suitable for kernels, parsers, operating-system shims, and
//! hosted libraries without introducing allocation policy.

use ..unicode;
use base.io.{FormatSpec, Formatable, Write};

/// UTF-8 conversion failures.
pub enum Utf8Error {
    /// The input ended before a complete scalar was available.
    UnexpectedEof,
    /// A byte sequence is not valid UTF-8 at this offset.
    InvalidEncoding: usize,
    /// A codepoint is not a Unicode scalar value.
    InvalidScalar,
    /// The caller-provided output buffer is too small.
    ShortOutput,
};

impl &Utf8Error : Formatable {
    /// Writes the UTF-8 error; format presentations do not affect diagnostics.
    pub fn write_fmt(spec: FormatSpec, writer: &mut Write) void {
        _ = spec;
        match (self.*) {
            .UnexpectedEof => _ = writer.write("Utf8Error.UnexpectedEof"),
            .{ InvalidEncoding: offset } => {
                _ = "Utf8Error.InvalidEncoding({})".fmt(.{offset}).write_to(writer);
            },
            .InvalidScalar => _ = writer.write("Utf8Error.InvalidScalar"),
            .ShortOutput => _ = writer.write("Utf8Error.ShortOutput"),
        }
    }
}

impl Utf8Error : Eq[Utf8Error] {
    /// Compares UTF-8 error variants and offsets exactly.
    pub fn eq(other: Utf8Error) bool {
        return match (self) {
            .UnexpectedEof => match (other) { .UnexpectedEof => true, _ => false },
            .{ InvalidEncoding: a } => match (other) {
                .{ InvalidEncoding: b } => a == b,
                _ => false,
            },
            .InvalidScalar => match (other) { .InvalidScalar => true, _ => false },
            .ShortOutput => match (other) { .ShortOutput => true, _ => false },
        };
    }
}

/// Decoded UTF-8 scalar and its source byte length.
pub struct Utf8Scalar {
    /// Unicode scalar value.
    pub codepoint: u32,
    /// Number of source bytes consumed.
    pub len: usize,
};

// UTF-8 continuation bytes all have the `10xxxxxx` high-bit pattern.
fn is_continuation(byte: u8) bool {
    return (byte & 0xC0u8) == 0x80u8;
}

/// Returns the UTF-8 byte width for a Unicode scalar value.
pub fn len(codepoint: u32) usize!Utf8Error {
    if (!unicode.is_scalar(codepoint)) return .{ Err: .InvalidScalar };
    if (codepoint <= 0x7Fu32) return .{ Ok: 1 };
    if (codepoint <= 0x7FFu32) return .{ Ok: 2 };
    if (codepoint <= 0xFFFFu32) return .{ Ok: 3 };
    return .{ Ok: 4 };
}

/// Writes one Unicode scalar as UTF-8 at `index`.
pub fn write_at(codepoint: u32, out: &mut [u8], index: usize) usize!Utf8Error {
    let width = len(codepoint).?;
    if (index > #out) return .{ Err: .ShortOutput };
    if (#out - index < width) return .{ Err: .ShortOutput };
    if (width == 1) {
        out.[index] = codepoint as u8;
        return .{ Ok: index + 1 };
    }
    if (width == 2) {
        out.[index] = (0xC0u32 + (codepoint >> 6)) as u8;
        out.[index + 1] = (0x80u32 + (codepoint & 0x3Fu32)) as u8;
        return .{ Ok: index + 2 };
    }
    if (width == 3) {
        out.[index] = (0xE0u32 + (codepoint >> 12)) as u8;
        out.[index + 1] = (0x80u32 + ((codepoint >> 6) & 0x3Fu32)) as u8;
        out.[index + 2] = (0x80u32 + (codepoint & 0x3Fu32)) as u8;
        return .{ Ok: index + 3 };
    }
    out.[index] = (0xF0u32 + (codepoint >> 18)) as u8;
    out.[index + 1] = (0x80u32 + ((codepoint >> 12) & 0x3Fu32)) as u8;
    out.[index + 2] = (0x80u32 + ((codepoint >> 6) & 0x3Fu32)) as u8;
    out.[index + 3] = (0x80u32 + (codepoint & 0x3Fu32)) as u8;
    return .{ Ok: index + 4 };
}

/// Writes one Unicode scalar as UTF-8 at the beginning of `out`.
pub fn write(codepoint: u32, out: &mut [u8]) usize!Utf8Error {
    return write_at(codepoint, out, 0);
}

/// Reads one UTF-8 scalar from `text` at byte offset `start`.
pub fn read_at(text: &[u8], start: usize) Utf8Scalar!Utf8Error {
    if (start >= #text) return .{ Err: .UnexpectedEof };
    let remaining = #text - start;

    let b0 = text.[start];
    if (b0 < 0x80u8) {
        return .{ Ok: .{ codepoint: b0 as u32, len: 1 } };
    }

    // Two-byte scalars must start at C2; C0 and C1 would be overlong ASCII.
    if (b0 >= 0xC2u8 and b0 <= 0xDFu8) {
        if (remaining < 2) return .{ Err: .UnexpectedEof };
        if (!is_continuation(text.[start + 1])) return .{ Err: .{ InvalidEncoding: start } };
        let payload0 = (b0 & 0x1Fu8) as u32;
        let payload1 = (text.[start + 1] & 0x3Fu8) as u32;
        let value = (payload0 << 6) + payload1;
        return .{ Ok: .{ codepoint: value, len: 2 } };
    }

    // Three-byte scalars need extra boundary checks for overlong forms and
    // UTF-16 surrogate codepoints.
    if (b0 >= 0xE0u8 and b0 <= 0xEFu8) {
        if (remaining < 3) return .{ Err: .UnexpectedEof };
        if (!is_continuation(text.[start + 1]) or !is_continuation(text.[start + 2])) {
            return .{ Err: .{ InvalidEncoding: start } };
        }
        let b1 = text.[start + 1];
        if ((b0 == 0xE0u8 and b1 < 0xA0u8)
            or (b0 == 0xEDu8 and b1 >= 0xA0u8)
        ) {
            return .{ Err: .{ InvalidEncoding: start } };
        }
        let payload0 = (b0 & 0x0Fu8) as u32;
        let payload1 = (b1 & 0x3Fu8) as u32;
        let payload2 = (text.[start + 2] & 0x3Fu8) as u32;
        let value = (payload0 << 12) + (payload1 << 6) + payload2;
        return .{ Ok: .{ codepoint: value, len: 3 } };
    }

    // Four-byte scalars are valid only up to U+10FFFF.
    if (b0 >= 0xF0u8 and b0 <= 0xF4u8) {
        if (remaining < 4) return .{ Err: .UnexpectedEof };
        if (!is_continuation(text.[start + 1])
            or !is_continuation(text.[start + 2])
            or !is_continuation(text.[start + 3])
        ) {
            return .{ Err: .{ InvalidEncoding: start } };
        }
        let b1 = text.[start + 1];
        if ((b0 == 0xF0u8 and b1 < 0x90u8)
            or (b0 == 0xF4u8 and b1 > 0x8Fu8)
        ) {
            return .{ Err: .{ InvalidEncoding: start } };
        }
        let payload0 = (b0 & 0x07u8) as u32;
        let payload1 = (b1 & 0x3Fu8) as u32;
        let payload2 = (text.[start + 2] & 0x3Fu8) as u32;
        let payload3 = (text.[start + 3] & 0x3Fu8) as u32;
        let value = (payload0 << 18) + (payload1 << 12) + (payload2 << 6) + payload3;
        return .{ Ok: .{ codepoint: value, len: 4 } };
    }

    return .{ Err: .{ InvalidEncoding: start } };
}

/// Returns whether `text` is valid UTF-8.
pub fn is_valid(text: &[u8]) bool {
    let mut i = 0;
    // UTF-8 validation advances by scalar width, not by individual bytes.
    while (i < #text) {
        let .{ Ok: scalar } = read_at(text, i) else return false;
        i += scalar.len;
    }
    return true;
}

/// Returns the number of Unicode scalar values in valid UTF-8 text.
pub fn scalar_count(text: &[u8]) usize!Utf8Error {
    let mut count = 0;
    let mut i = 0;
    // Scalar counting shares the decoder so validation and counting cannot drift.
    while (i < #text) {
        let scalar = read_at(text, i).?;
        count += 1;
        i += scalar.len;
    }
    return .{ Ok: count };
}

impl u32 {
    /// Returns the UTF-8 byte width for this Unicode scalar value.
    pub fn utf8_len() usize!Utf8Error {
        return len(self);
    }

    /// Writes this Unicode scalar as UTF-8 at the beginning of `out`.
    pub fn write_utf8(out: &mut [u8]) usize!Utf8Error {
        return write(self, out);
    }

    /// Writes this Unicode scalar as UTF-8 at `index`.
    pub fn write_utf8_at(out: &mut [u8], index: usize) usize!Utf8Error {
        return write_at(self, out, index);
    }
}

impl &[u8] {
    /// Reads one UTF-8 scalar at byte offset `start`.
    pub fn read_utf8_at(start: usize) Utf8Scalar!Utf8Error {
        return read_at(self, start);
    }

    /// Returns whether this byte slice is valid UTF-8.
    pub fn is_utf8() bool {
        return is_valid(self);
    }

    /// Returns the number of Unicode scalar values in this valid UTF-8 slice.
    pub fn utf8_scalar_count() usize!Utf8Error {
        return scalar_count(self);
    }
}
