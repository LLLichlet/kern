//! Tests for `base.mem.alloc` implementations and typed allocation helpers.

use base.coll;
use base.mem.Layout;
use base.mem.alloc.{Allocator, arena, gpa};
use base.test.{Report, report};
use base.io;
use std.mem.Page;

struct Pair {
    left: i32,
    right: i32,
};

fn sum(items: &[i32]) i32 {
    return items.fold[i32, i32](0i32, [](accum: i32, value: i32) i32 {
        return accum + value;
    });
}

fn check_gpa_and_arena[W](t: &mut Report[W]) void
    where &mut W: io.Write,
{
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    defer gpa.deinit();

    let aligned = Layout.{ size: 33usize, align: 256usize };
    let ptr_a = gpa.alloc(aligned).should_some().sum(@loc(), t);
    (((ptr_a as usize) % 256usize) == 0usize).should().sum(@loc(), t);

    let compact = Layout.{ size: 17usize, align: 64usize };
    let ptr_b = gpa.alloc(compact).should_some().sum(@loc(), t);
    (((ptr_b as usize) % 64usize) == 0usize).should().sum(@loc(), t);

    gpa.free(ptr_a, aligned);
    gpa.free(ptr_b, compact);

    let ptr_c = gpa.alloc(aligned).should_some().sum(@loc(), t);
    (((ptr_c as usize) % 256usize) == 0usize).should().sum(@loc(), t);
    gpa.free(ptr_c, aligned);

    let scratch = arena().on(page)..&;
    defer scratch.deinit();

    let arena_a = scratch.alloc(Layout.{ size: 24usize, align: 16usize }).should_some().sum(@loc(), t);
    (((arena_a as usize) % 16usize) == 0usize).should().sum(@loc(), t);

    let arena_b = scratch.alloc(Layout.{ size: 40usize, align: 32usize }).should_some().sum(@loc(), t);
    (((arena_b as usize) % 32usize) == 0usize).should().sum(@loc(), t);
    ((arena_b as usize) > (arena_a as usize)).should().sum(@loc(), t);

    scratch.reset();

    let arena_reused = scratch.alloc(Layout.{ size: 24usize, align: 16usize }).should_some().sum(@loc(), t);
    (arena_reused == arena_a).should().sum(@loc(), t);

    let grow = arena().on(page)..&;
    defer grow.deinit();

    let bump_a = grow.alloc(Layout.{ size: 12usize, align: 8usize }).should_some().sum(@loc(), t);
    let bump_b = grow.alloc(Layout.{ size: 12usize, align: 8usize }).should_some().sum(@loc(), t);
    ((bump_b as usize) > (bump_a as usize)).should().sum(@loc(), t);

    let large = grow.alloc(Layout.{ size: 9000usize, align: 64usize }).should_some().sum(@loc(), t);
    (((large as usize) % 64usize) == 0usize).should().sum(@loc(), t);

    grow.reset();

    let large_reused = grow.alloc(Layout.{ size: 9000usize, align: 64usize }).should_some().sum(@loc(), t);
    (large_reused == large).should().sum(@loc(), t);

    let bump_reused = grow.alloc(Layout.{ size: 12usize, align: 8usize }).should_some().sum(@loc(), t);
    ((bump_reused as usize) > (large_reused as usize)).should().sum(@loc(), t);
}

fn check_typed_helpers[W](t: &mut Report[W]) void
    where &mut W: io.Write,
{
    let page = Page.{}..&;
    let gpa = gpa().on(page)..&;
    let alloc = (gpa as &mut Allocator);
    defer gpa.deinit();

    let pair = alloc.try_alloc_one[Pair]().should_ok().sum(@loc(), t);
    pair.* = Pair.{ left: 11, right: 31 };
    (pair.left + pair.right).should().eq(42i32).sum(@loc(), t);
    alloc.free_one[Pair](pair);

    let items = alloc.try_alloc_array[i32](5usize).should_ok().sum(@loc(), t);
    items.[0] = 5;
    items.[1] = 1;
    items.[2] = 4;
    items.[3] = 1;
    items.[4] = 3;
    items.sort();
    (items == [5]i32.{ 1, 1, 3, 4, 5 }).should().sum(@loc(), t);
    sum(items).should().eq(14i32).sum(@loc(), t);
    alloc.free_array[i32](items);

    let source = [4]i32.{ 7, 8, 9, 10 };
    let clone = alloc.try_clone_array[i32](source.&[0...4]).should_ok().sum(@loc(), t);
    clone.[2] = 90;
    source.[2].should().eq(9i32).sum(@loc(), t);
    clone.[2].should().eq(90i32).sum(@loc(), t);
    clone.sort();
    clone.lower_bound(90i32).should().eq(3usize).sum(@loc(), t);
    alloc.free_array[i32](clone);

    let empty = alloc.try_alloc_array[u64](0usize).should_ok().sum(@loc(), t);
    (empty.@len()).should().eq(0usize).sum(@loc(), t);
    alloc.free_array[u64](empty);
}

#[test]
fn allocation_helpers() i32 {
    let t = report(io.discard())..&;
    check_gpa_and_arena(t);
    check_typed_helpers(t);
    return 0;
}
