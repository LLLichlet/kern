//! Tests for `base.text` ASCII, Unicode, and UTF-8 primitives.

use base.test.{Report, report};
use base.text.{ascii, unicode, utf8};
use base.io;

// Exercises ASCII classification and digit conversion across module and receiver APIs.
fn check_ascii[W](t: &mut Report[W]) void
    where &mut W: base.io.Write,
{
    ascii
        .is_digit(b'7')
        .should()
        .sum(@loc(), t);
    ascii
        .is_digit(b'x')
        .not()
        .should()
        .sum(@loc(), t);
    ascii
        .is_hex_digit(b'f')
        .should()
        .sum(@loc(), t);
    ascii
        .is_hex_digit(b'G')
        .not()
        .should()
        .sum(@loc(), t);
    ascii.hex_value(b'A')
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(10u8)
        .sum(@loc(), t);
    b'z'.ascii_digit_value(36)
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(35u8)
        .sum(@loc(), t);
    b'z'
        .ascii_digit_value(16)
        .should_none()
        .sum(@loc(), t);
    b'\n'
        .is_ascii_whitespace()
        .should()
        .sum(@loc(), t);
}

// Checks Unicode scalar and UTF-16 surrogate boundaries used by text codecs.
fn check_unicode[W](t: &mut Report[W]) void
    where &mut W: base.io.Write,
{
    unicode
        .is_scalar(0x41u32)
        .should()
        .sum(@loc(), t);
    unicode
        .is_scalar(0x10FFFFu32)
        .should()
        .sum(@loc(), t);
    unicode
        .is_scalar(0xD800u32)
        .not()
        .should()
        .sum(@loc(), t);
    unicode
        .is_high_surrogate(0xD83Du32)
        .should()
        .sum(@loc(), t);
    unicode
        .is_low_surrogate(0xDE80u32)
        .should()
        .sum(@loc(), t);
    unicode.scalar_from_surrogates(0xD83Du32, 0xDE80u32)
        .should_some()
        .sum(@loc(), t)
        .should()
        .eq(0x1F680u32)
        .sum(@loc(), t);
    unicode.scalar_from_surrogates(0xDE80u32, 0xD83Du32)
        .should_none()
        .sum(@loc(), t);
    0x110000u32
        .is_unicode_scalar()
        .not()
        .should()
        .sum(@loc(), t);
}

// Covers UTF-8 encode, decode, validation, counting, and error classification.
fn check_utf8[W](t: &mut Report[W]) void
    where &mut W: base.io.Write,
{
    let mut out: [4]u8 = undef;
    let written = 0x1F680u32
        .write_utf8(out..&[0...4])
        .should_ok()
        .sum(@loc(), t);
    written
        .should()
        .eq(4)
        .sum(@loc(), t);
    out.&[0...written]
        .should()
        .eq([4]u8.{ 0xF0, 0x9F, 0x9A, 0x80 })
        .sum(@loc(), t);
    let source = [6]u8.{ b'A', 0xE2, 0x98, 0x83, 0xF0, 0x9F };
    let first = source.&[0...source.@len()]
        .read_utf8_at(0)
        .should_ok()
        .sum(@loc(), t);
    first.codepoint
        .should()
        .eq(0x41u32)
        .sum(@loc(), t);
    first.len
        .should()
        .eq(1)
        .sum(@loc(), t);
    let snowman = source.&[0...source.@len()]
        .read_utf8_at(1)
        .should_ok()
        .sum(@loc(), t);
    snowman.codepoint
        .should()
        .eq(0x2603u32)
        .sum(@loc(), t);
    snowman.len
        .should()
        .eq(3)
        .sum(@loc(), t);
    source.&[0...4]
        .utf8_scalar_count()
        .should_ok()
        .eq(2)
        .sum(@loc(), t);
    source.&[0...source.@len()]
        .is_utf8()
        .not()
        .should()
        .sum(@loc(), t);
    source.&[4...source.@len()]
        .read_utf8_at(0)
        .should_err()
        .eq(utf8.Utf8Error.UnexpectedEof)
        .sum(@loc(), t);

    let overlong = [2]u8.{ 0xC0, 0x80 };
    overlong.&[0...2]
        .read_utf8_at(0)
        .should_err()
        .eq(utf8.Utf8Error.{ InvalidEncoding: 0 })
        .sum(@loc(), t);
    0xD800u32
        .write_utf8(out..&[0...4])
        .should_err()
        .eq(utf8.Utf8Error.InvalidScalar)
        .sum(@loc(), t);
    0x1F680u32
        .write_utf8(out..&[0...3])
        .should_err()
        .eq(utf8.Utf8Error.ShortOutput)
        .sum(@loc(), t);
}

// Runs freestanding text tests without depending on hosted stderr.
#[test]
fn text_helpers() i32 {
    let t = report(io.discard())..&;
    check_ascii(t);
    check_unicode(t);
    check_utf8(t);
    return 0;
}
