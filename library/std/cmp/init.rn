impl bool : Eq[bool] {
    pub fn eq(other: bool) bool {
        return self == other;
    }
}

impl bool : Comparable[bool] {
    pub fn cmp(other: bool) Ordering {
        if (self == other) return EQUAL;
        if (!self and other) return LESS;
        return GREATER;
    }
}

impl bool : Ord[bool] {}
