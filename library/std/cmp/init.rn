        if (self < other) return LESS;
        if (self > other) return GREATER;
        return EQUAL;
    }
}

impl usize : Ord[usize] {}

impl bool : Comparable[bool] {
    pub fn cmp(other: bool) Ordering {
        if (self == other) return EQUAL;
        if (!self and other) return LESS;
        return GREATER;
    }
}

impl bool : Ord[bool] {}
