pub type Ordering = i32;

pub const LESS = Ordering.{-1};
pub const EQUAL = Ordering.{0};
pub const GREATER = Ordering.{1};

pub type Eq[T] = trait {
    eq: fn(T) bool,
};

pub type Comparable[T] = trait {
    cmp: fn(T) Ordering,
};

pub type Ord[T]: Eq[T] + Comparable[T] = trait {};

pub fn eq[T](lhs: T, rhs: T) bool
    where T: Eq[T],
{
    return lhs.eq(rhs);
}

pub fn ord_cmp[T](lhs: T, rhs: T) Ordering
    where T: Ord[T],
{
    return lhs.cmp(rhs);
}

impl i8 : Eq[i8] {
    pub fn eq(other: i8) bool {
        return self == other;
    }
}

impl i8 : Comparable[i8] {
    pub fn cmp(other: i8) Ordering {
        if (self < other) return LESS;
        if (self > other) return GREATER;
        return EQUAL;
    }
}

impl i8 : Ord[i8] {}

impl i16 : Eq[i16] {
    pub fn eq(other: i16) bool {
        return self == other;
    }
}

impl i16 : Comparable[i16] {
