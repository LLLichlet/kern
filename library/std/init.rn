//! Kern standard library.
//!
//! `std` is the high-level hosted library layer built on top of `base`.
//! Foundation facilities remain in `base`, and startup glue remains in `rt`.
//!
//! Hosted implementation details are owned internally by `std.host`, not by a
//! public system package or an implicit libc dependency.

pub mod io;
pub mod fs;
pub mod env;
pub mod proc;
pub mod msg;
pub mod mem;
pub mod time;
pub mod term;
mod host;
