//! Test assertion helpers.
//!
//! This module is intentionally separate from `std.msg`:
//! `msg` is for diagnostics and low-level runtime failures, while `test`
//! defines vocabulary for executable test targets.

use std.io.Printable;
use ..msg;

/// Fails the current test immediately after printing a diagnostic.
pub fn fail(fmt: []u8, args: []*Printable) ! {
    msg.fail("test failed: ", fmt, args);
}

/// Fails the current test when `ok` is false.
pub fn assert(ok: bool, fmt: []u8, args: []*Printable) void {
    if (!ok) {
        fail(fmt, args);
    }
}

/// Fails unless `actual` equals `expected`.
pub fn eq[T](actual: T, expected: T) void
    where T: Eq[T],
{
    if (!(actual == expected)) {
        fail("expected values to be equal", .{});
    }
}

/// Fails with `fmt` unless `actual` equals `expected`.
pub fn eq_msg[T](actual: T, expected: T, fmt: []u8, args: []*Printable) void
    where T: Eq[T],
{
    if (!(actual == expected)) {
        fail(fmt, args);
    }
}

/// Fails when `actual` equals `unexpected`.
pub fn not_eq[T](actual: T, unexpected: T) void
    where T: Eq[T],
{
    if (actual == unexpected) {
        fail("expected values to differ", .{});
    }
}

/// Fails with `fmt` when `actual` equals `unexpected`.
pub fn not_eq_msg[T](actual: T, unexpected: T, fmt: []u8, args: []*Printable) void
    where T: Eq[T],
{
    if (actual == unexpected) {
        fail(fmt, args);
    }
}

/// Fails unless the option contains a value.
pub fn assert_some[T](value: ?T) void {
    let .{ Some: _ } = value else fail("expected option to contain a value", .{});
}

/// Fails with `fmt` unless the option contains a value.
pub fn assert_some_msg[T](value: ?T, fmt: []u8, args: []*Printable) void {
    let .{ Some: _ } = value else fail(fmt, args);
}

/// Fails unless the option is `None`.
pub fn assert_none[T](value: ?T) void {
    let .None = value else fail("expected option to be empty", .{});
}

/// Fails with `fmt` unless the option is `None`.
pub fn assert_none_msg[T](value: ?T, fmt: []u8, args: []*Printable) void {
    let .None = value else fail(fmt, args);
}

/// Returns the payload from `Some(T)` or fails when the option is `None`.
pub fn expect_some[T](value: ?T) T {
    let .{ Some: payload } = value else fail("expected option to contain a value", .{});
    return payload;
}

/// Returns the payload from `Some(T)` or fails with `fmt` when the option is `None`.
pub fn expect_some_msg[T](value: ?T, fmt: []u8, args: []*Printable) T {
    let .{ Some: payload } = value else fail(fmt, args);
    return payload;
}

/// Fails unless the option is `None`.
pub fn expect_none[T](value: ?T) void {
    let .None = value else fail("expected option to be empty", .{});
}

/// Fails with `fmt` unless the option is `None`.
pub fn expect_none_msg[T](value: ?T, fmt: []u8, args: []*Printable) void {
    let .None = value else fail(fmt, args);
}

/// Fails unless the result is `Ok`.
pub fn assert_ok[T, E](value: T!E) void {
    let .{ Ok: _ } = value else fail("expected result to be ok", .{});
}

/// Fails with `fmt` unless the result is `Ok`.
pub fn assert_ok_msg[T, E](value: T!E, fmt: []u8, args: []*Printable) void {
    let .{ Ok: _ } = value else fail(fmt, args);
}

/// Fails unless the result is `Err`.
pub fn assert_err[T, E](value: T!E) void {
    let .{ Err: _ } = value else fail("expected result to be err", .{});
}

/// Fails with `fmt` unless the result is `Err`.
pub fn assert_err_msg[T, E](value: T!E, fmt: []u8, args: []*Printable) void {
    let .{ Err: _ } = value else fail(fmt, args);
}

/// Returns the payload from `Ok(T)` or fails when the result is `Err`.
pub fn expect_ok[T, E](value: T!E) T {
    let .{ Ok: payload } = value else fail("expected result to be ok", .{});
    return payload;
}

/// Returns the payload from `Ok(T)` or fails with `fmt` when the result is `Err`.
pub fn expect_ok_msg[T, E](value: T!E, fmt: []u8, args: []*Printable) T {
    let .{ Ok: payload } = value else fail(fmt, args);
    return payload;
}

/// Returns the payload from `Err(E)` or fails when the result is `Ok`.
pub fn expect_err[T, E](value: T!E) E {
    let .{ Err: payload } = value else fail("expected result to be err", .{});
    return payload;
}

/// Returns the payload from `Err(E)` or fails with `fmt` when the result is `Ok`.
pub fn expect_err_msg[T, E](value: T!E, fmt: []u8, args: []*Printable) E {
    let .{ Err: payload } = value else fail(fmt, args);
    return payload;
}
