//! Minimal runtime memory intrinsics.

#[export_name("memcpy")]
pub extern fn memcpy(dest: *mut u8, src: *u8, len: usize) *mut u8 {
    for (let mut i = 0; i < len; i += 1) {
        let d = dest + i;
        let s = src + i;
        d.* = s.*;
    }
    return dest;
}

#[export_name("memset")]
pub extern fn memset(dest: *mut u8, val: i32, len: usize) *mut u8 {
    // The C `memset` signature uses `i32`, but the fill byte is applied as `u8`.
    let v = val as u8; 
    
    for (let mut i = usize.{0}; i < len; i += 1) {
        let d = dest + i;
        d.* = v;
    }
    return dest;
}

#[export_name("memmove")]
pub extern fn memmove(dest: *mut u8, src: *u8, len: usize) *mut u8 {
    // Checks for overlapping ranges by comparing addresses as `usize`.
    let d_addr = dest as usize;
    let s_addr = src as usize;
    
    // If `dest` falls inside `src`, forward copying would clobber unread bytes.
    if (d_addr > s_addr and d_addr < (s_addr + len)) {
        // Copies backward when the ranges overlap.
        for (let mut i = len; i > 0; ) {
            i -= 1;
            let d = dest + i;
            let s = src + i;
            d.* = s.*;
        }
    } else {
        // Copies forward when there is no overlap hazard.
        for (let mut i = 0; i < len; i += 1) {
            let d = dest + i;
            let s = src + i;
            d.* = s.*;
        }
    }
    return dest;
}
