use std.test;
use toml.parse;

fn check_managed_parse_mutate_render() void {
    let mut doc = test.expect_ok(parse(""));
    defer doc..&.deinit();

    let root = doc..&.root();
    let _ = test.expect_ok(root.set_string("title", "demo"));
    let _ = test.expect_ok(root.set_bool("enabled", true));

    let package = test.expect_ok(doc..&.ensure_table("package"));
    let _ = test.expect_ok(package.set_string("name", "toml"));
    let _ = test.expect_ok(package.set_integer("edition", 2026));

    let features = test.expect_ok(package.ensure_array("features"));
    let _ = test.expect_ok(features.push_string("parse"));
    let _ = test.expect_ok(features.push_string("render"));

    let dep = test.expect_ok(package.ensure_inline_table("dep"));
    let _ = test.expect_ok(dep.set_string("path", "../util"));

    let product = test.expect_ok(doc..&.append_array_table("products"));
    let _ = test.expect_ok(product.set_string("name", "hammer"));
    let _ = test.expect_ok(product.set_integer("price", 9));

    test.assert(
        test.expect_some(doc..&.get_path_string("package.name")).eq("toml"),
        "unexpected package name",
        .{}
    );
    test.eq(doc..&.array_table_len("products"), 1);

    let rendered = test.expect_ok(doc..&.render());
    let mut reparsed = test.expect_ok(parse(rendered));
    defer reparsed..&.deinit();

    test.assert(
        test.expect_some(reparsed..&.get_path_string("title")).eq("demo"),
        "unexpected rendered title",
        .{}
    );
    test.eq(test.expect_some(reparsed..&.get_path_bool("enabled")), true);
    test.eq(test.expect_some(reparsed..&.get_path_integer("package.edition")), 2026);
    test.eq(reparsed..&.array_table_len("products"), 1);
}

extern fn main(args: [][]u8) i32 {
    let _ = args;
    check_managed_parse_mutate_render();
    return 0;
}
