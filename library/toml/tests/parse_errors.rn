use std.test;
use toml.scan;

fn check_bad_array_of_tables_header_error() void {
    let err = test.expect_err(scan("[[products]\nname = \"hammer\"\n"));
    test.assert(
        err.message.eq("unterminated array-of-tables header"),
        "unexpected array-of-tables error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_empty_array_element_error() void {
    let err = test.expect_err(scan("items = [1, , 2]\n"));
    test.assert(
        err.message.eq("array elements cannot be empty"),
        "unexpected empty array error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_bad_float_error() void {
    let err = test.expect_err(scan("ratio = 1.\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected malformed float error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_bad_datetime_error() void {
    let err = test.expect_err(scan("release = 1979-13-27T07:32:00Z\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected malformed datetime error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_bad_local_time_error() void {
    let err = test.expect_err(scan("wake = 24:00:00\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected malformed local time error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_bad_offset_datetime_error() void {
    let err = test.expect_err(scan("release = 1979-05-27T07:32:00+24:00\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected malformed offset datetime error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_short_local_datetime_error() void {
    let err = test.expect_err(scan("release = 1979-05-27T07:32\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected short local datetime error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_bad_quoted_key_error() void {
    let err = test.expect_err(scan("site.\"google.com = true\n"));
    test.assert(
        err.message.eq("unterminated quoted key segment"),
        "unexpected malformed quoted key error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_trailing_inline_table_comma_error() void {
    let err = test.expect_err(scan("dep = { path = \"../util\", }\n"));
    test.assert(
        err.message.eq("inline table entries cannot be empty"),
        "unexpected trailing comma error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_inline_table_duplicate_key_error() void {
    let err = test.expect_err(scan("a = { b = 1, b = 2 }\n"));
    test.assert(
        err.message.eq("duplicate key path"),
        "unexpected inline-table duplicate key error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_inline_table_parent_namespace_conflict_error() void {
    let err = test.expect_err(scan(
        \\tab = { inner = { dog = "best" }, inner.cat = "worst" }
        \\
    ));
    test.assert(
        err.message.eq("key path conflicts with existing parent key namespace"),
        "unexpected inline-table namespace conflict error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_duplicate_key_error() void {
    let err = test.expect_err(scan("title = \"demo\"\ntitle = \"again\"\n"));
    test.assert(
        err.message.eq("duplicate key path"),
        "unexpected duplicate key error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 2);
}

fn check_table_key_conflict_error() void {
    let err = test.expect_err(scan("a = 1\n[a]\nname = \"demo\"\n"));
    test.assert(
        err.message.eq("table path conflicts with existing key path"),
        "unexpected table/key conflict error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 2);
}

fn check_duplicate_table_error() void {
    let err = test.expect_err(scan("[package]\nname = \"demo\"\n[package]\nversion = \"1\"\n"));
    test.assert(
        err.message.eq("duplicate table header"),
        "unexpected duplicate table error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 3);
}

fn check_nested_key_namespace_conflict_error() void {
    let err = test.expect_err(scan("a.b = 1\na = 2\n"));
    test.assert(
        err.message.eq("key path conflicts with existing nested key namespace"),
        "unexpected nested key namespace conflict error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 2);
}

fn check_parent_key_namespace_conflict_error() void {
    let err = test.expect_err(scan("a = 1\na.b = 2\n"));
    test.assert(
        err.message.eq("key path conflicts with existing parent key namespace"),
        "unexpected parent key namespace conflict error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 2);
}

fn check_unterminated_multiline_basic_string_error() void {
    let err = test.expect_err(scan(
        \\message = """
        \\hello
        \\
    ));
    test.assert(
        err.message.eq("unterminated multiline basic string"),
        "unexpected multiline basic string error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_unterminated_multiline_literal_string_error() void {
    let err = test.expect_err(scan(
        \\message = '''
        \\hello
        \\
    ));
    test.assert(
        err.message.eq("unterminated multiline literal string"),
        "unexpected multiline literal string error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_leading_zero_integer_error() void {
    let err = test.expect_err(scan("value = 0123\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected leading-zero integer error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_leading_zero_float_error() void {
    let err = test.expect_err(scan("value = 01.5\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected leading-zero float error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_signed_prefixed_integer_error() void {
    let err = test.expect_err(scan("value = +0x20\n"));
    test.assert(
        err.message.eq(
            "only integers, floats, booleans, strings, arrays, inline tables, and date/time literals are supported currently"
        ),
        "unexpected signed prefixed integer error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_unsupported_basic_string_escape_error() void {
    let err = test.expect_err(scan(
        \\message = "\e"
        \\
    ));
    test.assert(
        err.message.eq("unsupported basic string escape"),
        "unexpected unsupported escape error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_unicode_surrogate_escape_error() void {
    let err = test.expect_err(scan(
        \\message = "\uD800"
        \\
    ));
    test.assert(
        err.message.eq("unicode escape cannot encode a surrogate"),
        "unexpected unicode surrogate error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_invalid_control_character_error() void {
    let input = [1]u8.{ u8.{127}, };
    let err = test.expect_err(scan(input.[0 .. 1]));
    test.assert(
        err.message.eq("invalid control character in source"),
        "unexpected invalid control-character error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_invalid_utf8_error() void {
    let input = [1]u8.{ u8.{255}, };
    let err = test.expect_err(scan(input.[0 .. 1]));
    test.assert(
        err.message.eq("invalid UTF-8 in source"),
        "unexpected invalid utf-8 error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 1);
}

fn check_explicit_table_after_dotted_key_error() void {
    let err = test.expect_err(scan(
        \\[fruit]
        \\apple.color = "red"
        \\
        \\[fruit.apple]
        \\
    ));
    test.assert(
        err.message.eq("table path conflicts with existing key path"),
        "unexpected explicit-table-after-dotted-key error: {}",
        .{ err.message, }
    );
    test.eq(err.line, 4);
}

extern fn main(args: [][]u8) i32 {
    let _ = args;
    check_bad_array_of_tables_header_error();
    check_empty_array_element_error();
    check_bad_float_error();
    check_bad_datetime_error();
    check_bad_local_time_error();
    check_bad_offset_datetime_error();
    check_short_local_datetime_error();
    check_bad_quoted_key_error();
    check_trailing_inline_table_comma_error();
    check_duplicate_key_error();
    check_inline_table_duplicate_key_error();
    check_inline_table_parent_namespace_conflict_error();
    check_table_key_conflict_error();
    check_duplicate_table_error();
    check_nested_key_namespace_conflict_error();
    check_parent_key_namespace_conflict_error();
    check_unterminated_multiline_basic_string_error();
    check_unterminated_multiline_literal_string_error();
    check_leading_zero_integer_error();
    check_leading_zero_float_error();
    check_signed_prefixed_integer_error();
    check_unsupported_basic_string_escape_error();
    check_unicode_surrogate_escape_error();
    check_invalid_control_character_error();
    check_invalid_utf8_error();
    check_explicit_table_after_dotted_key_error();
    return 0;
}
