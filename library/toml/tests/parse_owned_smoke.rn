use std.test;
use std.mem.alloc.{Allocator, GPA, Page};
use toml.{parse_owned, render_document};

fn check_parse_owned_and_render() void {
    let mut page = Page.{}..&;
    let mut gpa = GPA.{ backing: page }..&;
    defer gpa.deinit();
    let alloc = gpa;

    let input =
        \\title = "demo"
        \\hex = 0x2A
        \\oct = 0o755
        \\bin = 0b1010
        \\special = +inf
        \\other = -nan
        \\birthday = 1979-05-27
        \\wake = 07:32:00
        \\local = 1979-05-27T07:32:00.125
        \\release = 1979-05-27T07:32:00Z
        \\message = "line 1\n\"quoted\""
        \\escaped = "\u0041"
        \\summary = """
        \\hello
        \\world
        \\"""
        \\folded = """
        \\alpha \
        \\    beta
        \\"""
        \\quote = """value""""
        \\apos = '''value''''
        \\site."google.com" = true
        \\[package]
        \\name = 'toml'
        \\root = '''
        \\C:\tools\kern
        \\'''
        \\dep.path = "../util"
        \\features = [
        \\    "parse",
        \\    """
        \\    stable
        \\    release
        \\    """,
        \\    { kind = "render", ok = true },
        \\]
        \\[[products]]
        \\name = "hammer"
        \\price = 9
        \\[[products]]
        \\name = "nail"
        \\available = true
        \\aliases = [
        \\    "prod",
        \\    # emitted render should still normalize this
        \\    "stable",
        \\]
        \\
    ;

    let mut doc = test.expect_ok(parse_owned(alloc, input));
    defer doc..&.deinit(alloc);

    test.assert(
        test.expect_some(doc..&.root().get_string("title")).eq("demo"),
        "unexpected root title",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_string("message")).eq("line 1\n\"quoted\""),
        "unexpected decoded basic string",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_string("escaped")).eq("A"),
        "unexpected unicode escape decode",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_string("summary")).eq("hello\nworld\n"),
        "unexpected decoded multiline basic string",
        .{}
    );
    test.eq(test.expect_some(doc..&.root().get_integer("hex")), 42);
    test.eq(test.expect_some(doc..&.root().get_integer("oct")), 493);
    test.eq(test.expect_some(doc..&.root().get_integer("bin")), 10);
    test.assert(
        test.expect_some(doc..&.root().get_float_text("special")).eq("+inf"),
        "unexpected special float text",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_float_text("other")).eq("-nan"),
        "unexpected special float text",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_datetime_text("birthday")).eq("1979-05-27"),
        "unexpected local date text",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_datetime_text("wake")).eq("07:32:00"),
        "unexpected local time text",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_datetime_text("local")).eq("1979-05-27T07:32:00.125"),
        "unexpected local datetime text",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_datetime_text("release")).eq("1979-05-27T07:32:00Z"),
        "unexpected offset datetime text",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_string("folded")).eq("alpha beta\n"),
        "unexpected folded multiline basic string",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_string("quote")).eq("value\""),
        "unexpected multiline quote tail",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.root().get_string("apos")).eq("value'"),
        "unexpected multiline literal quote tail",
        .{}
    );

    let site = test.expect_some(doc..&.root().get_inline_table("site"));
    test.eq(test.expect_some(site.get_bool("google.com")), true);
    test.eq(test.expect_some(doc..&.get_path_bool("site.\"google.com\"")), true);

    let package = test.expect_some(doc..&.get_table("package"));
    test.assert(
        test.expect_some(package.get_string("name")).eq("toml"),
        "unexpected package name",
        .{}
    );
    test.assert(
        test.expect_some(package.get_string("root")).eq("C:\\tools\\kern\n"),
        "unexpected decoded multiline literal string",
        .{}
    );
    let dep = test.expect_some(package.get_inline_table("dep"));
    test.assert(
        test.expect_some(dep.get_string("path")).eq("../util"),
        "unexpected nested dotted-key lowering",
        .{}
    );
    test.assert(
        test.expect_some(doc..&.get_path_string("package.dep.path")).eq("../util"),
        "unexpected document path lookup",
        .{}
    );
    let features = test.expect_some(package.get_array("features"));
    test.eq(features.len(), 3);

    test.eq(doc..&.array_table_len("products"), 2);
    let second = test.expect_some(doc..&.get_array_table("products", 1));
    test.assert(
        test.expect_some(second.get_string("name")).eq("nail"),
        "unexpected second product",
        .{}
    );
    let aliases = test.expect_some(second.get_array("aliases"));
    test.eq(aliases.len(), 2);

    let mut rendered = test.expect_ok(render_document(alloc, doc..&));
    defer rendered..&.deinit(alloc);

    let expected =
        \\title = "demo"
        \\hex = 42
        \\oct = 493
        \\bin = 10
        \\special = +inf
        \\other = -nan
        \\birthday = 1979-05-27
        \\wake = 07:32:00
        \\local = 1979-05-27T07:32:00.125
        \\release = 1979-05-27T07:32:00Z
        \\message = "line 1\n\"quoted\""
        \\escaped = "A"
        \\summary = "hello\nworld\n"
        \\folded = "alpha beta\n"
        \\quote = "value\""
        \\apos = "value'"
        \\site = { "google.com" = true }
        \\
        \\[package]
        \\name = "toml"
        \\root = "C:\\tools\\kern\n"
        \\dep = { path = "../util" }
        \\features = ["parse", "    stable\n    release\n    ", { kind = "render", ok = true }]
        \\
        \\[[products]]
        \\name = "hammer"
        \\price = 9
        \\
        \\[[products]]
        \\name = "nail"
        \\available = true
        \\aliases = ["prod", "stable"]
        \\
    ;

    test.assert(
        rendered.&.as_str().eq(expected),
        "unexpected parse_owned render output: {}",
        .{ rendered.&.as_str(), }
    );
}

fn check_parse_owned_super_tables_after_implicit_children() void {
    let mut page = Page.{}..&;
    let mut gpa = GPA.{ backing: page }..&;
    defer gpa.deinit();
    let alloc = gpa;

    let input =
        \\[a.b.c]
        \\answer = 42
        \\
        \\[a]
        \\better = 43
        \\
        \\[[parent-table.arr]]
        \\name = "first"
        \\[[parent-table.arr]]
        \\name = "second"
        \\[parent-table]
        \\not-arr = 1
        \\
    ;

    let mut doc = test.expect_ok(parse_owned(alloc, input));
    defer doc..&.deinit(alloc);

    let a = test.expect_some(doc..&.get_table("a"));
    test.eq(test.expect_some(a.get_integer("better")), 43);
    test.eq(test.expect_some(doc..&.get_path_integer("a.b.c.answer")), 42);

    let parent = test.expect_some(doc..&.get_table("parent-table"));
    test.eq(test.expect_some(parent.get_integer("not-arr")), 1);
    test.eq(doc..&.array_table_len("parent-table.arr"), 2);
    let second = test.expect_some(doc..&.get_array_table("parent-table.arr", 1));
    test.assert(
        test.expect_some(second.get_string("name")).eq("second"),
        "unexpected second array-table item",
        .{}
    );
}

fn check_parse_owned_duplicate_key_error() void {
    let mut page = Page.{}..&;
    let mut gpa = GPA.{ backing: page }..&;
    defer gpa.deinit();
    let alloc = gpa;

    let err = test.expect_err(parse_owned(
        alloc,
        \\title = "demo"
        \\title = "again"
        \\
    ));
    match (err) {
        .{ Parse: parse_err } => {
            test.assert(
                parse_err.message.eq("duplicate key path"),
                "unexpected parse_owned duplicate-key error: {}",
                .{ parse_err.message, }
            );
            test.eq(parse_err.line, 2);
        },
        .{ Model: _ } => test.fail("unexpected model error", .{}),
    }
}

extern fn main(args: [][]u8) i32 {
    let _ = args;
    check_parse_owned_and_render();
    check_parse_owned_super_tables_after_implicit_children();
    check_parse_owned_duplicate_key_error();
    return 0;
}
