use std.test;
use toml.{ScanDocumentKind, scan};

fn check_root_document() void {
    let doc = test.expect_ok(scan(
        "title = \"demo\"\ncount = 3\nratio = 1.25\nenabled = true\nnames = [\"a\", \"b\", 3]\nliteral = 'ok'\ndep = { path = \"../util\", package = \"util\" }\nsite.\"google.com\" = true\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.KeyValue);
    test.eq(doc.item_count, 8);
    test.eq(doc.root_key_count, 8);
    test.eq(doc.table_key_count, 0);
    test.eq(doc.table_count, 0);
    test.assert(!doc.has_tables(), "expected root document without tables", .{});
}

fn check_table_document() void {
    let doc = test.expect_ok(scan(
        "[package]\nname = \"demo\"\nversion = 1.0\nfeatures = [\"cli\", \"fmt\"]\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.Table);
    test.eq(doc.item_count, 4);
    test.eq(doc.root_key_count, 0);
    test.eq(doc.table_key_count, 3);
    test.eq(doc.table_count, 1);
    test.eq(doc.array_table_count, 0);
    test.assert(doc.has_tables(), "expected table document to report tables", .{});
    test.assert(doc.has_table_keys(), "expected table document to report table keys", .{});
}

fn check_mixed_document() void {
    let doc = test.expect_ok(scan(
        "title = \"demo\"\n[package]\nname = \"demo\"\nmembers = [[1, 2], [3, 4]]\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.Mixed);
    test.eq(doc.root_key_count, 1);
    test.eq(doc.table_key_count, 2);
    test.eq(doc.table_count, 1);
    test.eq(doc.array_table_count, 0);
}

fn check_quoted_table_header() void {
    let doc = test.expect_ok(scan(
        "[target.\"cfg(unix)\"] # host-specific linkage\nlink = { lib = \"ssl\", search = [\"/usr/lib\"] }\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.Table);
    test.eq(doc.root_key_count, 0);
    test.eq(doc.table_key_count, 1);
    test.eq(doc.table_count, 1);
    test.eq(doc.array_table_count, 0);
}

fn check_array_of_tables_document() void {
    let doc = test.expect_ok(scan(
        "[[products]]\nname = \"hammer\"\nprice = 9.99\n\n[[products]]\nname = \"nail\"\navailable = true\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.Table);
    test.eq(doc.item_count, 6);
    test.eq(doc.root_key_count, 0);
    test.eq(doc.table_key_count, 4);
    test.eq(doc.table_count, 2);
    test.eq(doc.array_table_count, 2);
    test.assert(doc.has_array_tables(), "expected array-of-tables document to report array tables", .{});
}

fn check_datetime_literals() void {
    let doc = test.expect_ok(scan(
        "birthday = 1979-05-27\nwake = 07:32:00\nrelease = 1979-05-27T07:32:00Z\nmeeting = 1979-05-27 07:32:00.125+02:30\nlocal = 1979-05-27T07:32:00.125\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.KeyValue);
    test.eq(doc.item_count, 5);
    test.eq(doc.root_key_count, 5);
    test.eq(doc.table_key_count, 0);
    test.eq(doc.table_count, 0);
    test.eq(doc.array_table_count, 0);
}

fn check_dotted_keys_do_not_conflict_when_disjoint() void {
    let doc = test.expect_ok(scan(
        "a.b = 1\na.c = 2\n[a.d]\nvalue = true\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.Mixed);
    test.eq(doc.root_key_count, 2);
    test.eq(doc.table_key_count, 1);
    test.eq(doc.table_count, 1);
}

fn check_arrays_allow_trailing_commas() void {
    let doc = test.expect_ok(scan(
        "values = [1, 2, 3, ]\nnested = [[1, 2], [3, 4], ]\ninline = { features = [\"parse\", \"render\", ] }\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.KeyValue);
    test.eq(doc.item_count, 3);
    test.eq(doc.root_key_count, 3);
    test.eq(doc.table_key_count, 0);
    test.eq(doc.table_count, 0);
    test.eq(doc.array_table_count, 0);
}

fn check_multiline_arrays_with_comments() void {
    let doc = test.expect_ok(scan(
        \\values = [
        \\    1,
        \\    # keep compatibility with common config style
        \\    2,
        \\    3,
        \\]
        \\package.features = [
        \\    "parse",
        \\    "render",
        \\]
        \\
    ));
    test.eq(doc.kind, ScanDocumentKind.KeyValue);
    test.eq(doc.item_count, 2);
    test.eq(doc.root_key_count, 2);
    test.eq(doc.table_key_count, 0);
    test.eq(doc.table_count, 0);
    test.eq(doc.array_table_count, 0);
}

fn check_multiline_strings() void {
    let doc = test.expect_ok(scan(
        \\message = """
        \\hello
        \\world
        \\"""
        \\path = '''
        \\C:\tools\kern
        \\'''
        \\items = [
        \\    """
        \\    alpha
        \\    beta
        \\    """,
        \\    { note = '''
        \\line a
        \\line b
        \\''' },
        \\]
        \\
    ));
    test.eq(doc.kind, ScanDocumentKind.KeyValue);
    test.eq(doc.item_count, 3);
    test.eq(doc.root_key_count, 3);
    test.eq(doc.table_key_count, 0);
    test.eq(doc.table_count, 0);
    test.eq(doc.array_table_count, 0);
}

fn check_numeric_formats() void {
    let doc = test.expect_ok(scan(
        "hex = 0xDEAD_BEEF\noct = 0o755\nbin = 0b1010_0110\nflt = +inf\nother = -nan\nexp = 1e6\n"
    ));
    test.eq(doc.kind, ScanDocumentKind.KeyValue);
    test.eq(doc.item_count, 6);
    test.eq(doc.root_key_count, 6);
    test.eq(doc.table_key_count, 0);
    test.eq(doc.table_count, 0);
    test.eq(doc.array_table_count, 0);
}

fn check_multiline_string_trailing_quotes() void {
    let doc = test.expect_ok(scan(
        \\quote = """value""""
        \\apos = '''value''''
        \\
    ));
    test.eq(doc.kind, ScanDocumentKind.KeyValue);
    test.eq(doc.item_count, 2);
    test.eq(doc.root_key_count, 2);
    test.eq(doc.table_key_count, 0);
    test.eq(doc.table_count, 0);
    test.eq(doc.array_table_count, 0);
}

fn check_explicit_super_tables_after_implicit_children() void {
    let doc = test.expect_ok(scan(
        \\[a.b.c]
        \\answer = 42
        \\
        \\[a]
        \\better = 43
        \\
    ));
    test.eq(doc.kind, ScanDocumentKind.Table);
    test.eq(doc.root_key_count, 0);
    test.eq(doc.table_key_count, 2);
    test.eq(doc.table_count, 2);
    test.eq(doc.array_table_count, 0);
}

fn check_explicit_super_tables_after_array_children() void {
    let doc = test.expect_ok(scan(
        \\[[parent-table.arr]]
        \\[[parent-table.arr]]
        \\[parent-table]
        \\not-arr = 1
        \\
    ));
    test.eq(doc.kind, ScanDocumentKind.Table);
    test.eq(doc.root_key_count, 0);
    test.eq(doc.table_key_count, 1);
    test.eq(doc.table_count, 3);
    test.eq(doc.array_table_count, 2);
}

fn check_reopen_array_table_after_nested_subtable() void {
    let doc = test.expect_ok(scan(
        \\[[arr]]
        \\[arr.subtab]
        \\val = 1
        \\
        \\[[arr]]
        \\[arr.subtab]
        \\val = 2
        \\
    ));
    test.eq(doc.kind, ScanDocumentKind.Table);
    test.eq(doc.table_key_count, 2);
    test.eq(doc.table_count, 4);
    test.eq(doc.array_table_count, 2);
}

extern fn main(args: [][]u8) i32 {
    let _ = args;
    check_root_document();
    check_table_document();
    check_mixed_document();
    check_quoted_table_header();
    check_array_of_tables_document();
    check_datetime_literals();
    check_dotted_keys_do_not_conflict_when_disjoint();
    check_arrays_allow_trailing_commas();
    check_multiline_arrays_with_comments();
    check_multiline_strings();
    check_numeric_formats();
    check_multiline_string_trailing_quotes();
    check_explicit_super_tables_after_implicit_children();
    check_explicit_super_tables_after_array_children();
    check_reopen_array_table_after_nested_subtable();
    return 0;
}
