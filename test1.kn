extern {
    fn printf(format: *u8, ...) i32;
}

type Point = struct {
    x: i32,
    y: i32,
};

fn main() i32 {
    let p = mut Point.{ x: 10, y: 20 };
    
    let ptr = p.&; 
    ptr.y = 100; 
    
    let msg = "Hello\n"; // 这里长度严格为 6, 类型为[]u8

    printf("Result: %d\n\0" as *u8, p.x + p.y); 
    
    return p.x + p.y;
}