fn pi(level: isize) f64 {
    let res = mut f64.{3.0};
    let sign = mut f64.{1.0}; 
    for (let j = mut isize.{1}; j < level; j += 2) { 
        let denom_int = (j + 1) * (j + 2) * (j + 3);
        let denom_f64 = @intToFloat[isize, f64](denom_int);
        res += sign * 4.0 / denom_f64;
        sign = -sign; 
    }
    return res;
}
extern {
    fn printf(format: *u8, ...) i32;
}
fn main() i32 {
    printf("%lf\n\0" as *u8, pi(999999));
    0
}