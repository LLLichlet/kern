extern {
    fn puts(s: *u8) i32;
}

type Status: u8 = enum {
    Ok = 0,
    Error,
    Pending,
};

fn process(val: i32) i32 {
    // Defer 1 会在返回前最后执行
    defer puts("Defer 1: Function ending\n\0" as *u8);

    let state = Status.Ok;

    let multiplier = switch (state) {
        .Ok => 10,
        .Pending => 5,
        .Error => {
            // Defer 2 只在这个 Block 退出时执行！
            defer puts("Defer 2: Error branch exiting\n\0" as *u8);
            0
        },
    };

    let sum = mut i32.{0};
    for (let i = 0; i < multiplier; i += 1) {
        sum += val;
    }

    return sum;
}

fn main() i32 {
    return process(5);
}