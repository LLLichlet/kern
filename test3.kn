type Box[T] = struct {
    value: T,
};

impl [T] *mut Box[T] {
    pub fn get_val() T {
        return self.value; 
    }
}

type Reader = trait {
    read: fn(Self) i32,
};

type File = struct { fd: i32 };

impl *mut File : Reader {
    pub fn read() i32 {
        return self.fd;
    }
}

fn read_data(r: mut Reader) i32 {
    return r.read(); 
}

extern {
    fn printf(format: *u8, ...) i32;
}

fn main() i32 {
    let b = mut Box[i32].{ value: 1024 };
    let val = b.&.get_val();
    let f = mut File.{ fd: 42 };
    let reader_obj = f.& as mut Reader; 
    let fd_val = read_data(reader_obj);
    printf("Result: %d\n\0" as *u8, val + fd_val);
    0
}