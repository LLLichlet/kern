extern {
    fn printf(format: *u8, ...) i32;
}
type Shape = trait {
    area: fn(Self) i32,
    scale: fn(Self, i32) void,
    id: fn(Self) i32,
};
type Rectangle = struct {
    width: i32,
    height: i32,
    shape_id: i32,
};
impl *mut Rectangle : Shape {
    pub fn area() i32 {
        return self.width * self.height;
    }
    pub fn scale(factor: i32) void {
        self.width *= factor;
        self.height *= factor;
    }
    pub fn id() i32 {
        return self.shape_id;
    }
}
fn process_shape(s: mut Shape) void {
    let id = s.id();           
    let initial_area = s.area(); 
    printf("[Shape %d] Initial Area: %d\n\0" as *u8, id, initial_area);
    s.scale(2);               
    let new_area = s.area();  
    printf("[Shape %d] Scaled Area: %d\n\0" as *u8, id, new_area);
}
fn process_slice(data: []i32) void {
    let len = #data; 
    printf("Slice length: %d\n\0" as *u8, len as i32);
    printf("First element: %d, Second element: %d\n\0" as *u8, data.[0], data.[1]);
}
fn main() i32 {
    printf("--- Kern Test 4: Advanced Polymorphism & Slices ---\n\n\0" as *u8);
    let rect = mut Rectangle.{ width: 10, height: 5, shape_id: 1001 };
    let shape_obj = rect.& as mut Shape;
    process_shape(shape_obj);
    printf("\n\0" as *u8);
    let arr = mut [3]i32.{ 42, 84, 126 };
    process_slice(arr);
    printf("\nAll tests completed successfully!\n\0" as *u8);
    0
}