// test5.kn
extern {
    fn printf(format: *u8, ...) i32;
}

type Point[T] = struct {
    x: T,
    y: T,
};

// 泛型函数
fn swap[T](a: *mut T, b: *mut T) void {
    let temp = a.*;
    a.* = b.*;
    b.* = temp;
}

fn main() i32 {
    printf("--- Kern Test 5: Generics ---\n\0" as *u8);
    
    // 测试 1: i32 类型的结构体和单态化
    let p_int = mut Point[i32].{x: 10, y: 20};
    printf("Int Point: x=%d, y=%d\n\0" as *u8, p_int.x, p_int.y);
    
    swap[i32](p_int.x.&, p_int.y.&);
    printf("Swapped Int: x=%d, y=%d\n\0" as *u8, p_int.x, p_int.y);

    // 测试 2: f64 类型的结构体和单态化
    let p_float = mut Point[f64].{x: 3.14, y: 2.71};
    printf("Float Point: x=%f, y=%f\n\0" as *u8, p_float.x, p_float.y);

    swap[f64](p_float.x.&, p_float.y.&);
    printf("Swapped Float: x=%f, y=%f\n\n\0" as *u8, p_float.x, p_float.y);
    
    0
}