// test6.kn
extern {
    fn printf(format: *u8, ...) i32;
}

type Color: u8 = enum {
    Red = 0,
    Green,
    Blue,
};

type Value = union {
    as_int: i32,
    as_float: f32,
};

fn process_color(c: Color) i32 {
    // 测试 Switch 作为表达式返回，并且枚举必须穷尽 (无 else)
    return switch (c) {
        // 使用kern省略语法
        .Red => 100, // Red
        .Green => 200, // Green
        .Blue => 300, // Blue
    };
}

fn main() i32 {
    printf("--- Kern Test 6: Enums, Unions & Switch ---\n\0" as *u8);
    
    let c = Color.Green;
    let score = process_color(c);
    printf("Color Score: %d\n\0" as *u8, score);

    // 测试 Union 内存写入与读取 (reinterpret)
    let val = mut Value.{ as_int: 0x4048F5C3 }; // Pi in IEEE 754 f32
    printf("Union as Int: 0x%X\n\0" as *u8, val.as_int);
    let float_val = @floatCast[f32, f64](val.as_float);
    printf("Union as Float: %f\n\n\0" as *u8, float_val);
    0
}