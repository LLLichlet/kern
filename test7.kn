// test7.kn
extern {
    fn printf(format: *u8, ...) i32;
}

static global_state = mut i32.{0};

fn manipulate_state() usize {
    let result = {
        global_state = 1;
        
        defer {
            printf("Defer 2 executing. State was: %d\n\0" as *u8, global_state);
            global_state += 10;
        };
        
        defer {
            printf("Defer 1 executing. State was: %d\n\0" as *u8, global_state);
            global_state += 2;
        };
        
        // 块表达式的值，应该在计算时立即求出，不受后面 defer 修改的影响
        if (global_state == 1) 42 else 99
    };
    
    return result;
}

fn main() i32 {
    printf("--- Kern Test 7: Defer & Block Eval ---\n\0" as *u8);
    
    let val = manipulate_state();
    
    printf("Block Return Value: %zu (Expected: 42)\n\0" as *u8, val);
    printf("Final Global State: %d (Expected: 13)\n\n\0" as *u8, global_state);
    
    0
}