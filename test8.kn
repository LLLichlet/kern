extern {
    fn printf(fmt: *u8, ...) i32;
}
pub type Option[T] = adt {
    Some: T,
    None,
};
pub type Result[T, E] = adt {
    Ok: T,
    Err: E,
};
pub type ASTNode = adt {
    Integer: i32,
    Boolean: bool,
    Empty,
};
fn safe_divide(a: i32, b: i32) Result[i32, i32] {
    if (b == 0) {
        return Result[i32, i32].{ Err: -1 }; 
    }
    Result[i32, i32].{ Ok: a / b }
}
pub fn main() i32 {
    printf("--- Kern ADT & Match Test Suite ---\n\0" as *u8);
    // 无负载变体的初始化与匹配
    let opt_none = Option[i32].{ None };
    match (opt_none) {
        .Some: val => {
            printf("Error: Expected None, got Some\n\0" as *u8);
        },
        .None => {
            printf("Test A Passed: Option is None\n\0" as *u8);
        },
    };
    // 有负载变体的解包
    let opt_some = Option[i32].{ Some: 42 };
    match (opt_some) {
        .Some: val => {
            printf("Test B Passed: Option contains value %d\n\0" as *u8, val);
        },
        .None => {
            printf("Error: Expected Some, got None\n\0" as *u8);
        },
    };
    // match 作为表达式返回值 
    let res_ok = safe_divide(10, 2);
    let ans1 = match (res_ok) {
        .Ok: val => val,
        .Err: code => code,
    };
    printf("Test C Passed: 10 / 2 = %d\n\0" as *u8, ans1);
    // 错误处理
    let res_err = safe_divide(10, 0);
    let ans2 = match (res_err) {
        .Ok: val => val,
        .Err: code => {
            printf("Test D Passed: Division failed, caught error code %d. Using fallback 0.\n\0" as *u8, code);
            0 
        },
    };
    // 穷尽性与 else 兜底
    let node = ASTNode.{ Integer: 99 };
    match (node) {
        ASTNode.Boolean: b => {
            printf("Error: Expected Integer\n\0" as *u8);
        },
        else => {
            printf("Test E Passed: Hit the catch-all `else` branch\n\0" as *u8);
        },
    };
    printf("--- All Tests Executed ---\n\0" as *u8);
    0
}