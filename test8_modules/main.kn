extern {
    fn printf(format: *u8, ...) i32;
}

// 导入整个模块（通过 init.kn）
use .math;
// 直接导入某个文件模块中的特定项
use .utils.print_point;

fn main() i32 {
    printf("--- Kern Test 8: Modules & Visibility ---\n\0" as *u8);
    
    // 1. 测试跨模块的 re-export 调用
    let p = mut math.Point.{ x: 0, y: 0 };
    p = math.new_point(10, 20);
    
    // 2. 测试直接导入的函数调用
    print_point(p.x, p.y);
    
    // 3. 测试同模块下的普通调用
    let sum = math.add(p.x, p.y);
    printf("Sum of coordinates: %d\n\n\0" as *u8, sum);

    // sizeof 测试
    let size = @sizeof[math.Point]();
    printf("Size of point: %d\n\0" as *u8, size);

    // Cast 测试
    let small = mut u8.{255};
    let big = @intCast[u8, i32](small);
    printf("Big: %d\n\0" as *u8, big);
    
    0
}