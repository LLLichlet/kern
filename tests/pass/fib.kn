// compile-flags: --link-libc
// expected-stdout: Hello World from Kern 0.3.9227465!

extern {
    fn printf(format: *u8, ...) i32;
}

fn fib(src: i64) i64 {
    if (src < 2) return src;
    return fib(src - 1) + fib(src - 2);
}

fn main(argc: i32, argv: *mut u8) i32 {
    let a = fib(35);
    let _ = printf("Hello World from Kern %d.%d.%d!\n\0".[0].&, i32.{0}, i32.{3}, a);
    return 0;
}