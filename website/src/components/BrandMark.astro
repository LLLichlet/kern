---
import { loadBrandSvg } from "@/lib/brand";

interface Props {
  class?: string;
  title?: string;
}

const { class: className = "h-7 w-auto", title = "Kern" } = Astro.props;
const rootLogo = loadBrandSvg();
const inlineLogo = rootLogo.replace(
  "<svg ",
  `<svg class="${className}" role="img" aria-label="${title}" `
);
---

<Fragment set:html={inlineLogo} />
