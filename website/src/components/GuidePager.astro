---
import { internalHref } from "@/lib/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  previous?: CollectionEntry<"guide">;
  next?: CollectionEntry<"guide">;
}

const { previous, next } = Astro.props;
---

<nav class="guide-pager" aria-label="Guide chapter navigation">
  {
    previous ? (
      <a class="guide-pager-link" href={internalHref(`/guide/${previous.id}/`)}>
        <div class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--kern-steel)]">Previous</div>
        <div class="mt-2 text-2xl text-[color:var(--kern-ink)]">{previous.data.title}</div>
      </a>
    ) : (
      <div></div>
    )
  }
  {
    next ? (
      <a class="guide-pager-link text-right" href={internalHref(`/guide/${next.id}/`)}>
        <div class="text-xs font-semibold uppercase tracking-[0.14em] text-[color:var(--kern-steel)]">Next</div>
        <div class="mt-2 text-2xl text-[color:var(--kern-ink)]">{next.data.title}</div>
      </a>
    ) : null
  }
</nav>
