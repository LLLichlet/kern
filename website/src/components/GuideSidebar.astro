---
import { internalHref } from "@/lib/site";
import type { CollectionEntry } from "astro:content";

interface Props {
  entries: CollectionEntry<"guide">[];
  currentId?: string;
}

const { entries, currentId } = Astro.props;
---

<aside class="guide-map card-surface rounded-lg p-5 md:p-6">
  <div class="flex items-center justify-between gap-4">
    <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">
      Guide Map
    </div>
    <div class="text-[11px] tracking-[0.12em] text-[color:var(--kern-text-soft)]">
      {entries.length} chapters
    </div>
  </div>
  <nav class="mt-5 flex flex-col gap-2">
    {
      entries.map((entry) => {
        const isActive = entry.id === currentId;
        return (
          <a
            class:list={[
              "rounded-md px-4 py-3 transition",
              isActive
                ? "bg-[color:var(--kern-soft)] text-[color:var(--kern-steel)]"
                : "text-[color:var(--kern-text-muted)] hover:bg-[color:var(--kern-soft)] hover:text-[color:var(--kern-steel-strong)]"
            ]}
            href={internalHref(`/guide/${entry.id}/`)}
          >
            <div class="text-xs font-semibold uppercase tracking-[0.14em] opacity-70">
              Chapter {entry.data.order}
            </div>
            <div class="mt-1 text-base font-semibold">{entry.data.title}</div>
          </a>
        );
      })
    }
  </nav>
</aside>
