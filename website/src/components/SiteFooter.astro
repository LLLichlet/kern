---
import BrandMark from "@/components/BrandMark.astro";
import { siteMeta } from "@/lib/site";
---

<footer class="mt-16 border-t border-[color:var(--kern-line)] bg-[color:var(--kern-panel)]">
  <div class="mx-auto grid max-w-6xl gap-8 px-5 py-12 text-sm text-[color:rgba(21,26,32,0.72)] md:grid-cols-[1.4fr_1fr] md:px-8">
    <div class="flex gap-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-[color:var(--kern-line)] bg-white">
        <BrandMark class="h-6 w-auto" />
      </div>
      <div>
        <div class="text-base font-semibold text-[color:var(--kern-ink)]">{siteMeta.title}</div>
        <p class="mt-2 max-w-xl">
        Kern is a systems programming language for kernels, firmware, and
        performance-critical infrastructure. The repository `docs/` remain the
        current authoritative reference while the website guide grows.
        </p>
      </div>
    </div>
    <div class="grid gap-2 md:justify-self-end">
      <div class="font-semibold text-[color:var(--kern-ink)]">Links</div>
      <a class="transition hover:text-[color:var(--kern-steel)]" href="/install">Install</a>
      <a class="transition hover:text-[color:var(--kern-steel)]" href="/guide">Guide</a>
      <a class="transition hover:text-[color:var(--kern-steel)]" href="/reference">Reference</a>
      <a class="transition hover:text-[color:var(--kern-steel)]" href={siteMeta.repoUrl} target="_blank" rel="noreferrer">
        GitHub Repository
      </a>
    </div>
  </div>
</footer>
