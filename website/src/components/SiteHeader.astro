---
import BrandMark from "@/components/BrandMark.astro";
import { internalHref, navItems, siteMeta } from "@/lib/site";
---

<header class="border-b border-[color:var(--kern-line)] bg-[rgba(243,245,247,0.96)]">
  <div class="mx-auto max-w-6xl px-5 py-4 md:px-8">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <a class="flex items-center gap-3" href={internalHref("/")}>
      <div class="flex h-11 w-11 items-center justify-center rounded-md border border-[color:var(--kern-line)] bg-white">
        <BrandMark class="h-7 w-auto" />
      </div>
      <div>
        <div class="text-lg font-semibold tracking-[-0.03em] text-[color:var(--kern-ink)]">
          {siteMeta.shortTitle}
        </div>
        <div class="text-[11px] uppercase tracking-[0.16em] text-[color:rgba(17,21,26,0.58)]">
          systems programming language
        </div>
      </div>
    </a>

    <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-[color:rgba(17,21,26,0.76)]">
      {
        navItems.map((item) => (
          <a
            class="transition hover:text-[color:var(--kern-steel-strong)]"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
      <a
        class="font-semibold text-[color:var(--kern-steel)] transition hover:text-[color:var(--kern-steel-strong)] md:ml-2"
        href={siteMeta.repoUrl}
        target="_blank"
        rel="noreferrer"
      >
        GitHub
      </a>
    </nav>
    </div>
  </div>
</header>
