---
import SiteFooter from "@/components/SiteFooter.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { loadBrandSvg } from "@/lib/brand";
import "@/styles/global.css";
import { siteMeta } from "@/lib/site";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = siteMeta.description } = Astro.props;
const pageTitle = title ? `${title} | ${siteMeta.title}` : siteMeta.title;
const faviconSvg = loadBrandSvg();
const faviconHref = `data:image/svg+xml,${encodeURIComponent(faviconSvg)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#354a5e" />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
