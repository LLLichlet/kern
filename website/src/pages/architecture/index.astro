---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { architectureLayers } from "@/lib/site";
---

<BaseLayout title="Architecture" description="Compiler pipeline overview for the current Kern implementation.">
  <section class="manual-page mx-auto px-5 pb-20 pt-14 md:px-8 md:pt-18">
    <div class="eyebrow">Architecture</div>
    <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
      Architecture
    </h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
      This page outlines the current implementation layers: frontend, analysis,
      lowering, MIR, backend, and the surrounding tooling.
    </p>

    <section class="manual-section">
      <h2>Implementation layers</h2>
      <div class="manual-directory mt-6">
      {
        architectureLayers.map((layer) => (
          <div class="manual-directory-item">
            <div class="manual-directory-heading">
              <div class="manual-directory-title">{layer.title}</div>
              <div class="manual-directory-meta">Layer</div>
            </div>
            <div class="manual-directory-body">{layer.body}</div>
          </div>
        ))
      }
      </div>
    </section>

    <section class="manual-section">
      <h2>Current pipeline</h2>
      <pre class="doc-code"><code>{`source
  -> lexer/parser -> AST
  -> semantic analysis
  -> Flow analysis
  -> MAST lowering
  -> MIR construction and optimization
  -> LLVM IR / object emission / linking`}</code></pre>
    </section>
  </section>
</BaseLayout>
