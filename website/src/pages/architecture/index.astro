---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { architectureLayers } from "@/lib/site";
---

<BaseLayout title="Architecture" description="Compiler pipeline overview for the current Kern implementation.">
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Architecture</div>
      <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        Architecture
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        This page outlines the current implementation layers: frontend, analysis,
        lowering, MIR, backend, and the surrounding tooling.
      </p>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Layers</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Implementation layers</h2>
    </div>
    <div class="dense-link-list mt-8">
      {
        architectureLayers.map((layer) => (
          <div class="dense-link-item">
            <div class="dense-link-title">{layer.title}</div>
            <p class="dense-link-summary">{layer.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Pipeline</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Current pipeline</h2>
    </div>
    <pre class="doc-code mt-8"><code>{`source
  -> lexer/parser -> AST
  -> semantic analysis
  -> flow analysis
  -> MAST lowering
  -> MIR construction and optimization
  -> LLVM IR / object emission / linking`}</code></pre>
  </section>
</BaseLayout>
