---
import QuickJumpPanel from "@/components/QuickJumpPanel.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { internalHref, siteMeta } from "@/lib/site";

const quickJumps = [
  {
    kicker: "Local",
    title: "Build the host tools for repository work",
    href: "/build-from-source",
    summary: "A normal local Cargo build is for contribution, debugging, and host-specific recovery."
  },
  {
    kicker: "Release",
    title: "Understand why local builds are not release archives",
    href: "/sdk",
    summary: "Official SDKs still go through packaging scripts, target policy, and archive verification."
  },
  {
    kicker: "Install",
    title: "Use the installer when you just want the toolchain",
    href: "/install",
    summary: "Use the release archive when you want the installed toolchain rather than a repository build."
  },
  {
    kicker: "Editor",
    title: "Use the source build for `kern-lsp` and extension work",
    href: "/tooling/editor-setup",
    summary: "Repository-local editor integration depends on local `kern-lsp` outputs."
  }
];

const localBuild = `git clone https://github.com/softfault/kern.git
cd kern
cargo build --release`;

const windowsRelease = `cargo build --release --target x86_64-pc-windows-msvc -p kernc_cli --bin kernc
cargo build --release --target x86_64-pc-windows-msvc -p craft
cargo build --release --target x86_64-pc-windows-msvc -p kern-lsp

py -3 -m ops release package --version v0.7.1 --target x86_64-windows-msvc`;

const unixRelease = `python3 -m ops release package --version v0.7.1 --target x86_64-linux-gnu
python3 -m ops release package --version v0.7.1 --target x86_64-apple-darwin
python3 -m ops release package --version v0.7.1 --target aarch64-apple-darwin`;
---

<BaseLayout
  title="Build From Source"
  description="Build Kern from source for local development, and understand how that differs from release-quality packaging."
>
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Build From Source</div>
      <h1 class="mt-6 max-w-5xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        Source builds are for local development, contribution, and host-specific recovery.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        Build from source when the release archive is not the right fit for your machine, or when you are
        actively working on Kern itself. Keep one distinction explicit: a normal local build is not the same
        thing as a release-quality packaged SDK.
      </p>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <QuickJumpPanel
      title="Pick the source-build scenario first"
      summary="These paths separate local development builds from release packaging, installation, and editor integration."
      items={quickJumps}
    />
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Local</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Normal repository build</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        The shortest local path is still the repository root plus Cargo. You need a current stable Rust toolchain
        and the host LLVM development libraries available on your machine.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
      <pre class="doc-code"><code>{localBuild}</code></pre>
      <div class="dense-link-list">
        <div class="dense-link-item">
          <div class="dense-link-title">What you get</div>
          <p class="dense-link-summary">Host-facing tools under `target/release/`, including `kernc`, `craft`, and `kern-lsp`.</p>
        </div>
        <div class="dense-link-item">
          <div class="dense-link-title">What it is for</div>
          <p class="dense-link-summary">Contribution, debugging, toolchain development, and recovery on a host where the release baseline is not appropriate.</p>
        </div>
        <div class="dense-link-item">
          <div class="dense-link-title">What it is not</div>
          <p class="dense-link-summary">It is not automatically the same thing as the official packaged SDK layout or release verification path.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">When</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">When a source build is the right answer</h2>
    </div>
    <ul class="doc-bullet-columns mt-8">
      <li>Your Unix machine is older than the official release archive's libc baseline.</li>
      <li>You are changing compiler, `craft`, or `kern-lsp` code locally.</li>
      <li>You want to debug the repository build and test flow directly.</li>
      <li>You want to stage local binaries for editor or packaging work without waiting for a formal release.</li>
    </ul>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Release</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Release-quality packaging still goes through repository scripts</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        Official archives are not just copied local binaries. The packaging path carries target naming,
        platform policy, and archive layout decisions that are part of the release contract.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-2">
      <div>
        <h3 class="text-2xl text-[color:var(--kern-ink)]">Windows release path</h3>
        <p class="mt-4 text-base leading-8 text-[color:var(--kern-text-muted)]">
          Windows uses the real Cargo target triple `x86_64-pc-windows-msvc`, but the release artifact label is `x86_64-windows-msvc`.
          The packaging path is authoritative because it handles that mapping and static CRT policy explicitly.
        </p>
        <pre class="doc-code mt-6"><code>{windowsRelease}</code></pre>
      </div>
      <div>
        <h3 class="text-2xl text-[color:var(--kern-ink)]">Unix release path</h3>
        <p class="mt-4 text-base leading-8 text-[color:var(--kern-text-muted)]">
          Unix archives also go through the packaging path rather than treating a plain local build as a shippable SDK.
          These archive labels are bounded host release identities, not a universal cross-host compatibility claim.
        </p>
        <pre class="doc-code mt-6"><code>{unixRelease}</code></pre>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Next</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Where to go after the tools build</h2>
    </div>
    <div class="dense-link-list mt-8">
      <a class="dense-link-item" href={internalHref("/guide/getting-started/")}>
        <div class="dense-link-title">Open Getting Started</div>
        <p class="dense-link-summary">Start using the built tools in a normal package workflow.</p>
      </a>
      <a class="dense-link-item" href={internalHref("/sdk")}>
        <div class="dense-link-title">Read the SDK layout page</div>
        <p class="dense-link-summary">Understand how release artifacts are structured and why source builds are a different contract.</p>
      </a>
      <a class="dense-link-item" href={internalHref("/tooling/editor-setup")}>
        <div class="dense-link-title">Configure the editor</div>
        <p class="dense-link-summary">Use the local `kern-lsp` outputs for repository-local editor integration.</p>
      </a>
      <a class="dense-link-item" href={`${siteMeta.repoUrl}/blob/main/docs/windows-distribution.md`} target="_blank" rel="noreferrer">
        <div class="dense-link-title">Windows distribution policy</div>
        <p class="dense-link-summary">Release-policy detail that still lives in the repository docs.</p>
      </a>
      <a class="dense-link-item" href={`${siteMeta.repoUrl}/blob/main/docs/unix-distribution.md`} target="_blank" rel="noreferrer">
        <div class="dense-link-title">Unix distribution policy</div>
        <p class="dense-link-summary">Unix release and archive policy detail for maintainers.</p>
      </a>
    </div>
  </section>
</BaseLayout>
