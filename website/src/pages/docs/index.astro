---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { authoritativeDocs, maintainerDocs, siteMeta } from "@/lib/site";
---

<BaseLayout title="Docs" description="Repository-native design and maintainer documents for Kern.">
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Repository Docs</div>
      <h1 class="mt-6 text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        Repository docs
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        The website is the primary user-facing documentation for `craft` and `kernc`.
        This page collects repository-native design documents and maintainer notes
        that still matter when you need implementation detail.
      </p>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Design</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Core design docs</h2>
    </div>
    <div class="dense-link-list mt-8">
      {
        authoritativeDocs.map((doc) => (
          <a class="dense-link-item" href={doc.href} target="_blank" rel="noreferrer">
            <div class="dense-link-title">{doc.title}</div>
            <p class="dense-link-summary">{doc.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Maintainers</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Maintainer docs</h2>
    </div>
    <div class="dense-link-list mt-8">
      {
        maintainerDocs.map((doc) => (
          <a class="dense-link-item" href={doc.href} target="_blank" rel="noreferrer">
            <div class="dense-link-title">{doc.title}</div>
            <p class="dense-link-summary">{doc.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Current Split</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">What belongs here</h2>
      <ul class="mt-5 space-y-3 text-base leading-8 text-[color:var(--kern-text-muted)]">
        <li>Use the website guide and reference pages for normal `craft` and `kernc` usage.</li>
        <li>Use repository docs for language design, runtime architecture, and maintainer internals.</li>
        <li>The goal is not to mirror every repo file, but to keep user docs and maintainer docs separate.</li>
      </ul>
      <a class="mt-6 button-primary" href={siteMeta.repoUrl} target="_blank" rel="noreferrer">
        Open repository
      </a>
    </div>
  </section>
</BaseLayout>
