---
import BaseLayout from "@/layouts/BaseLayout.astro";
import GuidePager from "@/components/GuidePager.astro";
import GuideSidebar from "@/components/GuideSidebar.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const entries = await getCollection("guide");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const guideEntries = (await getCollection("guide")).sort((left, right) => left.data.order - right.data.order);
const currentIndex = guideEntries.findIndex((candidate) => candidate.id === entry.id);
const previousEntry = currentIndex > 0 ? guideEntries[currentIndex - 1] : undefined;
const nextEntry = currentIndex >= 0 && currentIndex < guideEntries.length - 1 ? guideEntries[currentIndex + 1] : undefined;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <section class="mx-auto grid max-w-6xl gap-8 px-5 pb-20 pt-14 md:px-8 md:pt-18 lg:grid-cols-[0.8fr_1.2fr]">
    <GuideSidebar entries={guideEntries} currentId={entry.id} />

    <div>
      <a class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)] hover:text-[color:var(--kern-clay)]" href="/guide">
        Back to guide
      </a>
      <h1 class="mt-6 text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        {entry.data.title}
      </h1>
      <p class="mt-5 text-lg leading-8 text-[color:rgba(20,33,29,0.72)]">{entry.data.summary}</p>

      <article class="card-surface prose-kern mt-10 rounded-[2rem] p-7 text-[color:rgba(20,33,29,0.82)] md:p-10">
        <Content />
      </article>

      <GuidePager previous={previousEntry} next={nextEntry} />
    </div>
  </section>
</BaseLayout>
