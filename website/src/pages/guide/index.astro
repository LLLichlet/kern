---
import BaseLayout from "@/layouts/BaseLayout.astro";
import QuickJumpPanel from "@/components/QuickJumpPanel.astro";
import { internalHref } from "@/lib/site";
import { getCollection } from "astro:content";

const guideEntries = (await getCollection("guide")).sort((left, right) => left.data.order - right.data.order);
const starterEntries = guideEntries.filter((entry) => entry.data.order <= 4);
const coreEntries = guideEntries.filter((entry) => entry.data.order >= 5 && entry.data.order <= 8);
const runtimeEntries = guideEntries.filter((entry) => entry.data.order >= 9 && entry.data.order <= 15);
const systemsEntries = guideEntries.filter((entry) => entry.data.order >= 16);
const toolJumpItems = [
  {
    title: "`craft` Reference",
    href: "/reference/craft",
    kicker: "Package Manager",
    summary: "Commands, workspaces, `build.rn`, features, `doc`, and freestanding package workflows."
  },
  {
    title: "`kernc` Reference",
    href: "/reference/kernc",
    kicker: "Compiler Driver",
    summary: "Direct compile, link-only, LLVM IR emission, and explicit linker/runtime flags."
  },
  {
    title: "Getting Started",
    href: "/guide/getting-started/",
    kicker: "Guide Chapter",
    summary: "Start from the smallest working package before diving into the deeper material."
  },
  {
    title: "Freestanding Guide",
    href: "/guide/freestanding-and-linking/",
    kicker: "Guide Chapter",
    summary: "Jump straight to `_start`, linker scripts, and non-hosted builds."
  }
];
---

<BaseLayout title="Guide" description="The structured learning path for Kern.">
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Guide</div>
      <h1 class="mt-6 text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        Learn Kern in a few stages, not in one endless page.
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        Treat this page as a route map. Start with the shortest path, then move
        into language, runtime, and build topics as the project demands.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href={internalHref("/guide/getting-started/")}>
          Start with Getting Started
        </a>
        <a class="button-secondary" href={internalHref("/reference/craft")}>
          Open `craft`
        </a>
        <a class="button-secondary" href={internalHref("/reference/kernc")}>
          Open `kernc`
        </a>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <QuickJumpPanel
      title="Tool References Without Backtracking"
      summary="Use the guide for pacing. Use these direct entries when you already know you need exact `craft` or `kernc` behavior."
      items={toolJumpItems}
    />
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Short Path</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Read these chapters first</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        This is the route for most users who want to get productive without reading the entire site in one pass.
      </p>
    </div>
    <ol class="doc-entry-list mt-8">
      {
        starterEntries.map((entry) => (
          <li class="doc-entry-item">
            <a class="doc-entry-link" href={internalHref(`/guide/${entry.id}/`)}>
              <div class="doc-entry-grid">
                <div>
                  <div class="doc-entry-kicker">Chapter {entry.data.order}</div>
                  <div class="doc-entry-title">{entry.data.title}</div>
                </div>
                <p class="doc-entry-summary">{entry.data.summary}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">By Topic</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Browse the guide by area</h2>
    </div>
    <div class="doc-topic-grid mt-8">
      <section>
        <div class="doc-topic-title">Language Core</div>
        <ul class="doc-topic-list">
          {
            coreEntries.map((entry) => (
              <li>
                <a href={internalHref(`/guide/${entry.id}/`)}>
                  Chapter {entry.data.order}: {entry.data.title}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <div class="doc-topic-title">Runtime And Libraries</div>
        <ul class="doc-topic-list">
          {
            runtimeEntries.map((entry) => (
              <li>
                <a href={internalHref(`/guide/${entry.id}/`)}>
                  Chapter {entry.data.order}: {entry.data.title}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section>
        <div class="doc-topic-title">Systems Topics</div>
        <ul class="doc-topic-list">
          {
            systemsEntries.map((entry) => (
              <li>
                <a href={internalHref(`/guide/${entry.id}/`)}>
                  Chapter {entry.data.order}: {entry.data.title}
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Full Index</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">All chapters</h2>
    </div>
    <div class="dense-link-list dense-link-list-columns mt-8">
      {
        guideEntries.map((entry) => (
          <a class="dense-link-item" href={internalHref(`/guide/${entry.id}/`)}>
            <div class="dense-link-title">Chapter {entry.data.order}: {entry.data.title}</div>
            <p class="dense-link-summary">{entry.data.summary}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
