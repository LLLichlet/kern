---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { authoritativeDocs, internalHref, siteMeta } from "@/lib/site";
import { getCollection } from "astro:content";

const guideEntries = (await getCollection("guide")).sort((left, right) => left.data.order - right.data.order);
const starterGuides = guideEntries.filter((entry) =>
  ["overview", "getting-started", "language-tour", "libraries-and-runtime"].includes(entry.id)
);
---

<BaseLayout title="Home">
  <section class="mx-auto max-w-6xl px-5 pb-16 pt-14 md:px-8 md:pb-24 md:pt-18">
    <div class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(20rem,0.8fr)] lg:items-start">
      <div class="rise-in">
      <div class="eyebrow">Systems Programming Language</div>
      <h1 class="mt-6 max-w-4xl text-5xl text-[color:var(--kern-ink)] md:text-7xl">
        Kern is a systems programming language for kernels, firmware, and low-level software.
      </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:rgba(21,26,32,0.78)] md:text-xl">
          {siteMeta.description} Kern keeps imports, entry points, runtime
          policy, and library boundaries explicit instead of hiding them behind
          defaults.
        </p>
        <p class="mt-4 max-w-3xl text-base leading-7 text-[color:rgba(21,26,32,0.68)]">
          Start with the guide if you want the shortest learning path. Use the
          reference when you need exact language and runtime rules. The
          repository `docs/` remain authoritative while the website grows.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="button-primary" href={internalHref("/guide")}>
            Start the guide
          </a>
          <a class="button-secondary" href={internalHref("/install")}>
            Install Kern
          </a>
          <a class="button-secondary" href={internalHref("/reference")}>
            Open reference
          </a>
          <a class="button-secondary" href={internalHref("/guide/getting-started/")}>
            Read getting started
          </a>
        </div>
      </div>

      <aside class="card-surface rise-in rounded-lg p-6 [animation-delay:120ms] md:p-7">
        <div class="border-b border-[color:var(--kern-line)] pb-3">
          <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-[color:var(--kern-steel)]">
            Validated Example
          </div>
        </div>
        <div class="mt-5 rounded-md border border-[color:rgba(255,255,255,0.08)] bg-[#10161d] p-4 text-[13px] leading-7 text-[#f4f7fb]">
          <pre class="overflow-x-auto whitespace-pre-wrap"><code>{`use std.io;

fn main() i32 {
    io.println("hello from kern", .{});
    0
}`}</code></pre>
        </div>
        <ul class="mt-5 space-y-3 text-sm leading-7 text-[color:rgba(21,26,32,0.74)]">
          <li>Imports are explicit.</li>
          <li>`main` keeps an explicit low-level signature.</li>
          <li>`std.io` is a normal module, not a hidden prelude.</li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-14 md:px-8 md:pb-20">
    <div class="mb-8">
      <div class="eyebrow">Language</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Language overview</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <article class="card-surface rounded-lg p-6">
        <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">Explicit source</div>
        <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">
          Imports, entry signatures, and data layout stay visible in source instead of being implied by hidden runtime rules.
        </p>
      </article>
      <article class="card-surface rounded-lg p-6">
        <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">Freestanding first</div>
        <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">
          `sys` and the Kern runtime model come first. libc is available when you want it, not as the mandatory base layer.
        </p>
      </article>
      <article class="card-surface rounded-lg p-6">
        <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">Low-level interop</div>
        <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">
          ABI control, pointers, inline assembly, and C interop are part of the language surface rather than side channels around it.
        </p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-14 md:px-8 md:pb-20">
    <div class="mb-8">
      <div class="eyebrow">Start Here</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Start here</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      <a class="card-surface rounded-lg p-6 transition hover:border-[color:var(--kern-line-strong)]" href={internalHref("/guide/getting-started/")}>
        <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">Guide</div>
        <h3 class="mt-4 text-2xl text-[color:var(--kern-ink)]">Getting Started</h3>
        <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">
          Build and run a minimal package with the current toolchain and see the smallest valid project shape.
        </p>
      </a>
      <a class="card-surface rounded-lg p-6 transition hover:border-[color:var(--kern-line-strong)]" href={internalHref("/guide/language-tour/")}>
        <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">Guide</div>
        <h3 class="mt-4 text-2xl text-[color:var(--kern-ink)]">Language Tour</h3>
        <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">
          Read a first validated pass through real Kern source before dropping into the full design reference.
        </p>
      </a>
      <a class="card-surface rounded-lg p-6 transition hover:border-[color:var(--kern-line-strong)]" href={internalHref("/reference/language")}>
        <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">Reference</div>
        <h3 class="mt-4 text-2xl text-[color:var(--kern-ink)]">Language Reference</h3>
        <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">
          Go straight to the current language rules, syntax, intrinsics, traits, and compile-time behavior.
        </p>
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-14 md:px-8 md:pb-20">
    <div class="mb-8 flex items-end justify-between gap-6">
      <div>
        <div class="eyebrow">Guide</div>
        <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Guide chapters</h2>
      </div>
      <a class="hidden text-sm font-semibold text-[color:var(--kern-steel)] hover:text-[color:var(--kern-steel-strong)] md:inline-flex" href={internalHref("/guide")}>
        Open guide index
      </a>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {
        starterGuides.map((entry) => (
          <a class="card-surface rounded-lg p-6 transition hover:border-[color:var(--kern-line-strong)]" href={`/guide/${entry.id}/`}>
            <div class="text-xs font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-steel)]">
              Chapter {entry.data.order}
            </div>
            <h3 class="mt-4 text-2xl text-[color:var(--kern-ink)]">{entry.data.title}</h3>
            <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">{entry.data.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-20 md:px-8 md:pb-28">
    <div class="mb-8">
      <div class="eyebrow">Current authority</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Current authoritative documents</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        authoritativeDocs.slice(0, 3).map((doc) => (
          <a
            class="card-surface rounded-lg p-6 transition hover:border-[color:var(--kern-line-strong)]"
            href={doc.href}
            target="_blank"
            rel="noreferrer"
          >
            <h3 class="text-2xl text-[color:var(--kern-ink)]">{doc.title}</h3>
            <p class="mt-4 text-base leading-8 text-[color:rgba(21,26,32,0.72)]">{doc.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
