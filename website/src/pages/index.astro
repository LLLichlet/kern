---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { authoritativeDocs, internalHref, siteMeta } from "@/lib/site";

const entryPaths = [
  {
    kicker: "Guide",
    title: "Start with a package and `craft`",
    href: "/guide/getting-started/",
    summary: "The shortest path to a real working project, then outward into the rest of the toolchain."
  },
  {
    kicker: "Reference",
    title: "Read `craft` when you need exact package behavior",
    href: "/reference/craft",
    summary: "Commands, workspaces, `build.rn`, features, `doc`, and freestanding package workflows."
  },
  {
    kicker: "Reference",
    title: "Read `kernc` when you need exact driver behavior",
    href: "/reference/kernc",
    summary: "Direct compilation, LLVM emission, link-only mode, freestanding builds, and linker flags."
  },
  {
    kicker: "Guide",
    title: "Jump straight to freestanding and `_start`",
    href: "/guide/freestanding-and-linking/",
    summary: "For kernels, boot stages, and any setup that does not want hosted `main`."
  }
];

const languagePillars = [
  "Imports, entry signatures, runtime policy, and library boundaries stay visible in source.",
  "Hosted and freestanding are explicit toolchain choices, not hidden assumptions.",
  "ABI control, pointers, inline assembly, and C interop are part of the language surface."
];

const toolDocs = [
  {
    name: "`craft`",
    href: "/reference/craft",
    summary: "Package manager and build orchestrator for manifests, workspaces, lockfiles, and target execution."
  },
  {
    name: "`kernc`",
    href: "/reference/kernc",
    summary: "Compiler and linker driver for one explicit compile or link action."
  }
];

const commandFlow = `craft check
craft build
craft run`;

const helloExample = `use std.io;

fn main() i32 {
    io.println("hello from kern", .{});
    0
}`;
---

<BaseLayout title="Home">
  <section class="doc-shell doc-hero-shell">
    <div class="doc-hero-main rise-in">
      <div class="eyebrow">Systems Programming Language</div>
      <h1 class="mt-6 max-w-5xl text-5xl text-[color:var(--kern-ink)] md:text-7xl">
        Kern is a systems programming language for kernels, firmware, and low-level software.
      </h1>
      <p class="mt-6 max-w-3xl text-xl leading-9 text-[color:var(--kern-text-muted)]">
        {siteMeta.description} Kern keeps imports, entry points, runtime policy,
        and library boundaries explicit instead of hiding them behind defaults.
      </p>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-soft)]">
        The guide, tool references, and repository documents are all linked from here.
        Start with the guide for a working package, or open `craft` and `kernc`
        directly when you need exact command behavior.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href={internalHref("/guide/getting-started/")}>
          Start with Getting Started
        </a>
        <a class="button-secondary" href={internalHref("/reference/craft")}>
          Open `craft`
        </a>
        <a class="button-secondary" href={internalHref("/reference/kernc")}>
          Open `kernc`
        </a>
      </div>
    </div>

    <aside class="doc-hero-rail rise-in [animation-delay:120ms]">
      <div class="doc-rail-section">
        <div class="doc-rail-kicker">Three ways in</div>
        <ol class="doc-entry-list">
          {
            entryPaths.slice(0, 3).map((item) => (
              <li class="doc-entry-item">
                <a class="doc-entry-link" href={internalHref(item.href)}>
                  <div class="doc-entry-kicker">{item.kicker}</div>
                  <div class="doc-entry-title">{item.title}</div>
                </a>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="doc-rail-section">
        <div class="doc-rail-kicker">First commands</div>
        <pre class="doc-code mt-4"><code>{commandFlow}</code></pre>
      </div>
    </aside>
  </section>

  <section class="doc-shell">
    <div class="section-lead">
      <div class="eyebrow">Language</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">What Kern emphasizes</h2>
    </div>
    <ul class="doc-bullet-columns mt-8">
      {
        languagePillars.map((item) => (
          <li>{item}</li>
        ))
      }
    </ul>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Start Here</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Read in this order</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        Begin with a short guide path, then move into the deeper language,
        runtime, compiler, or package reference as needed.
      </p>
    </div>
    <ol class="doc-entry-list mt-8">
      {
        entryPaths.map((item) => (
          <li class="doc-entry-item">
            <a class="doc-entry-link" href={internalHref(item.href)}>
              <div class="doc-entry-grid">
                <div>
                  <div class="doc-entry-kicker">{item.kicker}</div>
                  <div class="doc-entry-title">{item.title}</div>
                </div>
                <p class="doc-entry-summary">{item.summary}</p>
              </div>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Example</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">A minimal hosted program</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        Imports are explicit. `main` keeps an explicit signature. `std.io` is a normal
        module, not a hidden prelude.
      </p>
    </div>
    <pre class="doc-code mt-8"><code>{helloExample}</code></pre>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Tools</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Tool references</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        Compiler, package, runtime, and language references are collected here.
      </p>
    </div>
    <div class="tool-strip mt-8">
      {
        toolDocs.map((tool) => (
          <a class="tool-strip-item" href={internalHref(tool.href)}>
            <div class="tool-strip-name">{tool.name}</div>
            <p class="tool-strip-summary">{tool.summary}</p>
          </a>
        ))
      }
      <a class="tool-strip-item" href={internalHref("/reference")}>
        <div class="tool-strip-name">Reference Index</div>
        <p class="tool-strip-summary">One page for language, runtime, compiler, and package tracks.</p>
      </a>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Design Docs</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Core repository documents</h2>
    </div>
    <div class="dense-link-list mt-8">
      {
        authoritativeDocs.slice(0, 3).map((doc) => (
          <a class="dense-link-item" href={doc.href} target="_blank" rel="noreferrer">
            <div class="dense-link-title">{doc.title}</div>
            <p class="dense-link-summary">{doc.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
