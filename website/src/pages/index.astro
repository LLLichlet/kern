---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { authoritativeDocs, siteMeta } from "@/lib/site";
import { getCollection } from "astro:content";

const guideEntries = (await getCollection("guide")).sort((left, right) => left.data.order - right.data.order);
---

<BaseLayout title="Home">
  <section class="mx-auto max-w-6xl px-5 pb-16 pt-14 md:px-8 md:pb-24 md:pt-20">
    <div class="rise-in grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
      <div>
        <div class="eyebrow">Experimental toolchain • current docs are authoritative</div>
        <h1 class="mt-6 max-w-4xl text-5xl leading-[0.94] text-[color:var(--kern-ink)] md:text-7xl">
          A language for kernels that does not pretend hardware is someone else’s problem.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-[color:rgba(20,33,29,0.76)] md:text-xl">
          {siteMeta.description} The implementation is already split across a
          real compiler pipeline, a package manager, an LSP, and an explicit
          runtime/library model. This site is the new public layer on top of that foundation.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a class="inline-flex items-center rounded-full bg-[color:var(--kern-ink)] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[color:var(--kern-olive)]" href="/guide">
            Start the guide
          </a>
          <a class="inline-flex items-center rounded-full border border-[rgba(50,86,71,0.18)] bg-white/70 px-6 py-3 text-sm font-semibold text-[color:var(--kern-olive)] transition hover:border-[rgba(182,95,58,0.24)] hover:text-[color:var(--kern-clay)]" href="/reference">
            Open reference map
          </a>
          <a class="inline-flex items-center rounded-full border border-[rgba(50,86,71,0.18)] bg-white/70 px-6 py-3 text-sm font-semibold text-[color:var(--kern-olive)] transition hover:border-[rgba(182,95,58,0.24)] hover:text-[color:var(--kern-clay)]" href="/docs">
            Browse current docs
          </a>
        </div>
      </div>

      <div class="card-surface rise-in rounded-[2rem] p-6 [animation-delay:120ms] md:p-8">
        <div class="text-sm font-semibold uppercase tracking-[0.18em] text-[color:var(--kern-olive)]">
          Pipeline Snapshot
        </div>
        <div class="mt-5 rounded-[1.5rem] border border-[rgba(50,86,71,0.12)] bg-[linear-gradient(180deg,rgba(255,255,255,0.92),rgba(247,239,221,0.92))] p-5 text-sm leading-7 text-[color:rgba(20,33,29,0.82)]">
          <div><span class="font-semibold text-[color:var(--kern-clay)]">AST</span> via lexer/parser</div>
          <div><span class="font-semibold text-[color:var(--kern-clay)]">Semantic analysis</span> with explicit module/type resolution</div>
          <div><span class="font-semibold text-[color:var(--kern-clay)]">Flow</span> for CFG/dataflow and lowering hints</div>
          <div><span class="font-semibold text-[color:var(--kern-clay)]">MAST</span> for monomorphized lowering</div>
          <div><span class="font-semibold text-[color:var(--kern-clay)]">MIR</span> for transform-oriented optimization</div>
          <div><span class="font-semibold text-[color:var(--kern-clay)]">LLVM/codegen</span> for native artifacts and LTO</div>
        </div>
        <p class="mt-5 text-sm leading-7 text-[color:rgba(20,33,29,0.7)]">
          The public docs and the compiler now describe the same architecture.
          That alignment is what makes the site and future guide worth building on.
        </p>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-14 md:px-8 md:pb-20">
    <div class="mb-8">
      <div class="eyebrow">Site structure</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">The website now has a real top-level shape.</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <a class="card-surface rounded-[1.75rem] p-6 transition hover:-translate-y-1" href="/guide">
        <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">Guide</div>
        <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">Structured learning path with validated tutorial chapters built against the current toolchain.</p>
      </a>
      <a class="card-surface rounded-[1.75rem] p-6 transition hover:-translate-y-1" href="/reference">
        <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">Reference</div>
        <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">Map of the current authoritative language, runtime, compiler, and package references.</p>
      </a>
      <a class="card-surface rounded-[1.75rem] p-6 transition hover:-translate-y-1" href="/tooling">
        <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">Tooling</div>
        <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">`kernc`, `craft`, `kern-lsp`, and editor integration boundaries.</p>
      </a>
      <a class="card-surface rounded-[1.75rem] p-6 transition hover:-translate-y-1" href="/architecture">
        <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">Architecture</div>
        <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">Frontend, Flow, MAST, MIR, and backend pipeline overview.</p>
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-14 md:px-8 md:pb-20">
    <div class="grid gap-4 md:grid-cols-3">
      <article class="card-surface rounded-[1.75rem] p-6">
        <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">Language</div>
        <h2 class="mt-4 text-3xl text-[color:var(--kern-ink)]">Explicit by construction</h2>
        <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">
          Kern keeps mutability, pointers, module boundaries, and startup policy visible in source instead of hiding them behind default runtime assumptions.
        </p>
      </article>
      <article class="card-surface rounded-[1.75rem] p-6">
        <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">Toolchain</div>
        <h2 class="mt-4 text-3xl text-[color:var(--kern-ink)]">Compiler, package manager, LSP</h2>
        <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">
          `kernc`, `craft`, and `kern-lsp` already exist as separate products with explicit boundaries. The website should reflect that instead of flattening them into one vague "SDK" story.
        </p>
      </article>
      <article class="card-surface rounded-[1.75rem] p-6">
        <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">Docs</div>
        <h2 class="mt-4 text-3xl text-[color:var(--kern-ink)]">Reference now, guide next</h2>
        <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">
          The repository `docs/` remain the current authority. This site becomes the structured learning path and public-facing reference surface on top of them.
        </p>
      </article>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-14 md:px-8 md:pb-20">
    <div class="mb-8 flex items-end justify-between gap-6">
      <div>
        <div class="eyebrow">Guide foundation</div>
        <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Validated chapters are taking shape.</h2>
      </div>
      <a class="hidden text-sm font-semibold text-[color:var(--kern-clay)] hover:text-[color:var(--kern-olive)] md:inline-flex" href="/guide">
        Open guide index
      </a>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      {
        guideEntries.map((entry, index) => (
          <a
            class="card-surface rise-in rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:border-[rgba(182,95,58,0.22)]"
            style={`animation-delay:${index * 90}ms`}
            href={`/guide/${entry.id}/`}
          >
            <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">
              Chapter {entry.data.order}
            </div>
            <h3 class="mt-4 text-3xl text-[color:var(--kern-ink)]">{entry.data.title}</h3>
            <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.74)]">{entry.data.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-20 md:px-8 md:pb-28">
    <div class="mb-8">
      <div class="eyebrow">Current authority</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Repository documents still define the current truth.</h2>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        authoritativeDocs.map((doc) => (
          <a
            class="card-surface rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:border-[rgba(50,86,71,0.2)]"
            href={doc.href}
            target="_blank"
            rel="noreferrer"
          >
            <h3 class="text-2xl text-[color:var(--kern-ink)]">{doc.title}</h3>
            <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.72)]">{doc.description}</p>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
