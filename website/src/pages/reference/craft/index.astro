---
import QuickJumpPanel from "@/components/QuickJumpPanel.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { internalHref, siteMeta } from "@/lib/site";

const quickJumps = [
  {
    kicker: "Loop",
    title: "Run the normal package workflow",
    href: "/guide/getting-started/",
    summary: "`check`, `build`, `run`, and `test` are the normal entry points for day-to-day package work."
  },
  {
    kicker: "Scripts",
    title: "Use `build.rn` for generated files and linker setup",
    href: "/guide/build-scripts-and-generated-sources/",
    summary: "Keep dependency identity in `Craft.toml`, then use `build.rn` for staged sources, native inputs, and package-local build wiring."
  },
  {
    kicker: "Freestanding",
    title: "Package a kernel or `_start` binary",
    href: "/guide/freestanding-and-linking/",
    summary: "Use `entry = \"none\"`, keep `libc = false`, and attach the linker script through `b.link_script(...)`."
  },
  {
    kicker: "Boundary",
    title: "Drop to `kernc` for one explicit driver action",
    href: "/reference/kernc",
    summary: "Use `kernc` when you want one exact compile, emit, or link command without package planning."
  }
];

const commandLoop = `craft check
craft build
craft run
craft test`;

const packageShape = `hello/
  Craft.toml
  src/
    main.rn`;

const manifestExample = `[package]
name = "hello"
version = "0.1.0"
kern = "0.7.0"

[runtime]
entry = "rt"
libc = false
bundle = "std"

[[bin]]
name = "hello"
root = "src/main.rn"`;

const optionsExample = `--project-path path/to/pkg-or-workspace
--profile release
--examples
--bin app
--example demo
--features tls,simd
--no-default-features
--root /tmp/install-root
--verbose
--timings`;

const buildScriptExample = `use craft.builder;

pub fn build(b: *mut builder.Builder) void {
    let path = b.copy_package_file("templates/main.rn", "src/main.rn");
    b.set_source_root(path);
}`;

const freestandingManifest = `[runtime]
entry = "none"
libc = false
bundle = "base"`;

const freestandingEntry = `#[export_name("_start")]
fn kmain() void {
    for (;;) {}
    @unreachable();
}`;

const linkScriptExample = `use craft.builder;

pub fn build(b: *mut builder.Builder) void {
    b.link_script("kernel.ld");
}`;
---

<BaseLayout
  title="craft Reference"
  description="User-facing reference for craft: commands, target selection, features, lockfiles, build scripts, and freestanding package workflows."
>
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Package Manager</div>
      <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        `craft`
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        `craft` owns package discovery, workspaces, dependency resolution,
        `Craft.lock`, target selection, `build.rn`, and target execution.
        If the question is which package graph or target set should be built,
        this is the tool layer that answers it.
      </p>
      <div class="mt-8 max-w-3xl border-y border-[color:var(--kern-line)] py-5 text-sm leading-7 text-[color:var(--kern-text-muted)]">
        The commands on this page were checked against the current toolchain while writing the docs.
        `craft doc` still requires at least one library target that emits package metadata, and freestanding linker
        scripts should use `b.link_script(...)` instead of raw `-T` path pairs.
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <QuickJumpPanel
      title="Start from the task, not from the whole command surface"
      summary="These four paths cover package workflows, build scripts, freestanding packages, and the direct-driver boundary."
      items={quickJumps}
    />
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Shape</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">A package is explicit on disk</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        `craft` reads `Craft.toml`, derives the selected package graph, and then drives `kernc`
        with explicit compile and link actions. `craft.rn` can normalize planning inputs before
        resolution. `build.rn` runs after resolution and can stage generated sources, native
        files, and linker inputs.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
      <pre class="doc-code"><code>{packageShape}</code></pre>
      <pre class="doc-code"><code>{manifestExample}</code></pre>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Commands</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">The normal package loop</h2>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.7fr)_minmax(0,1.3fr)]">
      <pre class="doc-code"><code>{commandLoop}</code></pre>
      <div class="tool-strip">
        <div class="tool-strip-item">
          <div class="tool-strip-name">`craft check`</div>
          <p class="tool-strip-summary">Validate manifests, scripts, and source analysis without doing the final link.</p>
        </div>
        <div class="tool-strip-item">
          <div class="tool-strip-name">`craft build`</div>
          <p class="tool-strip-summary">Resolve the package graph, compile the selected targets, and execute the final link steps.</p>
        </div>
        <div class="tool-strip-item">
          <div class="tool-strip-name">`craft run`</div>
          <p class="tool-strip-summary">Build one selected `bin` or `example` target and then execute it.</p>
        </div>
        <div class="tool-strip-item">
          <div class="tool-strip-name">`craft test`</div>
          <p class="tool-strip-summary">Build and run discovered test targets under the same package-planning model.</p>
        </div>
        <div class="tool-strip-item">
          <div class="tool-strip-name">`craft lock`, `fetch`, `doc`, `install`, `uninstall`</div>
          <p class="tool-strip-summary">Use these when you need deterministic resolution, cache materialization, docs, or installed binaries under an explicit root.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Selection</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Target and feature selection</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        The most important flags are the ones that change which package graph or target set is being planned.
        Use these when you want a different package root, profile, named target, or feature configuration.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
      <pre class="doc-code"><code>{optionsExample}</code></pre>
      <ul class="doc-bullet-columns">
        <li>`--project-path` can point at a package root, workspace root, or direct `Craft.toml` file.</li>
        <li>`--profile` is currently `dev` or `release`.</li>
        <li>`--bin`, `--example`, and `--examples` select which runnable targets are included.</li>
        <li>`--features` and `--no-default-features` control the feature set used during planning and analysis.</li>
        <li>`--root` only matters for `install` and `uninstall`, where it defines the destination prefix.</li>
        <li>`--verbose` and `--timings` are for inspection rather than semantics.</li>
      </ul>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Scripts</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">`build.rn` is a post-resolution boundary</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        `build.rn` runs after dependency identity has already been chosen. Use it for generated
        sources, copied files, tool outputs, native link inputs, or package-local linker wiring.
        Do not treat it as a second manifest language that changes the lockfile shape.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
      <pre class="doc-code"><code>{buildScriptExample}</code></pre>
      <div class="dense-link-list">
        <div class="dense-link-item">
          <div class="dense-link-title">What it is for</div>
          <p class="dense-link-summary">Generated sources, staged package files, native artifacts, and linker configuration that belongs to one package build.</p>
        </div>
        <div class="dense-link-item">
          <div class="dense-link-title">What it does not do</div>
          <p class="dense-link-summary">It does not rewrite dependency identity, workspace structure, or the meaning of `Craft.lock`.</p>
        </div>
        <a class="dense-link-item" href={internalHref("/guide/build-scripts-and-generated-sources/")}>
          <div class="dense-link-title">Open the build script guide</div>
          <p class="dense-link-summary">A guide-path explanation of generated files, staged inputs, and source-root replacement.</p>
        </a>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Freestanding</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Kernel and `_start` packages</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        A freestanding package should not pretend to be a hosted program. Use `entry = "none"` so
        the package owns `_start`, keep `libc = false`, and wire the linker script through the build
        API so the package root is resolved correctly.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-3">
      <pre class="doc-code"><code>{freestandingManifest}</code></pre>
      <pre class="doc-code"><code>{freestandingEntry}</code></pre>
      <pre class="doc-code"><code>{linkScriptExample}</code></pre>
    </div>
    <ul class="doc-bullet-columns mt-8">
      <li>`entry = "none"` means `craft` must not require a hosted program `main`.</li>
      <li>`bundle = "base"` keeps the library wiring aligned with freestanding bring-up.</li>
      <li>`b.link_script("kernel.ld")` resolves from the package root and emits the correct linker arguments.</li>
      <li>If you want raw linker experimentation, that is usually the point where `kernc` becomes the clearer tool.</li>
    </ul>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Boundary</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">When `craft` is the wrong layer</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        Use `craft` when packages, lockfiles, workspaces, features, or target discovery matter.
        Use `kernc` when you want one explicit compile, LLVM emission, or direct link command without
        package planning around it.
      </p>
    </div>
    <div class="dense-link-list mt-8">
      <a class="dense-link-item" href={internalHref("/reference/kernc")}>
        <div class="dense-link-title">Open the `kernc` reference</div>
        <p class="dense-link-summary">Direct driver modes, link-only actions, LLVM emission, freestanding direct builds, and raw linker flags.</p>
      </a>
      <a class="dense-link-item" href={`${siteMeta.repoUrl}/blob/main/docs/craft.md`} target="_blank" rel="noreferrer">
        <div class="dense-link-title">Open the maintainer document</div>
        <p class="dense-link-summary">Lower-level `craft` internals for toolchain contributors rather than normal package users.</p>
      </a>
    </div>
  </section>
</BaseLayout>
