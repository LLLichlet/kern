---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { referenceTracks } from "@/lib/site";
---

<BaseLayout title="Reference" description="The current reference map for Kern language, runtime, compiler, and package behavior.">
  <section class="mx-auto max-w-6xl px-5 pb-20 pt-14 md:px-8 md:pt-18">
    <div class="eyebrow">Reference</div>
    <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
      The reference surface should be explicit, not improvised.
    </h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:rgba(20,33,29,0.76)]">
      Kern already has real technical reference material in the repository. This
      page makes the reference model visible on the website before every detail
      has been migrated into website-native pages.
    </p>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      {
        referenceTracks.map((track) => (
          <a
            class="card-surface rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:border-[rgba(50,86,71,0.2)]"
            href={track.href}
            target="_blank"
            rel="noreferrer"
          >
            <h2 class="text-3xl text-[color:var(--kern-ink)]">{track.title}</h2>
            <p class="mt-4 text-base leading-8 text-[color:rgba(20,33,29,0.72)]">{track.description}</p>
          </a>
        ))
      }
    </div>

    <div class="card-surface mt-10 rounded-[2rem] p-7 md:p-8">
      <div class="text-sm font-semibold uppercase tracking-[0.16em] text-[color:var(--kern-olive)]">
        Migration rule
      </div>
      <p class="mt-5 max-w-3xl text-base leading-8 text-[color:rgba(20,33,29,0.76)]">
        Website-native reference pages should only replace repository docs when
        they become equally authoritative and are maintained with the same
        discipline. Until then, this page should point to the real source of truth
        instead of pretending the migration is already complete.
      </p>
    </div>
  </section>
</BaseLayout>
