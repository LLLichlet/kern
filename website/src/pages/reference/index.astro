---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { referenceTracks } from "@/lib/site";
---

<BaseLayout title="Reference" description="The current reference map for Kern language, runtime, compiler, and package behavior.">
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Reference</div>
      <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        Reference
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        Use this page when you want exact rules instead of tutorial pacing.
        `craft` and `kernc` are documented here as website-native user references.
        Language and runtime still link back to deeper repository design material.
      </p>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Tracks</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Reference tracks</h2>
    </div>
    <div class="dense-link-list mt-8">
      {
        referenceTracks.map((track) => (
          <div class="dense-link-item">
            <a class="dense-link-title" href={track.href}>{track.title}</a>
            <p class="dense-link-summary">{track.description}</p>
            {track.sourceHref && (
              <div class="mt-3 flex flex-wrap gap-4 text-sm text-[color:var(--kern-steel)]">
                <a href={track.sourceHref} target="_blank" rel="noreferrer">Open repository source</a>
              </div>
            )}
          </div>
        ))
      }
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Split</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">How to use this section</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        Use the website for `craft` and `kernc` workflows, commands, and normal
        day-to-day usage. Use the repository docs when you need maintainer-level
        design detail for the language core or runtime architecture.
      </p>
    </div>
  </section>
</BaseLayout>
