---
import QuickJumpPanel from "@/components/QuickJumpPanel.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { internalHref, siteMeta } from "@/lib/site";

const quickJumps = [
  {
    kicker: "Driver",
    title: "Compile and link one file directly",
    href: "/guide/getting-started/",
    summary: "Use `kernc` when you want one explicit driver action instead of package discovery."
  },
  {
    kicker: "IR",
    title: "Inspect LLVM IR",
    href: "/reference/kernc",
    summary: "Emit raw, verified, or optimized LLVM IR to inspect the backend-facing program shape."
  },
  {
    kicker: "Freestanding",
    title: "Build `_start` without hosted startup",
    href: "/guide/freestanding-and-linking/",
    summary: "Use `--runtime-entry none`, keep libc disabled, and pass the entry symbol and linker arguments explicitly."
  },
  {
    kicker: "Package",
    title: "Go back up to `craft`",
    href: "/reference/craft",
    summary: "If workspaces, lockfiles, or `build.rn` matter, the package layer is the correct abstraction."
  }
];

const driverModes = `kernc src/main.rn -o app
kernc -c src/main.rn -o app.o
kernc --emit-llvm src/main.rn
kernc --link-only --link-input app.o -o app`;

const coreFlags = `--runtime-entry none|rt|crt
--runtime-libc yes|no
--library-bundle none|base|std
--entry-symbol _start
--module-path std=./library/std
--metadata-output out/meta
--target x86_64-unknown-linux-gnu
--link-input file.o
--link-search native
--link-lib demo
--link-arg ARG
--print-link-command
--timings`;

const hostedBuild = `kernc \
  --runtime-entry rt \
  --runtime-libc no \
  --library-bundle std \
  src/main.rn \
  -o app`;

const splitBuild = `kernc -c \
  --runtime-entry rt \
  --runtime-libc no \
  --library-bundle std \
  src/main.rn \
  -o app.o

kernc --link-only \
  --runtime-entry rt \
  --runtime-libc no \
  --library-bundle std \
  --link-input app.o \
  -o app`;

const llvmBuild = `kernc --emit-llvm \
  --runtime-entry rt \
  --runtime-libc no \
  --library-bundle std \
  src/main.rn > app.ll`;

const freestandingEntry = `#[export_name("_start")]
fn kmain() void {
    for (;;) {}
    @unreachable();
}`;

const freestandingBuild = `kernc \
  --runtime-entry none \
  --runtime-libc no \
  --library-bundle base \
  --entry-symbol _start \
  src/main.rn \
  -o kernel.bin`;

const linkerScriptBuild = `kernc \
  --runtime-entry none \
  --runtime-libc no \
  --library-bundle base \
  --entry-symbol _start \
  --link-arg -T \
  --link-arg /absolute/path/to/kernel.ld \
  src/main.rn \
  -o kernel.bin`;
---

<BaseLayout
  title="kernc Reference"
  description="User-facing reference for kernc: driver modes, runtime flags, LLVM emission, direct linking, and freestanding builds."
>
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Compiler Driver</div>
      <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        `kernc`
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        `kernc` parses, checks, lowers, emits LLVM or native linker inputs, and can
        invoke the final system linker. It does not resolve packages or own lockfiles.
        Use it when you want one exact compiler-driver action.
      </p>
      <div class="mt-8 max-w-3xl border-y border-[color:var(--kern-line)] py-5 text-sm leading-7 text-[color:var(--kern-text-muted)]">
        The commands on this page were exercised while writing the docs, including hosted compile-and-link,
        compile-only plus `--link-only`, `--emit-llvm`, and freestanding direct linking with an explicit entry symbol.
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <QuickJumpPanel
      title="Choose the driver mode first"
      summary="Most confusion around `kernc` comes from mixing package concerns with driver concerns. Start from the exact action you want."
      items={quickJumps}
    />
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Modes</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Four direct driver shapes</h2>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.8fr)_minmax(0,1.2fr)]">
      <pre class="doc-code"><code>{driverModes}</code></pre>
      <div class="tool-strip">
        <div class="tool-strip-item">
          <div class="tool-strip-name">Compile and link</div>
          <p class="tool-strip-summary">The default mode compiles the source input and performs the final link in one command.</p>
        </div>
        <div class="tool-strip-item">
          <div class="tool-strip-name">Compile only</div>
          <p class="tool-strip-summary">`-c` emits a linker input artifact and stops before the final system link.</p>
        </div>
        <div class="tool-strip-item">
          <div class="tool-strip-name">Emit LLVM</div>
          <p class="tool-strip-summary">`--emit-llvm[=raw|verified|optimized]` prints IR instead of linking a program.</p>
        </div>
        <div class="tool-strip-item">
          <div class="tool-strip-name">Link only</div>
          <p class="tool-strip-summary">`--link-only` skips the frontend and codegen and invokes the linker with explicit inputs.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Flags</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Core runtime, library, and linker flags</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        The important flags are the ones that decide startup ownership, library wiring, target identity,
        and whether the final link happens under `kernc` or under another tool.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1.15fr)]">
      <pre class="doc-code"><code>{coreFlags}</code></pre>
      <ul class="doc-bullet-columns">
        <li>`--runtime-entry` controls startup ownership: `none`, `rt`, or `crt`.</li>
        <li>`--runtime-libc` controls whether libc is linked.</li>
        <li>`--library-bundle` wires the official root aliases such as `base` or `std`.</li>
        <li>`--entry-symbol` selects the final linker entry symbol when startup is not owned by `rt`.</li>
        <li>`--module-path` and `--module-interface-path` are for explicit module-root wiring in direct-driver setups.</li>
        <li>`--link-input`, `--link-search`, `--link-lib`, and `--link-arg` are raw final-link controls.</li>
      </ul>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Hosted</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Normal hosted direct builds</h2>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-3">
      <pre class="doc-code"><code>{hostedBuild}</code></pre>
      <pre class="doc-code"><code>{splitBuild}</code></pre>
      <pre class="doc-code"><code>{llvmBuild}</code></pre>
    </div>
    <ul class="doc-bullet-columns mt-8">
      <li>Use one-shot compile-and-link when you just want a binary.</li>
      <li>Split compile and link when another build system wants to stage or post-process the linker input.</li>
      <li>Use `--emit-llvm` when you need the backend-facing program form for debugging or validation.</li>
    </ul>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Freestanding</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Direct `_start` binaries</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        A freestanding direct build should say so explicitly. Disable hosted startup, keep libc off,
        choose the freestanding library bundle, and tell the final link which symbol is the entry.
      </p>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-3">
      <pre class="doc-code"><code>{freestandingEntry}</code></pre>
      <pre class="doc-code"><code>{freestandingBuild}</code></pre>
      <pre class="doc-code"><code>{linkerScriptBuild}</code></pre>
    </div>
    <div class="dense-link-list mt-8">
      <a class="dense-link-item" href={internalHref("/guide/freestanding-and-linking/")}>
        <div class="dense-link-title">Open the freestanding guide</div>
        <p class="dense-link-summary">Package-level `_start`, linker scripts, `craft` build wiring, and freestanding runtime choices.</p>
      </a>
      <a class="dense-link-item" href={internalHref("/reference/craft")}>
        <div class="dense-link-title">Use `craft` when package layout matters</div>
        <p class="dense-link-summary">Prefer `craft` plus `b.link_script(...)` when the build is already a package project rather than one raw driver command.</p>
      </a>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Maintainers</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Lower-level driver notes</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        This site documents the user-facing driver surface. Repository internals and implementation notes still live separately.
      </p>
    </div>
    <div class="dense-link-list mt-8">
      <a class="dense-link-item" href={`${siteMeta.repoUrl}/blob/main/docs/kernc.md`} target="_blank" rel="noreferrer">
        <div class="dense-link-title">Open the maintainer document</div>
        <p class="dense-link-summary">Compiler-driver internals, implementation notes, and lower-level integration details for contributors.</p>
      </a>
    </div>
  </section>
</BaseLayout>
