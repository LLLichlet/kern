---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteMeta } from "@/lib/site";
---

<BaseLayout title="Runtime And Libraries Reference" description="Current runtime and library reference for Kern: the base/sys/rt/std split, startup ownership, and libc policy.">
  <section class="manual-page mx-auto px-5 pb-20 pt-14 md:px-8 md:pt-18">
    <div class="eyebrow">Runtime And Libraries</div>
    <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
      Runtime and libraries
    </h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:rgba(21,26,32,0.76)]">
      This page describes the current `base` / `sys` / `rt` / `std` split,
      startup ownership, and libc policy.
    </p>

    <div class="manual-callout mt-10">
      <div class="manual-kicker">Layer Summary</div>
      <ul class="mt-4 space-y-2 text-base">
        <li>`base` provides runtime-independent foundation types, memory primitives, and containers.</li>
        <li>`sys` covers operating-system and provider boundaries.</li>
        <li>`rt` provides startup glue and minimal runtime support.</li>
        <li>`std` is user-facing Kern code built on `base` plus `sys`.</li>
      </ul>
    </div>

    <section class="manual-section">
      <div class="manual-grid manual-grid-2">
        <section>
          <h2 class="text-3xl text-[color:var(--kern-ink)]">Current runtime axes</h2>
          <ul class="mt-5 space-y-3 text-base">
          <li>`runtime_entry` chooses startup ownership: `none`, `rt`, or `crt`.</li>
          <li>`runtime_libc` chooses whether libc is linked.</li>
          <li>`library_bundle` chooses which official root aliases are wired: `none`, `base`, or `std`.</li>
          <li>`sys` and `rt` implementation choice stays in normal module/package wiring rather than a dedicated provider flag.</li>
          </ul>
        </section>

        <section>
          <div class="manual-kicker">Current policy</div>
          <ul class="mt-5 space-y-3 text-base">
          <li>The language itself is freestanding.</li>
          <li>`std` remains valid without libc.</li>
          <li>Hosted is an OS/process-environment concern rather than a C-language concern.</li>
          <li>Libc is an optional compatibility boundary rather than the semantic base of Kern programs.</li>
          </ul>
        </section>
      </div>
    </section>

    <section class="manual-section">
      <h2>Related guide chapters</h2>
      <div class="manual-links mt-6">
        <a class="button-primary" href="/guide/libraries-and-runtime/">
          Libraries and runtime
        </a>
        <a class="button-secondary" href="/guide/c-interop-and-libc/">
          C interop and libc
        </a>
        <a class="button-secondary" href="/guide/standard-library-tour/">
          Standard library tour
        </a>
      </div>
    </section>

    <section class="manual-section">
      <h2>Current authoritative source</h2>
      <div class="manual-links mt-6">
        <a class="button-primary" href={`${siteMeta.repoUrl}/blob/main/docs/runtime-architecture.md`} target="_blank" rel="noreferrer">
          Open runtime architecture doc
        </a>
        <a class="button-secondary" href="/reference">
          Back to reference tracks
        </a>
      </div>
    </section>
  </section>
</BaseLayout>
