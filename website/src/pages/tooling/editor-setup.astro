---
import QuickJumpPanel from "@/components/QuickJumpPanel.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { internalHref, siteMeta } from "@/lib/site";

const quickJumps = [
  {
    kicker: "Setup",
    title: "Install the toolchain first",
    href: "/install",
    summary: "Start from a working Kern install or a local source build that already produces `kern-lsp`."
  },
  {
    kicker: "Resolution",
    title: "Understand how the extension finds `kern-lsp`",
    href: "/tooling/editor-setup",
    summary: "The extension checks an explicit path, a bundled server, workspace builds, then `PATH`."
  },
  {
    kicker: "Workflow",
    title: "Refresh analysis when features or env change",
    href: "/tooling/editor-setup",
    summary: "Use the extension commands to refresh the `craft` context, restart the server, or inspect output."
  },
  {
    kicker: "Repository",
    title: "Build the extension from source",
    href: "/build-from-source",
    summary: "When you are editing the repo itself, use the workspace extension flow rather than the end-user install path."
  }
];

const settingsExample = `{
  "kern.server.path": "",
  "kern.server.args": [],
  "kern.server.env": {
    "KERN_DEV": "1"
  },
  "kern.project.features": ["experimental"],
  "kern.project.noDefaultFeatures": false
}`;

const devCommands = `cd editors/vscode
npm ci
npm run compile
npm run check
npm run test`;

const vsixCommands = `cargo build -p kern-lsp --release
cd editors/vscode
npm run stage:server
npm run package:vsix -- --target linux-x64`;
---

<BaseLayout title="Editor Setup" description="Set up VS Code and kern-lsp for a practical Kern editing workflow.">
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Editor Setup</div>
      <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        Configure the editor
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        The normal editor path is VS Code plus the first-party extension. The extension starts
        `kern-lsp` over stdio and reuses compiler analysis directly rather than maintaining a
        separate frontend.
      </p>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <QuickJumpPanel
      title="Common editor paths"
      summary="Use these entries for installation, server resolution, stale analysis, or repository-local extension work."
      items={quickJumps}
    />
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Path</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Recommended setup path</h2>
    </div>
    <ol class="mt-8 list-decimal space-y-3 pl-5 text-base leading-8 text-[color:var(--kern-text-muted)]">
      <li>Install Kern through the official installer or build it from source.</li>
      <li>Open VS Code on a Kern workspace.</li>
      <li>Install the first-party extension from `editors/vscode` or the packaged VSIX release when available.</li>
      <li>Open a `.rn` file and confirm the extension activates Kern language support.</li>
    </ol>
    <div class="dense-link-list mt-8">
      <a class="dense-link-item" href={internalHref("/install")}>
        <div class="dense-link-title">Install the toolchain</div>
        <p class="dense-link-summary">The standard setup path for `kernc`, `craft`, `kern-lsp`, and the shipped library layers.</p>
      </a>
      <a class="dense-link-item" href={internalHref("/build-from-source")}>
        <div class="dense-link-title">Build from source</div>
        <p class="dense-link-summary">Use this when you are working on the repository itself or the release archive is not the right host fit.</p>
      </a>
      <a class="dense-link-item" href={`${siteMeta.repoUrl}/tree/main/editors/vscode`} target="_blank" rel="noreferrer">
        <div class="dense-link-title">Open the extension source tree</div>
        <p class="dense-link-summary">Workspace extension source, packaging scripts, and the repository development entrypoint.</p>
      </a>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Surface</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">What the extension provides</h2>
    </div>
    <ul class="doc-bullet-columns mt-8">
      <li>Kern language registration for `.rn` files.</li>
      <li>Diagnostics, hover, completion, rename, semantic tokens, and code actions through `kern-lsp`.</li>
      <li>Commands for restarting the server, showing server output, and refreshing `craft` analysis context.</li>
      <li>Optional icon/theme assets for a consistent editor presentation.</li>
    </ul>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Resolution</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">How `kern-lsp` is resolved</h2>
      <p class="mt-4 max-w-3xl text-base leading-8 text-[color:var(--kern-text-muted)]">
        The extension resolves the language server in a deliberately practical order so repository-local
        development stays easy without breaking separately installed toolchains.
      </p>
    </div>
    <div class="dense-link-list mt-8">
      <div class="dense-link-item">
        <div class="dense-link-title">1. `kern.server.path`</div>
        <p class="dense-link-summary">If you configured an explicit server path, that wins.</p>
      </div>
      <div class="dense-link-item">
        <div class="dense-link-title">2. Bundled `kern-lsp`</div>
        <p class="dense-link-summary">A packaged extension can carry a platform-specific server inside the extension itself.</p>
      </div>
      <div class="dense-link-item">
        <div class="dense-link-title">3. Workspace build outputs</div>
        <p class="dense-link-summary">The extension checks `target/debug/kern-lsp` and `target/release/kern-lsp` in the current workspace.</p>
      </div>
      <div class="dense-link-item">
        <div class="dense-link-title">4. `PATH`</div>
        <p class="dense-link-summary">If none of the above exist, it falls back to `kern-lsp` from the ambient shell environment.</p>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Settings</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">The first settings that actually matter</h2>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)]">
      <pre class="doc-code"><code>{settingsExample}</code></pre>
      <div class="dense-link-list">
        <div class="dense-link-item">
          <div class="dense-link-title">`kern.server.path`, `kern.server.args`, `kern.server.env`</div>
          <p class="dense-link-summary">Use these when the language server path, environment, or launch flags must be controlled explicitly.</p>
        </div>
        <div class="dense-link-item">
          <div class="dense-link-title">`kern.project.features`, `kern.project.noDefaultFeatures`</div>
          <p class="dense-link-summary">These choose the feature context used by `craft`-backed analysis inside the editor.</p>
        </div>
        <div class="dense-link-item">
          <div class="dense-link-title">When analysis looks stale</div>
          <p class="dense-link-summary">Run `Kern: Refresh Craft Analysis Context`, restart the server if the path or environment changed, and inspect server output when behavior is unclear.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Repository</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Extension development and VSIX packaging</h2>
    </div>
    <div class="mt-8 grid gap-8 lg:grid-cols-2">
      <div>
        <h3 class="text-2xl text-[color:var(--kern-ink)]">Workspace development</h3>
        <p class="mt-4 text-base leading-8 text-[color:var(--kern-text-muted)]">
          If you are editing the extension itself, build it inside the repository and then launch an Extension Development Host from VS Code.
        </p>
        <pre class="doc-code mt-6"><code>{devCommands}</code></pre>
      </div>
      <div>
        <h3 class="text-2xl text-[color:var(--kern-ink)]">VSIX packaging</h3>
        <p class="mt-4 text-base leading-8 text-[color:var(--kern-text-muted)]">
          Release packaging stages a platform-specific `kern-lsp` so the published extension stays self-contained.
        </p>
        <pre class="doc-code mt-6"><code>{vsixCommands}</code></pre>
      </div>
    </div>
  </section>
</BaseLayout>
