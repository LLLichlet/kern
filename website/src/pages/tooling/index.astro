---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { internalHref, siteMeta, toolingProducts } from "@/lib/site";
---

<BaseLayout title="Tooling" description="The current Kern tooling stack: compiler, package manager, LSP, and editor integration.">
  <section class="doc-shell">
    <div class="section-lead max-w-4xl">
      <div class="eyebrow">Tooling</div>
      <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
        Tooling
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
        This page maps the current tooling surface: compiler, package manager,
        language server, and editor integration. The goal is to make the
        boundary between them easy to scan.
      </p>
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Components</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Toolchain components</h2>
    </div>
    <div class="dense-link-list mt-8">
      {
        toolingProducts.map((tool) => (
          <a
            class="dense-link-item"
            href={tool.href}
            target={tool.href.startsWith("http") ? "_blank" : undefined}
            rel={tool.href.startsWith("http") ? "noreferrer" : undefined}
          >
            <div class="dense-link-title">{tool.name}</div>
            <p class="dense-link-summary">{tool.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Common Paths</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">What users usually need next</h2>
    </div>
    <ol class="doc-entry-list mt-8">
      <li class="doc-entry-item">
        <a class="doc-entry-link" href={internalHref("/install")}>
          <div class="doc-entry-grid">
            <div>
              <div class="doc-entry-kicker">Setup</div>
              <div class="doc-entry-title">Install the toolchain</div>
            </div>
            <p class="doc-entry-summary">
              Start from the official installer path unless you are deliberately working on the repository itself.
            </p>
          </div>
        </a>
      </li>
      <li class="doc-entry-item">
        <a class="doc-entry-link" href={internalHref("/tooling/editor-setup")}>
          <div class="doc-entry-grid">
            <div>
              <div class="doc-entry-kicker">Editor</div>
              <div class="doc-entry-title">Configure the editor</div>
            </div>
            <p class="doc-entry-summary">
              Set up VS Code, understand `kern-lsp` resolution, and use the basic editor commands when analysis changes.
            </p>
          </div>
        </a>
      </li>
      <li class="doc-entry-item">
        <a class="doc-entry-link" href={internalHref("/build-from-source")}>
          <div class="doc-entry-grid">
            <div>
              <div class="doc-entry-kicker">Repository</div>
              <div class="doc-entry-title">Build the tools from source</div>
            </div>
            <p class="doc-entry-summary">
              Build local developer binaries, then keep them clearly separate from release-quality packaged SDK artifacts.
            </p>
          </div>
        </a>
      </li>
    </ol>
  </section>

  <section class="doc-shell section-divider">
    <div class="section-lead">
      <div class="eyebrow">Repository</div>
      <h2 class="mt-4 text-4xl text-[color:var(--kern-ink)]">Tooling source trees</h2>
      <div class="dense-link-list mt-8">
        <a class="dense-link-item" href={`${siteMeta.repoUrl}/tree/main/editors/vscode`} target="_blank" rel="noreferrer">
          <div class="dense-link-title">VS Code extension source</div>
          <p class="dense-link-summary">
            The first-party extension source, packaging scripts, and workspace development entrypoint.
          </p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
