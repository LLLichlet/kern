---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { internalHref, siteMeta, toolingProducts } from "@/lib/site";
---

<BaseLayout title="Tooling" description="The current Kern tooling stack: compiler, package manager, LSP, and editor integration.">
  <section class="manual-page mx-auto px-5 pb-20 pt-14 md:px-8 md:pt-18">
    <div class="eyebrow">Tooling</div>
    <h1 class="mt-6 max-w-4xl text-5xl leading-[0.95] text-[color:var(--kern-ink)] md:text-6xl">
      Tooling
    </h1>
    <p class="mt-6 max-w-3xl text-lg leading-8 text-[color:var(--kern-text-muted)]">
      This page maps the current tooling surface: compiler, package manager,
      language server, and editor integration. The goal is to show the boundary
      between them clearly before the full tooling documentation is migrated here.
    </p>

    <div class="manual-callout mt-10">
      <div class="manual-kicker">Tooling Summary</div>
      <ul class="mt-4 space-y-2 text-base">
        <li>`kernc` compiles and links explicit inputs.</li>
        <li>`craft` owns workspaces, dependency resolution, and build planning.</li>
        <li>`kern-lsp` and the editor extension provide the interactive editing workflow.</li>
      </ul>
    </div>

    <section class="manual-section">
      <h2>Toolchain components</h2>
      <div class="manual-directory mt-6">
        {
          toolingProducts.map((tool) => (
            <a
              class="manual-directory-item"
              href={tool.href}
              target={tool.href.startsWith("http") ? "_blank" : undefined}
              rel={tool.href.startsWith("http") ? "noreferrer" : undefined}
            >
              <div class="manual-directory-heading">
                <div class="manual-directory-title">{tool.name}</div>
                <div class="manual-directory-meta">Tool</div>
              </div>
              <div class="manual-directory-body">{tool.summary}</div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="manual-section">
      <h2>Common paths</h2>
      <div class="manual-directory mt-6">
        <div class="manual-directory-item">
          <div class="manual-directory-heading">
            <div class="manual-directory-title">Install the toolchain</div>
            <div class="manual-directory-meta">Setup</div>
          </div>
          <div class="manual-directory-body">
            Start from the official installer path unless you are deliberately working on the repository.
          </div>
          <div class="manual-directory-links">
            <a href={internalHref("/install")}>Open install page</a>
          </div>
        </div>

        <div class="manual-directory-item">
          <div class="manual-directory-heading">
            <div class="manual-directory-title">Configure the editor</div>
            <div class="manual-directory-meta">Editor</div>
          </div>
          <div class="manual-directory-body">
            Set up VS Code, understand `kern-lsp` resolution, and use the basic editor commands when analysis changes.
          </div>
          <div class="manual-directory-links">
            <a href={internalHref("/tooling/editor-setup")}>Open editor setup</a>
          </div>
        </div>

        <div class="manual-directory-item">
          <div class="manual-directory-heading">
            <div class="manual-directory-title">Build the tools from source</div>
            <div class="manual-directory-meta">Repository</div>
          </div>
          <div class="manual-directory-body">
            Build local developer binaries, then distinguish them clearly from release-quality packaged SDK artifacts.
          </div>
          <div class="manual-directory-links">
            <a href={internalHref("/build-from-source")}>Open source build guide</a>
          </div>
        </div>
      </div>
    </section>

    <section class="manual-section">
      <h2>Repository sources</h2>
      <p class="mt-4 max-w-3xl text-base">
        Some tooling details still live in repository-native documents and source directories.
      </p>
      <div class="manual-directory mt-6">
        <div class="manual-directory-item">
          <div class="manual-directory-heading">
            <div class="manual-directory-title">VS Code extension source</div>
            <div class="manual-directory-meta">Repository</div>
          </div>
          <div class="manual-directory-body">
            The first-party extension source, packaging scripts, and workspace development entrypoint.
          </div>
          <div class="manual-directory-links">
            <a href={`${siteMeta.repoUrl}/tree/main/editors/vscode`} target="_blank" rel="noreferrer">Open repository directory</a>
          </div>
        </div>
      </div>
    </section>
  </section>
</BaseLayout>
